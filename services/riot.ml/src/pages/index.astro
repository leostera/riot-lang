<script>
  document.querySelectorAll("[data-command-tabs]").forEach((root) => {
    const mobileQuery = window.matchMedia("(max-width: 860px)");
    const tabList = root.querySelector<HTMLElement>(".riot-command-tablist");
    const panelContainer = root.querySelector<HTMLElement>(".riot-command-panels");
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>('[role="tab"]'),
    );
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tabpanel"]'),
    );
    const initialPanelOrder = panels.slice();

    const activate = (tab: HTMLButtonElement) => {
      tabs.forEach((item) => {
        const selected = item === tab;
        item.setAttribute("aria-selected", selected ? "true" : "false");
        item.setAttribute("aria-expanded", selected ? "true" : "false");
        item.setAttribute("tabindex", mobileQuery.matches ? "0" : selected ? "0" : "-1");
      });

      panels.forEach((panel) => {
        panel.hidden = panel.id !== tab.getAttribute("aria-controls");
      });
    };

    const syncLayoutMode = () => {
      if (!tabList || !panelContainer) return;

      root.setAttribute("data-command-mode", mobileQuery.matches ? "accordion" : "tabs");

      if (mobileQuery.matches) {
        tabList.removeAttribute("role");
        tabList.removeAttribute("aria-orientation");
        tabs.forEach((tab) => {
          const panel = root.querySelector<HTMLElement>(
            `#${tab.getAttribute("aria-controls")}`,
          );
          tab.setAttribute("role", "button");
          tab.setAttribute("tabindex", "0");
          if (panel) {
            panel.removeAttribute("role");
            tab.insertAdjacentElement("afterend", panel);
          }
        });
      } else {
        tabList.setAttribute("role", "tablist");
        tabList.setAttribute("aria-orientation", "vertical");
        tabs.forEach((tab) => {
          tab.setAttribute("role", "tab");
        });
        initialPanelOrder.forEach((panel) => {
          panel.setAttribute("role", "tabpanel");
          panelContainer.append(panel);
        });
      }

      const selected =
        tabs.find((tab) => tab.getAttribute("aria-selected") === "true") ??
        tabs[0];
      if (selected) activate(selected);
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event: KeyboardEvent) => {
        if (mobileQuery.matches) return;

        const last = tabs.length - 1;
        const keyMap: Record<string, number> = {
          ArrowDown: index === last ? 0 : index + 1,
          ArrowRight: index === last ? 0 : index + 1,
          ArrowUp: index === 0 ? last : index - 1,
          ArrowLeft: index === 0 ? last : index - 1,
          Home: 0,
          End: last,
        };
        const nextIndex = keyMap[event.key];

        if (nextIndex === undefined) return;
        event.preventDefault();
        const next = tabs[nextIndex];
        if (!next) return;
        next.focus();
        activate(next);
      });
    });

    syncLayoutMode();
    mobileQuery.addEventListener("change", syncLayoutMode);
  });
</script>
