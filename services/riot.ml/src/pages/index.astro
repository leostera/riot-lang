---
import HeroAsciinemaPlayer from "../components/HeroAsciinemaPlayer.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const installCommand = "curl -sSL https://get.riot.ml | sh";
const introCastUrl = "/riot.cast";
---

<SiteLayout
  title="Riot · OCaml stack"
  description="Riot is an opinionated OCaml stack and toolchain for shipping actor-oriented, multi-core ready software."
>
  <div class="site-shell">
    <header class="site-header">
      <div class="site-brand" aria-label="Riot home">
        <a href="#top">Riot</a>
        <small>by <a href="https://x.com/leostera">@leostera</a></small>
      </div>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#why-riot">Why Riot</a>
        <a href="#try-riot">Try Riot</a>
        <a href="#use-cases">Use Cases</a>
        <a href="https://docs.riot.ml">Docs</a>
        <a href="https://pkgs.ml">Packages</a>
      </nav>
      <button
        class="theme-toggle"
        type="button"
        data-state="unchecked"
        data-theme-toggle
        role="switch"
        aria-checked="false"
        aria-label="Toggle dark mode"
      >
        <span class="theme-toggle__track" aria-hidden="true">
          <span class="theme-toggle__thumb" data-theme-icon>☼</span>
        </span>
      </button>
    </header>

    <main id="top">
      <section class="landing-hero" aria-labelledby="hero-title">
        <div class="landing-hero__copy">
          <div class="hero-flag" aria-hidden="true">🏴‍☠️</div>
          <h1 id="hero-title">Riot</h1>
          <p class="landing-hero__lede">There are many OCaml stacks, this one is mine.</p>

          <div class="command-strip" aria-label="Install Riot command">
            <code>{installCommand}</code>
            <button type="button" data-copy={installCommand}>copy</button>
          </div>

          <HeroAsciinemaPlayer castUrl={introCastUrl} />

          <a class="hero-agent-link" href="/llms.txt">Riot for agents → llms.txt</a>
        </div>
      </section>

      <section class="landing-section" id="why-riot" aria-labelledby="why-riot-title">
        <div class="section-heading">
          <p class="landing-eyebrow">Why Riot</p>
          <h2 id="why-riot-title">There are many OCaml stacks. This one is mine.</h2>
          <p>
            Riot is my take on what an ML stack should feel like in 2026:
            beautiful and practical, actor-based, multi-core ready, type-safe,
            vertically designed, and built for shipping.
          </p>
        </div>

        <div class="feature-row">
          <article class="feature-card">
            <h3>Optimized for developer joy</h3>
            <p>
              Riot gets out of the way and helps you build good software:
              fast feedback, useful defaults, clear output, recoverable errors,
              and no setup ritual before the work starts.
            </p>
          </article>
          <article class="feature-card">
            <h3>One piece, not many</h3>
            <p>
              Compiler, runtime, package manager, docs, registry, formatter,
              tests, diagnostics, and standard library should feel like parts of
              the same whole.
            </p>
          </article>
          <article class="feature-card">
            <h3>Built for shipping</h3>
            <p>
              Make it work, learn whether it matters, make it beautiful, make it
              fast where it needs to be fast, and keep shipping.
            </p>
          </article>
        </div>
      </section>

      <section class="landing-section landing-section--compact" id="try-riot" aria-labelledby="try-riot-title">
        <div class="section-heading">
          <p class="landing-eyebrow">Try Riot</p>
          <h2 id="try-riot-title">The command is <code>riot</code>.</h2>
          <p>
            The toolchain should feel like one surface. Riot handles the pieces
            that usually leak across separate commands, hidden configuration,
            and project-local folklore.
          </p>
        </div>

        <div class="try-surface">
          <div class="terminal" aria-label="Riot command examples">
            <div class="terminal__head">
              <span>~/projects/app</span>
              <span>riot</span>
            </div>
            <pre class="terminal__body"><span class="prompt">λ</span> riot new service
<span class="ok">created</span> service
<span class="muted">next:</span> cd service && riot test

<span class="prompt">λ</span> riot add std
<span class="ok">added</span> std 0.6.0

<span class="prompt">λ</span> riot test --json
<span class="ok">ok</span> 42 tests passed in 54ms</pre>
          </div>
          <div class="try-copy">
            <h3>It ships the daily loop.</h3>
            <ul class="compact-list">
              <li>automatic OCaml toolchain management</li>
              <li>zero-config formatting optimized for readable diffs</li>
              <li>linting with automatic fixes</li>
              <li>unit tests, property tests, snapshots, and benchmarks</li>
              <li>package search, install, docs, and publish flows</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="landing-section" id="use-cases" aria-labelledby="use-cases-title">
        <div class="section-heading">
          <p class="landing-eyebrow">What’s possible with Riot</p>
          <h2 id="use-cases-title">A stack for systems, services, packages, and tools.</h2>
          <p>
            Riot is not just a website and a command. It is the compiler-facing,
            runtime-facing, docs-facing, registry-facing path through building
            OCaml software.
          </p>
        </div>

        <div class="feature-row feature-row--wrap">
          <article class="feature-card">
            <h3>Actor services</h3>
            <p>
              Build software from actors that communicate via message passing.
              Spawn work, supervise it, and let the runtime rebalance across CPUs.
            </p>
            <a href="#actors">Runtime model</a>
          </article>
          <article class="feature-card">
            <h3>Modern packages</h3>
            <p>
              Publish to <a href="https://pkgs.ml">pkgs.ml</a>, generate docs, track
              package usage, and make package search useful from web and terminal.
            </p>
            <a href="https://pkgs.ml/p/std">Open std</a>
          </article>
          <article class="feature-card">
            <h3>Standard library</h3>
            <p>
              <code>std</code> covers core datatypes, collections, IO, time,
              networking, formats, crypto, actors, logging, telemetry, testing,
              benchmarking, and more.
            </p>
            <a href="https://pkgs.ml/p/std">Browse package</a>
          </article>
          <article class="feature-card">
            <h3>Agent-ready workflows</h3>
            <p>
              Commands can run non-interactively, diagnostics have ids, and
              structured output gives tools enough context to help without guessing.
            </p>
            <a href="/llms.txt">Read llms.txt</a>
          </article>
        </div>
      </section>

      <section class="landing-section" id="actors" aria-labelledby="actors-title">
        <div class="split-section">
          <div class="section-heading">
            <p class="landing-eyebrow">Actors</p>
            <h2 id="actors-title">Concurrency is the default shape.</h2>
          </div>
          <div class="riot-prose">
            <p>
              Riot runs on an actor-model, multi-core runtime for OCaml. Like
              Erlang and Elixir, you build software with actors that communicate
              via message passing. If you need parallelism, call
              <code>spawn</code> and the runtime does the rest.
            </p>
            <p>
              Spawning actors and sending messages is designed to be cheap enough
              that supervision, isolation, and concurrency become everyday tools.
            </p>
          </div>
        </div>
      </section>

      <section class="landing-section" id="get-started" aria-labelledby="get-started-title">
        <div class="section-heading">
          <p class="landing-eyebrow">Get started with Riot</p>
          <h2 id="get-started-title">Install it. Break it. Help shape it.</h2>
          <p>
            Riot is useful enough to build with and experimental enough that the
            edges still matter. Try it, publish packages, and report where the
            stack is sharp in the wrong places.
          </p>
        </div>

        <div class="resource-list">
          <a class="resource-row" href="https://docs.riot.ml">
            <b>Read the docs</b>
            <span>Concepts, commands, and workflow guidance.</span>
          </a>
          <a class="resource-row" href="https://pkgs.ml">
            <b>Search packages</b>
            <span>Find packages, docs, metadata, freshness, and install commands.</span>
          </a>
          <a class="resource-row" href="https://github.com/leostera/riot">
            <b>Open the source</b>
            <span>Compiler, runtime, packages, services, and design work.</span>
          </a>
          <a class="resource-row" href="https://github.com/sponsors/leostera">
            <b>Sponsor the work</b>
            <span>Help turn this into the Rails of OCaml.</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand">
          <h2>Riot</h2>
          <p>
            An opinionated OCaml stack for building software that works, shipping it
            quickly, making it beautiful when it proves useful, and enjoying the work
            along the way.
          </p>
        </div>

        <div class="site-footer__links">
          <div class="site-footer__group">
            <b>Riot</b>
            <a href="https://github.com/leostera/riot">Source</a>
            <a href="https://docs.riot.ml">Docs</a>
            <a href="/llms.txt">For agents</a>
          </div>
          <div class="site-footer__group">
            <b>Stack</b>
            <a href="https://pkgs.ml">pkgs.ml</a>
            <a href="https://docs.riot.ml">docs.riot.ml</a>
            <a href="https://get.riot.ml">get.riot.ml</a>
          </div>
          <div class="site-footer__group">
            <b>Author</b>
            <a href="https://leostera.com">@leostera</a>
            <a href="https://github.com/sponsors/leostera">Sponsor</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
</SiteLayout>
