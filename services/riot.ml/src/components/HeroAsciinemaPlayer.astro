---
interface Props {
  castUrl: string;
  title?: string;
}

const {
  castUrl,
  title,
} = Astro.props;
---

<div class="mx-auto mt-6 max-w-2xl text-left">
  {
    typeof title === "string" && title.length > 0 ? (
      <p class="mb-3 text-center text-xs uppercase tracking-[0.16em] text-[#c8afb7]">
        {title}
      </p>
    ) : null
  }
  <div class="overflow-hidden rounded-[1.125rem] border border-[#32242a] bg-[linear-gradient(180deg,#121720,#0d1117)] px-3 py-3 shadow-[0_20px_80px_rgba(0,0,0,0.45)]">
    <div
      class="overflow-hidden rounded-[0.95rem] border border-[#32242a] bg-[#0f141b]"
      data-asciinema-player
      data-cast-url={castUrl}
    ></div>
  </div>
</div>

<script>
  import * as AsciinemaPlayer from "asciinema-player";

  const mounts = document.querySelectorAll<HTMLElement>("[data-asciinema-player]");

  for (const mount of mounts) {
    const src = mount.dataset.castUrl;
    const initialized = mount.dataset.playerInitialized === "true";

    if (initialized || typeof src !== "string" || src.length === 0) {
      continue;
    }

    AsciinemaPlayer.create(src, mount, {
      autoPlay: true,
      preload: true,
      poster: "npt:0:01",
      fit: "width",
      controls: false,
      speed: 1.05,
      idleTimeLimit: 1.2,
    });

    mount.dataset.playerInitialized = "true";
  }
</script>
