---
import PageRail from "@/components/jollyroger/PageRail.astro";
import ApplicationsSection from "@/components/jollyroger/sections/ApplicationsSection.astro";
import ComponentsSection from "@/components/jollyroger/sections/ComponentsSection.astro";
import FoundationsSection from "@/components/jollyroger/sections/FoundationsSection.astro";
import HeroSection from "@/components/jollyroger/sections/HeroSection.astro";
import JollyFooter from "@/components/jollyroger/sections/JollyFooter.astro";
import PrinciplesSection from "@/components/jollyroger/sections/PrinciplesSection.astro";
import VoiceSection from "@/components/jollyroger/sections/VoiceSection.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Riot’s Jolly Roger · Design System"
  description="Riot’s Jolly Roger is the flag, voice, and surface system for Riot."
>
  <div class="jr-app">
    <main class="jr-main" id="top">
      <div class="jr-content">
        <HeroSection />
        <div class="jr-page-body">
          <PageRail />
          <div class="jr-page-sections">
            <PrinciplesSection />
            <VoiceSection />
            <FoundationsSection />
            <ComponentsSection />
            <ApplicationsSection />
          </div>
        </div>
      </div>

      <JollyFooter />
    </main>
  </div>
</SiteLayout>
