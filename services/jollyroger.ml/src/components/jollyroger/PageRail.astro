---
interface TocItem {
  href: string;
  label: string;
}

interface TocGroup {
  key: string;
  title: string;
  href: string;
  items: TocItem[];
}

const navGroups: TocGroup[] = [
  {
    key: "principles",
    title: "Principles",
    href: "#principles",
    items: [
      { href: "#why-this-exists", label: "Why Riot?" },
      { href: "#principle-joy", label: "#01 - Optimize for Developer Joy" },
      { href: "#principle-platform", label: "#02 - Design as One Piece" },
      { href: "#principle-shipping", label: "#03 - Build for Shipping" },
      { href: "#principle-agent", label: "#04 - Human-led, agent-ready" },
      { href: "#principle-crew", label: "#05 - Trust Builders With Power" },
    ],
  },
  {
    key: "voice",
    title: "Voice",
    href: "#voice",
    items: [
      { href: "#voice-direct", label: "Direct" },
      { href: "#voice-useful", label: "Useful" },
      { href: "#voice-joyful", label: "Joyful" },
      { href: "#voice-errors", label: "Errors" },
      { href: "#voice-agents", label: "Agents" },
    ],
  },
  {
    key: "foundations",
    title: "Foundations",
    href: "#foundations",
    items: [
      { href: "#foundation-mark", label: "Mark" },
      { href: "#foundation-color", label: "Color" },
      { href: "#foundation-typography", label: "Typography" },
      { href: "#foundation-spacing", label: "Spacing" },
      { href: "#foundation-edges", label: "Edges" },
      { href: "#foundation-density", label: "Density" },
      { href: "#foundation-layout", label: "Layout" },
      { href: "#foundation-code", label: "Code and terminal" },
    ],
  },
  {
    key: "components",
    title: "Components",
    href: "#components",
    items: [
      { href: "#component-buttons", label: "Buttons" },
      { href: "#component-tables", label: "Tables" },
      { href: "#component-forms", label: "Forms" },
      { href: "#component-inputs", label: "Inputs" },
      { href: "#component-badges", label: "Badges" },
      { href: "#component-callouts", label: "Callouts" },
      { href: "#component-cards", label: "Cards" },
      { href: "#component-code", label: "Code" },
    ],
  },
  {
    key: "applications",
    title: "Applications",
    href: "#applications",
    items: [
      { href: "#app-riot", label: "Web" },
      { href: "#app-pkgs", label: "Registry" },
      { href: "#app-docs", label: "Docs" },
      { href: "#app-cli", label: "CLI output" },
      { href: "#app-errors", label: "Error pages" },
    ],
  },
];
---

<nav class="jr-chapter-nav" aria-label="Page navigation">
  <div class="jr-chapter-label jr-chapter-label--toc">
    <b>Table of Contents</b>
  </div>

  <div class="jr-chapter-groups">
    {
      navGroups.map((group) => (
        <div class="jr-chapter-group">
          <a class="jr-chapter-group__title" href={group.href} data-toc-link>
            {group.title}
          </a>
          <div class="jr-chapter-links">
            {group.items.map((item) => (
              <div class="jr-toc-item">
                <a href={item.href} data-toc-link>{item.label}</a>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</nav>

<script>
  const tocLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
  );
  const linkById = new Map(
    tocLinks
      .map((link) => [link.hash.slice(1), link] as const)
      .filter(([id]) => id.length > 0),
  );
  const tocTargets = Array.from(linkById.keys())
    .map((id) => document.getElementById(id))
    .filter((element): element is HTMLElement => element !== null);

  let queued = false;

  function setCurrentTocLink(id: string) {
    tocLinks.forEach((link) => {
      link.removeAttribute("aria-current");
      link.closest(".jr-chapter-group")?.classList.remove("jr-chapter-group--current");
    });

    const currentLink = linkById.get(id);
    if (!currentLink) return;

    currentLink.setAttribute("aria-current", "location");
    currentLink
      .closest(".jr-chapter-group")
      ?.classList.add("jr-chapter-group--current");
  }

  function updateTocCursor() {
    queued = false;
    const cursorLine = window.innerHeight / 4;
    let currentTarget = tocTargets[0];

    for (const target of tocTargets) {
      if (target.getBoundingClientRect().top <= cursorLine) {
        currentTarget = target;
      } else {
        break;
      }
    }

    if (currentTarget) {
      setCurrentTocLink(currentTarget.id);
    }
  }

  function queueTocUpdate() {
    if (queued) return;
    queued = true;
    window.requestAnimationFrame(updateTocCursor);
  }

  window.addEventListener("scroll", queueTocUpdate, { passive: true });
  window.addEventListener("resize", queueTocUpdate);
  updateTocCursor();
</script>
