---
import { Card } from "@/components/ui/card";

interface Props {
  id: string;
  url: string;
  class?: string;
}

const { id, url, class: className } = Astro.props;
---

<Card className={["jr-mock", className].filter(Boolean).join(" ")} id={id}>
  <div class="jr-mock__bar">
    <div class="jr-mock__dots"><span></span><span></span><span></span></div>
    <span>{url}</span>
  </div>
  <slot />
</Card>
