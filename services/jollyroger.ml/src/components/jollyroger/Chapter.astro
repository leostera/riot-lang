---
interface ChapterLink {
  href: string;
  label: string;
}

interface Props {
  id: string;
  number: string;
  section: string;
  subtitle?: string;
  links?: ChapterLink[];
  kicker: string;
  title: string;
  copy: string;
  copyId?: string;
}

const { id, number, section, subtitle, links = [], kicker, title, copy, copyId } =
  Astro.props;
---

<section class="jr-section" id={id}>
  <div class="jr-chapter">
    <nav class="jr-chapter-nav" aria-label={`${section} navigation`}>
      <div class="jr-chapter-label">
        <span>{number}</span>
        <b>{section}</b>
        {subtitle && <small>{subtitle}</small>}
      </div>
      {
        links.length > 0 && (
          <div class="jr-chapter-links">
            {links.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        )
      }
    </nav>
    <div class="jr-section-body">
      <div class="jr-intro">
        <p class="jr-kicker">{kicker}</p>
        <h2>{title}</h2>
        <p id={copyId}>{copy}</p>
      </div>
      <slot />
    </div>
  </div>
</section>
