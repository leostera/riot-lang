---
import FlagMark from "../FlagMark.astro";
---

<footer class="home-footer">
  <div class="jr-content">
    <FlagMark size="xl" tone="coal" />
    <h2 class="jr-heading">Black flag.<br /><span class="jr-red">/</span> Sharp tools.</h2>
    <p>
      Riot’s Jolly Roger is the design system for my OCaml: a joyful, powerful,
      actor-based, type-safe, multi-core ready ML stack designed as one piece
      and built for shipping.
    </p>
    <div class="home-footer__grid">
      <div>
        <b>Document</b>
        <span>Brand and design system</span>
        <span>Principles, voice, foundations, components, applications</span>
        <span>May 2026</span>
      </div>
      <div>
        <b>Surfaces</b>
        <span>riot.ml</span>
        <span>pkgs.ml</span>
        <span>docs.pkgs.ml</span>
      </div>
      <div>
        <b>Assets</b>
        <span>Flag mark · SVG</span>
        <span>Color tokens · CSS</span>
        <span>Type scale · CSS</span>
      </div>
      <div>
        <b>Type</b>
        <span>Martian Mono</span>
        <span>JetBrains Mono</span>
        <span>Atkinson Hyperlegible</span>
      </div>
    </div>
  </div>
</footer>
