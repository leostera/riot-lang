---
import CodeBlock from "../CodeBlock.astro";
import FlagMark from "../FlagMark.astro";
import MockShell from "../MockShell.astro";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import {
  Table,
  TableBody,
  TableCaption,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";

const packages = [
  {
    name: "std",
    version: "0.4.0",
    description: "Standard library. Datatypes, collections, IO, time, formats.",
    category: "core",
    downloads: "1,247,890",
    updated: "today",
  },
  {
    name: "kernel",
    version: "0.0.18",
    description: "Core abstractions shared across the Riot ecosystem.",
    category: "core",
    downloads: "840,221",
    updated: "2d",
  },
  {
    name: "serde",
    version: "0.3.0",
    description: "Schema-driven serialization helpers for Riot data.",
    category: "format",
    downloads: "620,498",
    updated: "6h",
  },
  {
    name: "krasny",
    version: "0.2.1-rc",
    description: "Web framework on top of Riot’s actor runtime.",
    category: "web",
    downloads: "98,114",
    updated: "1d",
  },
];

---

<section class="jr-section" id="applications">
  <div class="jr-section-body">
      <div class="jr-intro">
        <p class="jr-kicker">In the wild</p>
        <h2 class="jr-heading">Real surfaces governed by the system.</h2>
        <p class="jr-copy">
          Each application names the surface, the reader's task, the required
          information, the traps to avoid, and the components that carry it.
        </p>
      </div>

      <div class="jr-stack">
        <MockShell id="app-riot" url="https://riot.ml">
          <div class="surface-rules">
            <div><b>Purpose</b><span>Make people think: this might be the ML stack I wanted.</span></div>
            <div><b>Must show</b><span>The stack, a real command, real code, and the path to install, learn, and ship.</span></div>
            <div><b>Avoid</b><span>Startup SaaS air, vague positioning, and technical proof buried below chrome.</span></div>
            <div><b>Primary components</b><span>Buttons, cards, code, and callouts.</span></div>
          </div>
          <div class="site-mini">
            <div>
              <p class="jr-kicker">riot.ml</p>
              <h3 class="jr-heading">Many OCaml stacks.<br /><span class="jr-red">/</span> One flies a flag.</h3>
              <p class="jr-copy">
                The Riot website makes the stack legible fast. Show the
                command, the stack, and the path to install, learn, and ship.
              </p>
              <div class="home-actions">
                <Button variant="primary" size="sm">Read docs</Button>
                <Button variant="ghost" size="sm" className="jr-mono">$ riot init app</Button>
              </div>
            </div>
            <div class="site-mini__packages">
              <Card className="mini-package">
                <div><b>std</b><span>@0.6.0</span></div>
                <p>Standard library surface for system work.</p>
                <small>published today</small>
              </Card>
              <Card className="mini-package">
                <div><b>kernel</b><span>@0.0.18</span></div>
                <p>Core abstractions shared across Riot.</p>
                <small>updated 6h ago</small>
              </Card>
            </div>
          </div>
        </MockShell>

        <MockShell id="app-pkgs" url="https://pkgs.ml">
          <div class="surface-rules">
            <div><b>Purpose</b><span>Help users find, compare, evaluate, and install packages.</span></div>
            <div><b>Must show</b><span>Name, version, docs status, freshness, owner, install command, and compatibility context.</span></div>
            <div><b>Avoid</b><span>Decorative cards when comparison is the task.</span></div>
            <div><b>Primary components</b><span>Tables, badges, forms, inputs, and callouts.</span></div>
          </div>
          <div class="package-title">
            <div class="package-title__name">
              <FlagMark size="sm" />
              pkgs<span class="jr-red">.ml</span>
            </div>
            <Badge variant="mint">1,247 packages</Badge>
          </div>
          <div class="package-stats">
            <div class="package-stat"><b>Total packages</b><span>1,247</span></div>
            <div class="package-stat"><b>Downloads</b><span>8.4M</span></div>
            <div class="package-stat"><b>Publishers</b><span>309</span></div>
            <div class="package-stat"><b>Median publish</b><span>1.8s</span></div>
          </div>
          <div class="package-body">
            <Table aria-label="Registry package comparison table">
              <TableCaption>Registry package comparison</TableCaption>
              <TableHeader>
                <TableRow>
                  <TableHead>Package</TableHead>
                  <TableHead>Version</TableHead>
                  <TableHead>Description</TableHead>
                  <TableHead>Category</TableHead>
                  <TableHead className="num">Downloads</TableHead>
                  <TableHead className="num">Updated</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {
                  packages.map((pkg) => (
                    <TableRow>
                      <TableCell><b>{pkg.name}</b></TableCell>
                      <TableCell><Badge variant="mint">{pkg.version}</Badge></TableCell>
                      <TableCell>{pkg.description}</TableCell>
                      <TableCell>{pkg.category}</TableCell>
                      <TableCell className="num">{pkg.downloads}</TableCell>
                      <TableCell className="num">{pkg.updated}</TableCell>
                    </TableRow>
                  ))
                }
              </TableBody>
            </Table>
          </div>
        </MockShell>

        <MockShell
          id="app-docs"
          url="https://docs.pkgs.ml/p/kernel/0.0.18/Kernel/Result"
          class="docs-mock"
        >
          <div class="surface-rules">
            <div><b>Purpose</b><span>Help readers understand generated API documentation without losing orientation.</span></div>
            <div><b>Must show</b><span>Package, version, module, breadcrumbs, search, local navigation, signatures, examples, and stability markers.</span></div>
            <div><b>Avoid</b><span>Decorative chrome around generated reference material.</span></div>
            <div><b>Primary components</b><span>Tables, cards, code, callouts, and badges.</span></div>
          </div>
          <div class="docs-mock__top">
            <a class="jr-brand" href="#applications">
              <FlagMark size="sm" />
              <span>Riot <small>Docs</small></span>
            </a>
            <span>kernel / Kernel / <b>Result</b></span>
            <Badge variant="riot">v0.0.18</Badge>
          </div>
          <div class="docs-mock__body">
            <aside>
              <b>Modules</b>
              <span>Kernel</span>
              <span>.Core</span>
              <span>.Time</span>
              <span class="active">.Result</span>
              <span>.Option</span>
            </aside>
            <main>
              <p class="jr-kicker">module · Kernel.Result</p>
              <h3 class="jr-heading">Result</h3>
              <p class="jr-copy">
                Errors are values. Results carry them through pipelines, actor
                boundaries, and logs.
              </p>
              <CodeBlock label="Signature"><span class="t-key">type</span> ('a, 'e) t = Ok of 'a | Error of 'e
<span class="t-key">val</span> map : ('a -> 'b) -> ('a, 'e) t -> ('b, 'e) t</CodeBlock>
              <Alert>
                <AlertTitle>Note</AlertTitle>
                <AlertDescription>
                  <p>
                    Use <code>let*</code> for chains. Stop nesting binds when
                    the next step can fail.
                  </p>
                </AlertDescription>
              </Alert>
            </main>
          </div>
        </MockShell>

        <MockShell id="app-cli" url="terminal surfaces">
          <div class="surface-rules">
            <div><b>Purpose</b><span>Tell the user what happened and what to do next in plain text.</span></div>
            <div><b>Must show</b><span>Status, package, version, source when relevant, diagnostic IDs, and copyable next commands.</span></div>
            <div><b>Avoid</b><span>Noisy success output, fake terminal theater, and prose that breaks scripts.</span></div>
            <div><b>Primary components</b><span>Code, badges, tables, and callouts.</span></div>
          </div>
          <div class="cli-grid">
            <div>
              <p class="jr-kicker">CLI</p>
              <h3 class="jr-subheading">Plain text still carries the brand.</h3>
              <p class="jr-copy">
                Prompts, aligned labels, diagnostic IDs, and fix commands work
                without browser chrome.
              </p>
            </div>
            <CodeBlock label="CLI output"><span class="t-prompt">λ</span> riot publish --dry-run
<span class="t-ok">ok</span> package checked
<span class="t-muted">package:</span> krasny
<span class="t-muted">version:</span> 0.2.1
<span class="t-link">next:</span> run riot publish</CodeBlock>
          </div>
        </MockShell>

        <MockShell id="app-errors" url="https://pkgs.ml/not-found">
          <div class="surface-rules">
            <div><b>Purpose</b><span>Turn a dead end into a recovery path.</span></div>
            <div><b>Must show</b><span>Problem, context, possible cause, fix, and fallback.</span></div>
            <div><b>Avoid</b><span>Cute dead ends, jokes instead of recovery, and errors with no next action.</span></div>
            <div><b>Primary components</b><span>Callouts, code, buttons, and badges.</span></div>
          </div>
          <div class="cli-grid">
            <div>
              <p class="jr-kicker">Error pages</p>
              <h3 class="jr-subheading">Useful dead ends.</h3>
              <p class="jr-copy">
                Error pages are diagnostics in web form. Explain what failed,
                whether it is local or remote, and what the user can do next.
              </p>
              <CodeBlock label="Anatomy">problem: package not found
context: registry search
possible cause: misspelled package name
fix: search for krasny
fallback: publish a new package</CodeBlock>
            </div>
            <Alert variant="danger">
              <AlertTitle>Package not found</AlertTitle>
              <AlertDescription>
                <p>
                  No package named <code>krasney</code> exists in the registry.
                  Search for <code>krasny</code> or publish a new package.
                </p>
              </AlertDescription>
            </Alert>
          </div>
        </MockShell>
      </div>
  </div>
</section>
