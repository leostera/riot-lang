---
import FlagMark from "../FlagMark.astro";
---

<section class="home-hero flex items-center justify-center overflow-hidden" id="hero" aria-labelledby="hero-title">
  <div class="home-hero__stack flex w-[min(100%,var(--jr-hero-content-width))] max-w-[var(--jr-hero-content-width)] flex-col items-center">
    <FlagMark size="xl" label="Riot’s Jolly Roger" class="home-hero__mark" />
    <h1 class="home-hero__title flex w-[min(100%,var(--jr-hero-title-max-width))] min-w-0 flex-row flex-wrap items-center justify-center" id="hero-title">
      <span>Riot’s</span>
      <span>Jolly Roger</span>
    </h1>
    <p class="lede home-hero__subtitle min-w-0 w-[min(100%,var(--jr-hero-lead-max-width))]">
      The design system for RiotML: one voice across web, CLI, docs, packages,
      diagnostics, releases.
    </p>
    <a class="button tertiary mono mt-[var(--jr-space-5)]" href="/llms.txt">
      For agents · llms.txt
    </a>
  </div>
</section>
