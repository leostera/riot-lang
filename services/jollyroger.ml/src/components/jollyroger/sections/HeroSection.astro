---
import FlagMark from "../FlagMark.astro";
---

<section class="home-hero" id="hero" aria-labelledby="hero-title">
  <div class="home-hero__stack">
    <FlagMark size="xl" label="Riot’s Jolly Roger" class="home-hero__mark" />
    <h1 class="jr-display" id="hero-title">
      <span>Riot’s Jolly</span>
      <span>Roger</span>
    </h1>
    <p class="jr-lede">
      The flag and surface system for RiotML: one voice across web, CLI, docs,
      packages, diagnostics, and releases.
    </p>
  </div>
</section>
