---
import ComponentRow from "../ComponentRow.astro";
import CodeBlock from "../CodeBlock.astro";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  Table,
  TableBody,
  TableCaption,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { Textarea } from "@/components/ui/textarea";

const buttonRows = [
  ["Primary", "One main action on the surface.", "Install Riot"],
  ["Default", "A secondary action with normal weight.", "Read docs"],
  ["Dark", "A technical or source-adjacent action.", "View source"],
  ["Ghost", "A quiet command-shaped action.", "$ riot init app"],
  ["Small", "Compact toolbars and dense forms.", "Add"],
];

const badgeRows = [
  ["Default", "Neutral categories and tags.", "stdlib"],
  ["Solid", "Strong version or status metadata.", "v0.6.0"],
  ["Riot", "Identity, risk, or attention.", "unstable"],
  ["Mint", "Readiness, success, passing checks.", "stable"],
  ["Amber", "Caution, beta state, review needed.", "beta"],
];
---

<section class="jr-section" id="components">
  <div class="jr-section-body">
    <div class="jr-intro">
      <p class="jr-kicker">Components</p>
      <h2>Reusable primitives with Riot judgment.</h2>
      <p>
        Components are repeated decisions. Buttons, tables, forms, inputs,
        badges, callouts, cards, and code should look like the same system and
        carry the same voice.
      </p>
    </div>

    <div class="component-grid">
      <ComponentRow id="component-buttons" title="Buttons" description="Direct, compact, imperative actions." block>
        <Table aria-label="Button variant rules">
          <TableCaption>Button variant rules</TableCaption>
          <TableHeader>
            <TableRow>
              <TableHead>Variant</TableHead>
              <TableHead>Use for</TableHead>
              <TableHead>Example</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {buttonRows.map(([name, use, label]) => (
              <TableRow>
                <TableCell><b>{name}</b></TableCell>
                <TableCell>{use}</TableCell>
                <TableCell>
                  {name === "Primary" && <Button variant="primary" size="sm">{label}</Button>}
                  {name === "Default" && <Button size="sm">{label}</Button>}
                  {name === "Dark" && <Button variant="dark" size="sm">{label}</Button>}
                  {name === "Ghost" && <Button variant="ghost" size="sm" className="mono">{label}</Button>}
                  {name === "Small" && <Button variant="primary" size="sm">{label}</Button>}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </ComponentRow>

      <ComponentRow id="component-tables" title="Tables" description="Let users scan and compare dense structured information." block>
        <div class="component-variant-list">
          <div class="component-variant component-variant--block">
            <Table aria-label="Package metadata comparison table">
              <TableCaption>Package metadata comparison</TableCaption>
              <TableHeader>
                <TableRow>
                  <TableHead>Package</TableHead>
                  <TableHead>Version</TableHead>
                  <TableHead>Docs</TableHead>
                  <TableHead>Owner</TableHead>
                  <TableHead className="num">Updated</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                <TableRow><TableCell><b>std</b></TableCell><TableCell><Badge variant="mint">0.6.0</Badge></TableCell><TableCell>ready</TableCell><TableCell>core</TableCell><TableCell className="num">today</TableCell></TableRow>
                <TableRow><TableCell><b>kernel</b></TableCell><TableCell><Badge variant="mint">0.0.18</Badge></TableCell><TableCell>ready</TableCell><TableCell>core</TableCell><TableCell className="num">2d</TableCell></TableRow>
                <TableRow><TableCell><b>krasny</b></TableCell><TableCell><Badge variant="riot">0.2.1</Badge></TableCell><TableCell>partial</TableCell><TableCell>web</TableCell><TableCell className="num">1d</TableCell></TableRow>
              </TableBody>
            </Table>
          </div>
          <div class="component-variant component-variant--block">
            <Table aria-label="Benchmark comparison table">
              <TableCaption>Benchmark comparison</TableCaption>
              <TableHeader>
                <TableRow>
                  <TableHead>Run</TableHead>
                  <TableHead className="num">Mean</TableHead>
                  <TableHead className="num">P95</TableHead>
                  <TableHead className="num">Delta</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                <TableRow><TableCell><b>baseline</b></TableCell><TableCell className="num">42 ms</TableCell><TableCell className="num">68 ms</TableCell><TableCell className="num">0%</TableCell></TableRow>
                <TableRow><TableCell><b>current</b></TableCell><TableCell className="num">37 ms</TableCell><TableCell className="num">54 ms</TableCell><TableCell className="num">-12%</TableCell></TableRow>
              </TableBody>
            </Table>
          </div>
        </div>
      </ComponentRow>

      <ComponentRow id="component-reference-rows" title="Reference rows" description="Dense generated docs need rows and details that behave like source, not product cards." block>
        <div class="component-variant-list">
          <div class="component-variant component-variant--block">
            <div class="jr-reference-list" aria-label="Generated docs module index">
              <a class="jr-reference-row" href="#component-reference-rows">
                <span class="jr-reference-row__name">Agent</span>
                <span class="jr-reference-row__summary">Simple concurrent state access.</span>
              </a>
              <a class="jr-reference-row" href="#component-reference-rows">
                <span class="jr-reference-row__name">Array</span>
                <span class="jr-reference-row__summary">Resizable, indexed collections for dense data.</span>
              </a>
              <a class="jr-reference-row" href="#component-reference-rows">
                <span class="jr-reference-row__name">Result</span>
                <span class="jr-reference-row__summary">Errors as values, carried through pipelines.</span>
              </a>
            </div>
          </div>

          <div class="component-variant component-variant--block">
            <article class="jr-reference-detail" id="reference-row-detail-demo">
              <h4 class="jr-reference-detail__title">
                <span class="jr-kind jr-kind--fn">fn</span>
                <a href="#reference-row-detail-demo">start</a>
                <span class="jr-reference-detail__signature">: fn:(unit -&gt; 'state) -&gt; 'state t</span>
                <a class="jr-reference-detail__anchor" href="#reference-row-detail-demo" aria-label="Permalink">#</a>
              </h4>
              <p>
                Start an agent with the given initial state. The detail keeps
                the kind, name, signature, anchor, and explanation in one
                predictable shape.
              </p>
            </article>
          </div>
        </div>
      </ComponentRow>

      <ComponentRow id="component-forms" title="Forms" description="Group controls by the decision they support." block>
        <div class="component-variant-list">
          <div class="component-variant">
            <Label><span>Package name</span><Input value="std" readOnly aria-label="Package name" /></Label>
            <p>Fields keep labels close to values so compact forms still scan cleanly.</p>
          </div>
          <div class="component-variant">
            <Label><span>Version</span><Input value="^0.6.0" readOnly aria-label="Version" /></Label>
            <p>Version values stay mono and exact.</p>
          </div>
          <div class="component-variant">
            <Label><span>Visibility</span><Input value="public" readOnly aria-label="Visibility" /></Label>
            <p>Short fields read like configuration, not marketing copy.</p>
          </div>
        </div>
      </ComponentRow>

      <ComponentRow id="component-inputs" title="Inputs" description="Compact, labeled, bordered in ink." block>
        <div class="component-variant-list">
          <div class="component-variant">
            <Label><span>Search</span><Input placeholder="Search packages" aria-label="Search packages" /></Label>
            <p>Use placeholders for examples, not hidden labels.</p>
          </div>
          <div class="component-variant">
            <Label className="jr-field--wide">
              <span>Group note</span>
              <Textarea value="Group related controls by the decision they support." readOnly aria-label="Group note" />
            </Label>
            <p>Textareas follow the same border, type, and spacing rules as inputs.</p>
          </div>
        </div>
      </ComponentRow>

      <ComponentRow id="component-badges" title="Badges" description="Small status and metadata markers." block>
        <Table aria-label="Badge variant rules">
          <TableCaption>Badge variant rules</TableCaption>
          <TableHeader>
            <TableRow>
              <TableHead>Variant</TableHead>
              <TableHead>Use for</TableHead>
              <TableHead>Example</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {badgeRows.map(([name, use, label]) => (
              <TableRow>
                <TableCell><b>{name}</b></TableCell>
                <TableCell>{use}</TableCell>
                <TableCell>
                  {name === "Default" && <Badge>{label}</Badge>}
                  {name === "Solid" && <Badge variant="solid">{label}</Badge>}
                  {name === "Riot" && <Badge variant="riot">{label}</Badge>}
                  {name === "Mint" && <Badge variant="mint">{label}</Badge>}
                  {name === "Amber" && <Badge variant="amber">{label}</Badge>}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </ComponentRow>

      <ComponentRow id="component-callouts" title="Callouts" description="Interrupt only when the information changes what the reader should do." block>
        <div class="component-variant-list">
          <div class="component-variant component-variant--block">
            <Alert>
              <AlertTitle>Note</AlertTitle>
              <AlertDescription>
                <p>Use a note when context changes how the next paragraph reads.</p>
              </AlertDescription>
            </Alert>
          </div>
          <div class="component-variant component-variant--block">
            <Alert variant="warning">
              <AlertTitle>Caution</AlertTitle>
              <AlertDescription>
                <p>Foreign dependencies need visible platform caveats and a concrete recovery path.</p>
              </AlertDescription>
            </Alert>
          </div>
          <div class="component-variant component-variant--block">
            <Alert variant="danger">
              <AlertTitle>Danger</AlertTitle>
              <AlertDescription>
                <p>Use danger only when the reader can lose data, trust, or a working build.</p>
              </AlertDescription>
            </Alert>
          </div>
          <div class="component-variant component-variant--block">
            <Alert variant="success">
              <AlertTitle>Success</AlertTitle>
              <AlertDescription>
                <p>Use success when the system has completed something meaningful and recoverable.</p>
              </AlertDescription>
            </Alert>
          </div>
        </div>
      </ComponentRow>

      <ComponentRow id="component-cards" title="Cards" description="Use cards for one bounded object. Do not use cards to replace comparison tables." block>
        <div class="card-demo-list">
          <Card className="jr-example-card">
            <CardHeader>
              <span>Generated docs</span>
              <Badge variant="mint">ready</Badge>
            </CardHeader>
            <CardContent>
              <div class="jr-card-title">
                <b>std / Std.Agent</b>
                <span>API docs surface</span>
              </div>
              <p>
                Use a card when one object needs a bounded summary. This one
                names the package, module, status, and next place to go.
              </p>
              <div class="jr-card-meta" aria-label="Generated docs metadata">
                <div><b>Package</b><span>std</span></div>
                <div><b>Module</b><span>Std.Agent</span></div>
                <div><b>Items</b><span>8 functions · 1 type</span></div>
              </div>
              <Button variant="link" size="sm">Open generated docs</Button>
            </CardContent>
          </Card>
          <Card className="jr-example-card">
            <CardHeader>
              <span>Build report</span>
              <Badge variant="amber">review</Badge>
            </CardHeader>
            <CardContent>
              <div class="jr-card-title">
                <b>riot build</b>
                <span>Local workspace check</span>
              </div>
              <p>
                Cards can summarize one run, one report, or one setting group.
                Keep the next action visible and keep comparable data in rows.
              </p>
              <div class="jr-card-meta" aria-label="Build report metadata">
                <div><b>Status</b><span>needs review</span></div>
                <div><b>Target</b><span>services/jollyroger.ml</span></div>
                <div><b>Next</b><span>run riot check</span></div>
              </div>
              <Button variant="ghost" size="sm" className="mono">riot check</Button>
            </CardContent>
          </Card>
        </div>
      </ComponentRow>

      <ComponentRow id="component-code" title="Code" description="Code examples are product UI." block>
        <div class="component-variant-list">
          <div class="component-variant component-variant--block">
            <CodeBlock label="Code snippet"><span class="t-prompt">λ</span> riot fmt --check
<span class="t-ok">ok</span> 128 files formatted</CodeBlock>
          </div>
          <div class="component-variant component-variant--block">
            <CodeBlock label="Structured output">package: std
source:  src/lib.ri
fix:     riot add std</CodeBlock>
          </div>
        </div>
      </ComponentRow>
    </div>
  </div>
</section>
