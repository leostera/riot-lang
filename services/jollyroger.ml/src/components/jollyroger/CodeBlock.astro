---
import { Card, CardContent } from "@/components/ui/card";

interface Props {
  id?: string;
  label?: string;
  class?: string;
}

const { id, label, class: className } = Astro.props;
const classes = ["code-block", className].filter(Boolean).join(" ");
---

<Card className={classes} id={id}>
  {label && <div class="code-block__label">{label}</div>}
  <CardContent className="code-block__body">
    <pre><slot /></pre>
  </CardContent>
</Card>
