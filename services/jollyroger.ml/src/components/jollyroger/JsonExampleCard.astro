---
import { Card, CardContent } from "@/components/ui/card";
import hljs from "highlight.js/lib/core";
import json from "highlight.js/lib/languages/json";

interface Props {
  label: string;
  code: string;
}

hljs.registerLanguage("json", json);

const { label, code } = Astro.props;
const highlighted = hljs.highlight(code.trim(), { language: "json" }).value;
---

<Card className="jr-example-block jr-example-block--info jr-example-block--code">
  <div class="jr-example-block__label">{label}</div>
  <CardContent className="jr-example-block__body">
    <pre><code set:html={highlighted} /></pre>
  </CardContent>
</Card>
