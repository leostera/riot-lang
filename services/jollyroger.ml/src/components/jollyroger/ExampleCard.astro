---
import { Card, CardContent } from "@/components/ui/card";

interface Props {
  label: string;
  tone?: "bad" | "good" | "info";
}

const { label, tone = "info" } = Astro.props;
const classes = ["jr-example-block", `jr-example-block--${tone}`].join(" ");
---

<Card className={classes}>
  <div class="jr-example-block__label">{label}</div>
  <CardContent className="jr-example-block__body">
    <div class="jr-example-block__text"><slot /></div>
  </CardContent>
</Card>
