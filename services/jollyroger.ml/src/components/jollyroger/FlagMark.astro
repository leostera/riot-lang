---
interface Props {
  size?: "base" | "sm" | "xl" | "huge";
  tone?: "default" | "coal" | "riot";
  label?: string;
  class?: string;
}

const {
  size = "base",
  tone = "default",
  label,
  class: className,
} = Astro.props;

const classes = [
  "jr-flag",
  size !== "base" && `jr-flag--${size}`,
  tone === "coal" && "jr-flag--on-coal",
  tone === "riot" && "jr-flag--on-riot",
  className,
];
---

<span
  class:list={classes}
  aria-hidden={label ? undefined : "true"}
  aria-label={label}
  role={label ? "img" : undefined}
>
</span>
