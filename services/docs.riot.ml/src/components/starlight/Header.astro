---
import SiteTitle from "virtual:starlight/components/SiteTitle";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import { getTopTabForPath, topTabs } from "../../../docs-nav.mjs";

const pathname = Astro.url.pathname;
const activeTab = getTopTabForPath(pathname);
---

<div class="riot-header-shell">
  <div class="riot-header-top">
    <div class="riot-header-brand">
      <SiteTitle />
    </div>
    <div class="riot-header-actions print:hidden">
      <a class="riot-header-link" href="https://github.com/leostera/riot">GitHub</a>
      <ThemeSelect />
    </div>
  </div>

  <div class="riot-header-bottom print:hidden">
    <nav class="riot-top-tabs" aria-label="Top-level documentation sections">
      {
        topTabs.map((tab) => (
          <a
            class="riot-top-tab"
            data-current={activeTab?.label === tab.label ? "true" : undefined}
            href={tab.href}
            title={tab.description}
          >
            {tab.label}
          </a>
        ))
      }
    </nav>
  </div>
</div>
