---
import { env } from "cloudflare:workers";
import VscodeWorkbench from "@/components/VscodeWorkbench.tsx";
import { readPlayAuthenticatedSession, type PlayAuthEnv } from "@/lib/auth.ts";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { buildStarterWorkspace, parseWorkspaceDependencies } from "@/lib/workspace.ts";

const dependencies = parseWorkspaceDependencies(Astro.url.searchParams.get("deps"));
const workspace = buildStarterWorkspace(dependencies);
const authenticatedUser = await readPlayAuthenticatedSession(env as unknown as PlayAuthEnv, Astro.request);
const loginUrl = `https://api.pkgs.ml/v1/auth/github/start?return_to=${encodeURIComponent(
  Astro.url.toString(),
)}`;
---

<SiteLayout
  title="play.riot.ml"
  description="An in-browser Riot workspace for exploring packages and examples."
  immersive
>
  <VscodeWorkbench
    client:only="react"
    activePath={workspace.activePath}
    files={workspace.files}
    authenticated={authenticatedUser !== null}
    loginUrl={loginUrl}
  />
</SiteLayout>
