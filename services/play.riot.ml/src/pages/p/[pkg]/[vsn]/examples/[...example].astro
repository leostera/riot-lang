---
import VscodeWorkbench from "@/components/VscodeWorkbench.tsx";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchPackageExamples, fetchPackageOverview } from "@/lib/api.ts";
import { exampleLabel, examplePathFromRoute } from "@/lib/examples.ts";
import { buildExampleWorkspace } from "@/lib/workspace.ts";

const packageName = Astro.params.pkg ?? "";
const version = Astro.params.vsn ?? "";
const requestedTail = Astro.params.example ?? "";
const requestedPath = examplePathFromRoute(requestedTail);
const [overview, examples] = await Promise.all([
  fetchPackageOverview(packageName),
  fetchPackageExamples(packageName, { version }),
]);

const selectedExample = examples?.examples.find((example) => example.path === requestedPath) ?? null;

if (examples === null || selectedExample === null) {
  Astro.response.status = 404;
}

const displayTitle =
  selectedExample === null ? `${packageName} example not found` : `${packageName} · ${exampleLabel(selectedExample.path)}`;
const description =
  overview?.description ?? `Explore ${packageName} examples in the Riot Playground.`;
const workspace =
  selectedExample === null || examples === null
    ? null
    : buildExampleWorkspace({
        packageName,
        packageVersion: version,
        activeExamplePath: `/workspace/${selectedExample.path}`,
        examples: examples.examples.map((example) => ({
          path: `/workspace/${example.path}`,
          sourceCode: example.source_code,
        })),
      });
---

<SiteLayout title={`${displayTitle} · play.riot.ml`} description={description} immersive>
  {
    selectedExample ? (
      <VscodeWorkbench
        client:only="react"
        activePath={workspace?.activePath ?? "/workspace/src/main.ml"}
        files={workspace?.files ?? []}
      />
    ) : (
      <section class="mx-auto flex min-h-[calc(100vh-65px)] w-full max-w-5xl items-center px-4 py-8 sm:px-6">
        <div class="w-full rounded-2xl border border-white/10 bg-black/25 px-6 py-8 shadow-[0_24px_80px_rgba(0,0,0,0.22)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--color-copy-muted)]">
            Example not found
          </p>
          <h1 class="mt-3 font-heading text-2xl tracking-tight text-white">
            {packageName} does not have that example at {version}
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--color-copy-muted)]">
            Head back to the package page and pick one of the published examples for this release.
          </p>
          <div class="mt-5">
            <a
              href={`https://pkgs.ml/p/${encodeURIComponent(packageName)}/${encodeURIComponent(version)}`}
              class="inline-flex rounded-full border border-white/10 px-4 py-2 text-sm text-white transition hover:border-[var(--color-riot-red)]"
            >
              Back to package page
            </a>
          </div>
        </div>
      </section>
    )
  }
</SiteLayout>
