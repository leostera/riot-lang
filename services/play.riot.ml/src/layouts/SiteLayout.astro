---
import "@/styles/globals.css";

interface Props {
  title: string;
  description?: string;
  immersive?: boolean;
}

const { title, description = "Riot Play", immersive = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen">
    {
      immersive ? null : (
        <header class="border-b border-white/10 bg-black/20 backdrop-blur">
          <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
            <a href="/" class="font-heading text-lg tracking-tight text-white">
              ▶ play.riot.ml
            </a>
            <nav class="flex items-center gap-4 text-sm text-[var(--color-copy-muted)]">
              <a href="https://riot.ml" class="hover:text-white">Riot</a>
              <a href="https://pkgs.ml" class="hover:text-white">Packages</a>
              <a href="https://docs.riot.ml" class="hover:text-white">Docs</a>
            </nav>
          </div>
        </header>
      )
    }

    <main class:list={[immersive ? "h-screen" : ""]}>
      <slot />
    </main>
  </body>
</html>
