PUBLIC_CDN_BASE_URL=https://cdn.pkgs.ml
PUBLIC_INDEX_BASE_URL=https://api.pkgs.ml
PUBLIC_INDEX_BASE_PATH=v1/index
PUBLIC_REGISTRY_BASE_URL=https://api.pkgs.ml
# Optional override. Defaults to ${PUBLIC_REGISTRY_BASE_URL}/v1/search.
# PUBLIC_SEARCH_API_BASE_URL=https://api.pkgs.ml/v1/search

# Optional live smoke-test targets for `bun run test:e2e`
# PKGS_E2E_BASE_URL=https://pkgs.ml
# PKGS_E2E_SEARCH_API_BASE_URL=https://api.pkgs.ml/v1/search
# PKGS_E2E_PUBLISH_PACKAGE_LOCATOR=github.com/leostera/riot-new/packages/kernel
# PKGS_E2E_SESSION_COOKIE=pkgs_session=...
# PKGS_E2E_GITHUB_LOGIN=leostera
# REGISTRY_E2E_BASE_URL=https://api.pkgs.ml
# REGISTRY_E2E_ROOT_AUTH_TOKEN=
