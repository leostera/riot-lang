---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getConfig } from "@/lib/config";
import { fetchRegistryServiceDocument } from "@/lib/web-views";

interface SchemaField {
  name: string;
  type: string;
  notes: string;
}

interface SchemaSection {
  title: string;
  route: string;
  description: string;
  fields: SchemaField[];
  example: string;
}

const config = getConfig();
const service = await fetchRegistryServiceDocument();
const routeRows = Object.entries(service.routes);
const cdnRouteRows = Object.entries(service.cdn_routes);

function pretty(value: unknown): string {
  return JSON.stringify(value, null, 2);
}

const publishExample = [
  "curl -X POST https://api.pkgs.ml/v1/publish \\",
  "  -H \"Authorization: Bearer <publish-token>\" \\",
  "  -H \"Content-Type: application/gzip\" \\",
  "  --data-binary @package.tar.gz",
].join("\n");

const searchExample = "curl -fsSL 'https://api.pkgs.ml/v1/search?q=std'";
const discoveryExample = "curl -fsSL https://api.pkgs.ml/";
const indexExample = "curl -fsSL https://cdn.pkgs.ml/index/v1/config.json";

const schemaSections: SchemaSection[] = [
  {
    title: "Service discovery",
    route: "GET https://api.pkgs.ml/",
    description: "Machine-readable root document listing the live route surface.",
    fields: [
      { name: "service", type: "string", notes: "Registry service identifier." },
      { name: "routes", type: "object", notes: "Current control-plane routes keyed by purpose." },
      { name: "cdn_routes", type: "object", notes: "Current CDN/index/download routes keyed by purpose." },
      { name: "legacy_routes", type: "object", notes: "Backwards-compatible aliases still served." },
      { name: "cdn_base_url", type: "string", notes: "Base URL for CDN-backed public reads." },
      { name: "index_base_url", type: "string", notes: "Base URL for sparse-index reads." },
    ],
    example: pretty({
      service: "riot-package-registry",
      routes: {
        publish_artifact: "/v1/publish",
        search: "/v1/search?q=<query>",
        views_package_overview: "/v1/views/packages/<package-name>/overview",
      },
      cdn_routes: {
        index_config: "/index/v1/config.json",
        index_package: "/index/v1/<sharded-package-document>.json",
        artifact_download: "/<artifact-key>",
      },
      legacy_routes: {
        publish_artifact: "/api/v1/publish",
      },
      cdn_base_url: "https://cdn.pkgs.ml",
      index_base_url: "https://cdn.pkgs.ml/index/v1",
    }),
  },
  {
    title: "Search results",
    route: "GET https://api.pkgs.ml/v1/search?q=<query>",
    description: "Free-text package search over package names and indexed metadata.",
    fields: [
      { name: "query", type: "string", notes: "The user query echoed back." },
      { name: "count", type: "number", notes: "Total matching packages returned." },
      { name: "results", type: "SearchResult[]", notes: "Search hits ordered by registry ranking." },
      { name: "results[].package_name", type: "string", notes: "Published package name." },
      { name: "results[].latest_version", type: "string", notes: "Latest version currently indexed." },
      { name: "results[].description", type: "string | null", notes: "Latest package description." },
      { name: "results[].license", type: "string | null", notes: "Latest package license." },
      { name: "results[].repository", type: "string | null", notes: "Package repository URL, if present." },
      { name: "results[].updated_at", type: "string", notes: "Last update timestamp." },
    ],
    example: pretty({
      query: "std",
      count: 1,
      results: [
        {
          package_name: "std",
          normalized_name: "std",
          latest_version: "0.1.0",
          description: "Riot standard library",
          license: "Apache-2.0",
          homepage: null,
          repository: "https://github.com/leostera/riot",
          root_module: "Std",
          canonical_locator: "github.com/leostera/riot/packages/std",
          repo_url: "https://github.com/leostera/riot",
          repo_owner: "leostera",
          repo_name: "riot",
          subdir: "packages/std",
          release_count: 1,
          updated_at: "2026-04-04T09:00:00.000Z",
        },
      ],
    }),
  },
  {
    title: "Publish response",
    route: "POST https://api.pkgs.ml/v1/publish",
    description: "Response returned after successfully publishing a package-root artifact.",
    fields: [
      { name: "packageName", type: "string", notes: "Published package name." },
      { name: "packageVersion", type: "string", notes: "Published package version." },
      { name: "artifactSha256", type: "string", notes: "Immutable digest of the install artifact." },
      { name: "sourceKey", type: "string", notes: "Artifact storage key under the CDN surface." },
      { name: "manifestKey", type: "string", notes: "Manifest storage key under the CDN surface." },
      { name: "claimKey", type: "string", notes: "Package claim metadata object key." },
      { name: "releaseKey", type: "string", notes: "Release metadata object key." },
      { name: "indexChanged", type: "boolean", notes: "Whether the sparse index document changed." },
    ],
    example: pretty({
      artifactSha256: "e2d91c...f6ab",
      sourceKey: "sources/std/0.1.0/e2d91c...f6ab.tar.gz",
      manifestKey: "packages/std/0.1.0/e2d91c...f6ab.manifest.json",
      manifestCreated: true,
      sourceCreated: true,
      packageName: "std",
      packageVersion: "0.1.0",
      claimKey: "claims/std.json",
      releaseKey: "releases/std/0.1.0.json",
      claimCreated: true,
      releaseCreated: true,
      indexChanged: true,
    }),
  },
  {
    title: "Package overview view",
    route: "GET https://api.pkgs.ml/v1/views/packages/<package>/overview",
    description: "Summary view used by package detail pages.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current view schema version." },
      { name: "package_name", type: "string", notes: "Package name." },
      { name: "latest_version", type: "string", notes: "Latest published version." },
      { name: "artifact_sha256", type: "string", notes: "Digest of the latest install artifact." },
      { name: "source_key", type: "string", notes: "Artifact download key for the latest release." },
      { name: "owner_github_login", type: "string", notes: "Owning GitHub login shown on package pages." },
      { name: "release_count", type: "number", notes: "Total published versions." },
      { name: "dependency_count", type: "number", notes: "Direct dependency count for the latest release." },
      { name: "dependent_count", type: "number", notes: "Indexed dependents count." },
      { name: "download_count", type: "number", notes: "All-time package downloads recorded." },
      { name: "categories", type: "string[]", notes: "Indexed categories." },
      { name: "keywords", type: "string[]", notes: "Indexed keywords." },
    ],
    example: pretty({
      schema_version: 1,
      package_name: "kernel",
      latest_version: "0.0.1",
      updated_at: "2026-04-04T09:00:00.000Z",
      published_at: "2026-04-04T09:00:00.000Z",
      description: "Kernel package",
      license: "Apache-2.0",
      canonical_locator: "github.com/leostera/riot/packages/kernel",
      repo_url: "https://github.com/leostera/riot",
      subdir: "packages/kernel",
      source_key: "sources/kernel/0.0.1/abc123.tar.gz",
      manifest_key: "packages/kernel/0.0.1/abc123.manifest.json",
      artifact_sha256: "abc123",
      owner_github_login: "leostera",
      release_count: 1,
      dependency_count: 3,
      dependent_count: 5,
      download_count: 42,
      categories: ["systems"],
      keywords: ["runtime", "kernel"],
    }),
  },
  {
    title: "Package downloads view",
    route: "GET https://api.pkgs.ml/v1/views/packages/<package>/downloads",
    description: "Download graph data for the package detail page.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current view schema version." },
      { name: "package_name", type: "string", notes: "Package name." },
      { name: "latest_version", type: "string", notes: "Latest published version." },
      { name: "window_days", type: "number", notes: "Number of days included in daily_downloads." },
      { name: "total_downloads", type: "number", notes: "All-time downloads recorded for the package." },
      { name: "daily_downloads", type: "PackageDailyDownloadPoint[]", notes: "One point per day in the selected window." },
      { name: "version_downloads", type: "PackageVersionDownloadPoint[]", notes: "Per-version all-time download counts." },
    ],
    example: pretty({
      schema_version: 1,
      package_name: "kernel",
      latest_version: "0.0.1",
      generated_at: "2026-04-04T09:00:00.000Z",
      window_days: 30,
      total_downloads: 42,
      daily_downloads: [
        { date: "2026-04-02", download_count: 3 },
        { date: "2026-04-03", download_count: 9 },
        { date: "2026-04-04", download_count: 30 },
      ],
      version_downloads: [
        { version: "0.0.1", published_at: "2026-04-04T09:00:00.000Z", download_count: 42, is_latest: true },
      ],
    }),
  },
  {
    title: "Package relations view",
    route: "GET https://api.pkgs.ml/v1/views/packages/<package>/relations",
    description: "Dependencies and dependents for a package.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current view schema version." },
      { name: "package_name", type: "string", notes: "Package name." },
      { name: "updated_at", type: "string", notes: "Time the view was generated." },
      { name: "dependencies", type: "PackageRelationDependency[]", notes: "Direct dependencies with registry requirement strings." },
      { name: "dependents", type: "PackageRelationDependent[]", notes: "Packages that currently depend on this package." },
    ],
    example: pretty({
      schema_version: 1,
      package_name: "kernel",
      updated_at: "2026-04-04T09:00:00.000Z",
      dependencies: [
        { package_name: "std", requirement: "*" },
      ],
      dependents: [
        { package_name: "actors", latest_version: "0.0.1", requirement: "*" },
      ],
    }),
  },
  {
    title: "Registry events",
    route: "GET https://api.pkgs.ml/v1/events?limit=<count>&after=<event-id>",
    description: "Chronological package publication and indexing activity.",
    fields: [
      { name: "limit", type: "number | undefined", notes: "Requested page size." },
      { name: "after", type: "string | undefined", notes: "Cursor-style event id for polling newer events." },
      { name: "events", type: "RegistryEventRecord[]", notes: "Newest-first event list." },
      { name: "events[].event_type", type: "string", notes: "One of package.submitted, package.verified, package.published, package.indexed, package.searchable." },
      { name: "events[].payload", type: "object", notes: "Small event-specific payload used by the activity UIs." },
    ],
    example: pretty({
      limit: 2,
      after: "0195f6c1-3cc1-7c84-b0f4-8c7f7d7e5f3f",
      events: [
        {
          event_id: "0195f6c1-3d5b-7198-8f76-8d5880e66eb0",
          event_type: "package.published",
          package_name: "kernel",
          package_version: "0.0.1",
          package_locator: "github.com/leostera/riot/packages/kernel",
          payload: {
            artifact_sha256: "abc123",
            dependency_count: 3,
          },
          created_at: "2026-04-04T09:00:00.000Z",
        },
      ],
    }),
  },
  {
    title: "Stats summary view",
    route: "GET https://api.pkgs.ml/v1/views/stats/summary",
    description: "Homepage counters and small stats summaries.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current view schema version." },
      { name: "generated_at", type: "string", notes: "When the summary was generated." },
      { name: "total_package_downloads", type: "number", notes: "All recorded package installs." },
      { name: "total_riot_downloads", type: "number", notes: "All recorded Riot binary downloads." },
      { name: "total_ocaml_downloads", type: "number", notes: "All recorded OCaml toolchain downloads." },
      { name: "total_packages", type: "number", notes: "Published package count." },
      { name: "total_versions", type: "number", notes: "Published version count." },
      { name: "total_users", type: "number", notes: "Authenticated user count." },
    ],
    example: pretty({
      schema_version: 1,
      generated_at: "2026-04-04T09:00:00.000Z",
      total_package_downloads: 42,
      total_riot_downloads: 9,
      total_ocaml_downloads: 7,
      total_packages: 12,
      total_versions: 19,
      total_users: 4,
    }),
  },
  {
    title: "Sparse index config",
    route: "GET https://cdn.pkgs.ml/index/v1/config.json",
    description: "Registry bootstrap document for sparse-index clients.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current sparse index schema version." },
      { name: "kind", type: "\"sparse\"", notes: "Index format identifier." },
      { name: "package_path_strategy", type: "\"cargo-lowercase-v1\"", notes: "Sharding algorithm used for package documents." },
      { name: "index_base_url", type: "string", notes: "Base URL for package shard documents." },
      { name: "artifact_base_url", type: "string", notes: "Base URL for artifact downloads." },
    ],
    example: pretty({
      schema_version: 1,
      kind: "sparse",
      package_path_strategy: "cargo-lowercase-v1",
      index_base_url: "https://cdn.pkgs.ml/index/v1",
      artifact_base_url: "https://cdn.pkgs.ml",
    }),
  },
  {
    title: "Sparse package document",
    route: "GET https://cdn.pkgs.ml/index/v1/<sharded-package>.json",
    description: "Sparse-index package document consumed by solvers and installers.",
    fields: [
      { name: "schema_version", type: "1", notes: "Current sparse index schema version." },
      { name: "name", type: "string", notes: "Package name." },
      { name: "latest", type: "string", notes: "Latest version string." },
      { name: "updated_at", type: "string", notes: "Latest package update time." },
      { name: "releases", type: "IndexedPackageRelease[]", notes: "All published versions kept in the sparse index." },
      { name: "releases[].source_key", type: "string", notes: "Published install artifact key, joined with artifact_base_url." },
      { name: "releases[].manifest_key", type: "string", notes: "Manifest object key." },
      { name: "releases[].artifact_sha256", type: "string", notes: "Digest of the published install artifact." },
    ],
    example: pretty({
      schema_version: 1,
      name: "std",
      latest: "0.1.0",
      updated_at: "2026-04-04T09:00:00.000Z",
      releases: [
        {
          version: "0.1.0",
          published_at: "2026-04-04T09:00:00.000Z",
          canonical_locator: "github.com/leostera/riot/packages/std",
          repo_url: "https://github.com/leostera/riot",
          subdir: "packages/std",
          artifact_sha256: "abc123",
          description: "Riot standard library",
          license: "Apache-2.0",
          manifest_key: "packages/std/0.1.0/abc123.manifest.json",
          source_key: "sources/std/0.1.0/abc123.tar.gz",
          dependencies: [{ stdlib: "*" }],
        },
      ],
    }),
  },
];
---

<SiteLayout
  title="API · pkgs.ml"
  description="API and CDN surface for Riot’s OCaml package registry."
  navSearchQuery=""
>
  <section class="border-b border-border">
    <div class="mx-auto grid w-full max-w-6xl gap-3 px-4 py-8 sm:px-6">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a class="hover:text-foreground" href="/">home</a>
        <span>/</span>
        <span class="text-foreground">api</span>
      </nav>
      <div class="grid gap-2">
        <h1 class="font-heading text-2xl font-semibold tracking-tight text-foreground">
          pkgs.ml API
        </h1>
        <p class="max-w-3xl text-base leading-7 text-muted-foreground">
          The registry exposes two public surfaces: the control plane on <code>api.pkgs.ml</code>
          for publishing, search, auth, views, events, and stats; and the read plane on{" "}
          <code>cdn.pkgs.ml</code> for the sparse index, package artifacts, and Riot/OCaml
          distribution files.
        </p>
      </div>
    </div>
  </section>

  <section class="py-6">
    <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 sm:px-6">
      <div class="grid gap-4 lg:grid-cols-2">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Control plane</CardTitle>
            <CardDescription>
              Authenticated and query-style routes served from {config.registryBaseUrl}.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 py-4 text-base text-muted-foreground">
            <p>
              Use the control plane to search packages, fetch package views, list events, create
              API tokens, and publish artifacts.
            </p>
            <p>
              Machine-readable route discovery is available at <code>{config.registryBaseUrl}/</code>.
            </p>
            <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-sm text-foreground"><code>{discoveryExample}</code></pre>
          </CardContent>
        </Card>

        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">CDN read plane</CardTitle>
            <CardDescription>
              Sparse index and immutable download URLs served from {config.indexBaseUrl}.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 py-4 text-base text-muted-foreground">
            <p>
              Use the CDN surface to bootstrap the sparse index, read package shard documents, and
              download published artifacts.
            </p>
            <p>
              Start from <code>{service.index_base_url}/config.json</code>, then read package docs
              and fetch artifacts via <code>source_key</code>.
            </p>
            <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-sm text-foreground"><code>{indexExample}</code></pre>
          </CardContent>
        </Card>
      </div>

      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Control-plane routes</CardTitle>
            <CardDescription>
              Current public routes reported by the live registry service.
            </CardDescription>
          </CardHeader>
          <CardContent className="px-0">
            <div class="overflow-x-auto">
              <table class="w-full min-w-[560px] text-left text-sm">
                <thead class="border-b border-border text-muted-foreground">
                  <tr>
                    <th class="px-4 py-2 font-medium">Route</th>
                    <th class="px-4 py-2 font-medium">Path</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    routeRows.map(([name, path]) => (
                      <tr class="border-b border-border/70 last:border-b-0">
                        <td class="px-4 py-3 align-top font-medium text-foreground">{name}</td>
                        <td class="px-4 py-3 align-top text-muted-foreground">
                          <code>{path}</code>
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>

        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">CDN routes</CardTitle>
            <CardDescription>
              Public immutable download and sparse-index routes.
            </CardDescription>
          </CardHeader>
          <CardContent className="px-0">
            <div class="overflow-x-auto">
              <table class="w-full min-w-[420px] text-left text-sm">
                <thead class="border-b border-border text-muted-foreground">
                  <tr>
                    <th class="px-4 py-2 font-medium">Route</th>
                    <th class="px-4 py-2 font-medium">Path</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    cdnRouteRows.map(([name, path]) => (
                      <tr class="border-b border-border/70 last:border-b-0">
                        <td class="px-4 py-3 align-top font-medium text-foreground">{name}</td>
                        <td class="px-4 py-3 align-top text-muted-foreground">
                          <code>{path}</code>
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Examples</CardTitle>
            <CardDescription>
              Minimal requests for search, publishing, and route discovery.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-4 py-4">
            <div class="grid gap-2">
              <div class="text-sm font-medium text-foreground">Search</div>
              <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-sm text-foreground"><code>{searchExample}</code></pre>
            </div>

            <div class="grid gap-2">
              <div class="text-sm font-medium text-foreground">Publish artifact</div>
              <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-sm text-foreground"><code>{publishExample}</code></pre>
            </div>
          </CardContent>
        </Card>

        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Client model</CardTitle>
            <CardDescription>
              How third-party clients should think about the registry surface.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 py-4 text-base text-muted-foreground">
            <p>
              For package resolution, start from the sparse index config on <code>cdn.pkgs.ml</code>,
              then read package documents from the shard path and fetch package artifacts by joining{" "}
              <code>artifact_base_url</code> and the release <code>source_key</code>.
            </p>
            <p>
              For publishing, create a package-root <code>tar.gz</code> with <code>tusk.toml</code> at
              archive root and upload it to <code>POST /v1/publish</code> with a bearer token.
            </p>
            <p>
              For agents and non-human clients, see{" "}
              <a class="text-foreground hover:text-primary" href="/llms.txt">/llms.txt</a>.
            </p>
          </CardContent>
        </Card>
      </div>

      <Card size="sm" className="rounded-md shadow-none">
        <CardHeader className="border-b border-border">
          <CardTitle className="text-base">Schemas</CardTitle>
          <CardDescription>
            Public document shapes for the main control-plane and CDN endpoints.
          </CardDescription>
        </CardHeader>
        <CardContent className="grid gap-4 py-4">
          {
            schemaSections.map((section) => (
              <article class="grid gap-4 rounded-md border border-border bg-card px-4 py-4">
                <div class="grid gap-1">
                  <h2 class="text-base font-semibold text-foreground">{section.title}</h2>
                  <p class="text-sm text-muted-foreground">
                    <code>{section.route}</code>
                  </p>
                  <p class="text-base text-muted-foreground">{section.description}</p>
                </div>

                <div class="overflow-x-auto rounded-md border border-border">
                  <table class="w-full min-w-[720px] text-left text-sm">
                    <thead class="border-b border-border bg-muted/50 text-muted-foreground">
                      <tr>
                        <th class="px-3 py-2 font-medium">Field</th>
                        <th class="px-3 py-2 font-medium">Type</th>
                        <th class="px-3 py-2 font-medium">Notes</th>
                      </tr>
                    </thead>
                    <tbody>
                      {
                        section.fields.map((field) => (
                          <tr class="border-b border-border/70 last:border-b-0">
                            <td class="px-3 py-2 align-top font-medium text-foreground">
                              <code>{field.name}</code>
                            </td>
                            <td class="px-3 py-2 align-top text-muted-foreground">
                              <code>{field.type}</code>
                            </td>
                            <td class="px-3 py-2 align-top text-muted-foreground">{field.notes}</td>
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>

                <div class="grid gap-2">
                  <div class="text-sm font-medium text-foreground">Example</div>
                  <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-sm text-foreground"><code>{section.example}</code></pre>
                </div>
              </article>
            ))
          }
        </CardContent>
      </Card>
    </div>
  </section>
</SiteLayout>
