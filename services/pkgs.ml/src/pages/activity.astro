---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getConfig } from "@/lib/config.ts";
import {
  eventLabel,
  eventTone,
  formatEventTimestamp,
  formatEventTimestampCompact,
  packageActivityHref,
  packageLabel,
  secondaryFacts,
} from "@/lib/registry-events.ts";
import { fetchRegistryEvents } from "@/lib/web-views.ts";

const feed = await fetchRegistryEvents(100);
const registryBaseUrl = getConfig().registryBaseUrl;
const initialAfter = feed.events.length > 0 ? feed.events[0]?.event_id ?? "" : "";
---

<SiteLayout
  title="Activity · pkgs.ml"
  description="Live package publishing, indexing, and post-publish pipeline activity across the Riot package registry."
  showNavSearch={true}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-6">
      <div class="grid gap-2 border-b border-border pb-4">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div class="grid gap-1">
            <h1 class="font-heading text-2xl font-semibold tracking-tight text-foreground">
              Registry activity
            </h1>
            <p class="text-base text-muted-foreground">
              Publish, verification, indexing, and post-publish pipeline events across the registry.
            </p>
          </div>

          <div class="text-sm text-muted-foreground">
            Polling every 5 seconds
          </div>
        </div>
      </div>

      {
        feed.events.length === 0 ? (
          <div
            id="activity-empty"
            class="rounded-md border border-border bg-card px-4 py-5 text-base text-muted-foreground"
          >
            No registry activity has been recorded yet.
          </div>
        ) : (
          <div id="activity-empty" class="hidden rounded-md border border-border bg-card px-4 py-5 text-base text-muted-foreground">
            No registry activity has been recorded yet.
          </div>
        )
      }

      <div
        id="activity-feed"
        class="grid gap-2"
        data-registry-base-url={registryBaseUrl}
        data-after={initialAfter}
      >
        {feed.events.map((event) => {
          const facts = secondaryFacts(event);
          const targetHref = packageActivityHref(event);
          const payloadEntries = Object.entries(event.payload).filter(([, value]) => value !== undefined);
          const payloadJson = payloadEntries.length > 0 ? JSON.stringify(event.payload, null, 2) : null;

          return (
            <details class="group overflow-hidden rounded-md border border-border bg-card" data-event-id={event.event_id}>
              <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-3 marker:hidden">
                <div class="min-w-0 flex-1">
                  <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                    <time class="shrink-0 text-xs text-muted-foreground" datetime={event.created_at}>
                      {formatEventTimestampCompact(event.created_at)}
                    </time>
                    <span class:list={["inline-flex items-center rounded-sm border px-2 py-0.5 text-[11px] font-medium", eventTone(event.event_type)]}>
                      {eventLabel(event.event_type)}
                    </span>
                    {
                      targetHref ? (
                        <>
                          <span class="min-w-0 text-sm font-medium text-foreground md:hidden">
                            {packageLabel(event)}
                          </span>
                          <a href={targetHref} class="hidden min-w-0 text-sm font-medium text-foreground hover:text-primary md:inline-flex">
                            {packageLabel(event)}
                          </a>
                        </>
                      ) : (
                        <span class="min-w-0 text-sm font-medium text-foreground">
                          {packageLabel(event)}
                        </span>
                      )
                    }
                    {
                      facts.length > 0 ? (
                        <span class="min-w-0 text-sm text-muted-foreground sm:truncate">
                          {facts.join(" · ")}
                        </span>
                      ) : null
                    }
                  </div>
                </div>

                <span class="shrink-0 text-xs text-muted-foreground group-open:hidden">Details</span>
                <span class="hidden shrink-0 text-xs text-muted-foreground group-open:inline">Hide</span>
              </summary>

              <div class="grid gap-4 border-t border-border px-4 py-3">
                <dl class="grid gap-3 sm:grid-cols-2">
                  <div class="grid gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">When</dt>
                    <dd class="text-sm text-foreground">{formatEventTimestamp(event.created_at)}</dd>
                  </div>

                  <div class="grid gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Event</dt>
                    <dd>
                      <span class:list={["inline-flex w-fit items-center rounded-sm border px-2 py-0.5 text-xs font-medium", eventTone(event.event_type)]}>
                        {eventLabel(event.event_type)}
                      </span>
                    </dd>
                  </div>

                  {
                    event.package_name ? (
                      <div class="grid gap-1">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Package</dt>
                        <dd class="text-sm text-foreground">{event.package_name}</dd>
                      </div>
                    ) : null
                  }

                  {
                    event.package_version ? (
                      <div class="grid gap-1">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Version</dt>
                        <dd class="text-sm text-foreground">{event.package_version}</dd>
                      </div>
                    ) : null
                  }

                  {
                    event.package_locator ? (
                      <div class="grid gap-1 sm:col-span-2">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Locator</dt>
                        <dd class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                          {event.package_locator}
                        </dd>
                      </div>
                    ) : null
                  }

                  {
                    targetHref ? (
                      <div class="grid gap-1 sm:col-span-2">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Inspect</dt>
                        <dd>
                          <a href={targetHref} class="text-sm font-medium text-primary hover:text-foreground">
                            Open package activity
                          </a>
                        </dd>
                      </div>
                    ) : null
                  }
                </dl>

                {
                  facts.length > 0 ? (
                    <div class="grid gap-2">
                      <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Facts</div>
                      <div class="flex flex-wrap gap-2 text-sm text-muted-foreground">
                        {facts.map((fact) => (
                          <span class="rounded-sm border border-border bg-muted px-2 py-0.5">
                            {fact}
                          </span>
                        ))}
                      </div>
                    </div>
                  ) : null
                }

                {
                  payloadJson ? (
                    <div class="grid gap-2">
                      <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Payload</div>
                      <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">{payloadJson}</pre>
                    </div>
                  ) : null
                }
              </div>
            </details>
          );
        })}
      </div>
    </div>
  </section>
</SiteLayout>

<script
  is:inline
  define:vars={{
    registryBaseUrl,
  }}
>
  const feed = document.getElementById("activity-feed");
  const emptyState = document.getElementById("activity-empty");

  const eventLabel = (eventType) => {
    switch (eventType) {
      case "package.submitted":
        return "Submitted";
      case "package.verified":
        return "Verified";
      case "package.published":
        return "Published";
      case "package.searchable":
        return "Searchable";
      case "package.indexed":
        return "Indexed";
      case "package.processing.queued":
        return "Queued";
      case "package.processing.started":
        return "Processing";
      case "package.processing.requeued":
        return "Requeued";
      case "package.processing.blocked":
        return "Blocked";
      case "package.processing.finished":
        return "Processed";
      case "package.docs.staged":
        return "Docs staged";
      case "package.docs.generated":
        return "Docs ready";
      case "package.docs.failed":
        return "Docs failed";
      case "package.build.staged":
        return "Build staged";
      case "package.build.verified":
        return "Build verified";
      case "package.build.failed":
        return "Build failed";
      default:
        return eventType;
    }
  };

  const eventTone = (eventType) => {
    switch (eventType) {
      case "package.submitted":
        return "border-slate-200 bg-slate-50 text-slate-700";
      case "package.verified":
        return "border-sky-200 bg-sky-50 text-sky-700 dark:border-sky-900 dark:bg-sky-950/40 dark:text-sky-300";
      case "package.published":
        return "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-300";
      case "package.searchable":
        return "border-violet-200 bg-violet-50 text-violet-700 dark:border-violet-900 dark:bg-violet-950/40 dark:text-violet-300";
      case "package.indexed":
        return "border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-900 dark:bg-amber-950/40 dark:text-amber-300";
      case "package.processing.queued":
        return "border-slate-200 bg-slate-50 text-slate-700";
      case "package.processing.started":
        return "border-sky-200 bg-sky-50 text-sky-700 dark:border-sky-900 dark:bg-sky-950/40 dark:text-sky-300";
      case "package.processing.requeued":
        return "border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-900 dark:bg-rose-950/40 dark:text-rose-300";
      case "package.processing.blocked":
        return "border-rose-300 bg-rose-100 text-rose-800 dark:border-rose-900 dark:bg-rose-950/60 dark:text-rose-200";
      case "package.processing.finished":
        return "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-300";
      case "package.docs.staged":
        return "border-indigo-200 bg-indigo-50 text-indigo-700 dark:border-indigo-900 dark:bg-indigo-950/40 dark:text-indigo-300";
      case "package.docs.generated":
        return "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-300";
      case "package.docs.failed":
        return "border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-900 dark:bg-rose-950/40 dark:text-rose-300";
      case "package.build.staged":
        return "border-teal-200 bg-teal-50 text-teal-700 dark:border-teal-900 dark:bg-teal-950/40 dark:text-teal-300";
      case "package.build.verified":
        return "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-300";
      case "package.build.failed":
        return "border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-900 dark:bg-rose-950/40 dark:text-rose-300";
      default:
        return "border-slate-200 bg-slate-50 text-slate-700";
    }
  };

  const formatTimestamp = (value, compact = false) => {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return value;
    }

    return new Intl.DateTimeFormat("en", compact ? {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    } : {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    }).format(date);
  };

  const packageLabel = (event) => {
    if (!event.package_name) {
      return "Unknown package";
    }

    return event.package_version
      ? `${event.package_name} ${event.package_version}`
      : event.package_name;
  };

  const packageActivityHref = (event) => {
    if (!event.package_name) {
      return null;
    }

    if (!event.package_version) {
      return `/p/${encodeURIComponent(event.package_name)}`;
    }

    return `/p/${encodeURIComponent(event.package_name)}/${encodeURIComponent(event.package_version)}/activity`;
  };

  const secondaryFacts = (event) => {
    const facts = [];

    if (typeof event.payload?.dependency_count === "number" && Number.isFinite(event.payload.dependency_count)) {
      facts.push(`${event.payload.dependency_count} deps`);
    }

    if (typeof event.payload?.latest === "string" && event.payload.latest.length > 0) {
      facts.push(`latest ${event.payload.latest}`);
    }

    if (typeof event.payload?.run_kind === "string" && event.payload.run_kind.length > 0) {
      facts.push(event.payload.run_kind);
    }

    if (typeof event.payload?.attempt_count === "number" && Number.isFinite(event.payload.attempt_count)) {
      facts.push(`attempt ${event.payload.attempt_count}`);
    }

    if (typeof event.payload?.artifact_sha256 === "string" && event.payload.artifact_sha256.length >= 7) {
      facts.push(`artifact ${event.payload.artifact_sha256.slice(0, 12)}`);
    }

    if (typeof event.package_locator === "string" && event.package_locator.length > 0) {
      facts.push(event.package_locator);
    }

    return facts;
  };

  const escapeHtml = (value) =>
    value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  const renderEvent = (event) => {
    const facts = secondaryFacts(event);
    const href = packageActivityHref(event);
    const factsSummary = facts.length > 0
      ? `<span class="min-w-0 text-sm text-muted-foreground sm:truncate">${escapeHtml(facts.join(" · "))}</span>`
      : "";
    const payloadEntries = Object.entries(event.payload ?? {}).filter(([, value]) => value !== undefined);
    const payloadMarkup = payloadEntries.length > 0
      ? `<div class="grid gap-2"><div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Payload</div><pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">${escapeHtml(JSON.stringify(event.payload, null, 2))}</pre></div>`
      : "";
    const factsMarkup = facts.length > 0
      ? `<div class="grid gap-2"><div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Facts</div><div class="flex flex-wrap gap-2 text-sm text-muted-foreground">${facts.map((fact) => `<span class="rounded-sm border border-border bg-muted px-2 py-0.5">${escapeHtml(fact)}</span>`).join("")}</div></div>`
      : "";
    const packageMarkup = href
      ? `<span class="min-w-0 text-sm font-medium text-foreground md:hidden">${escapeHtml(packageLabel(event))}</span><a href="${escapeHtml(href)}" class="hidden min-w-0 text-sm font-medium text-foreground hover:text-primary md:inline-flex">${escapeHtml(packageLabel(event))}</a>`
      : `<span class="min-w-0 text-sm font-medium text-foreground">${escapeHtml(packageLabel(event))}</span>`;
    const inspectMarkup = href
      ? `<div class="grid gap-1 sm:col-span-2"><dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Inspect</dt><dd><a href="${escapeHtml(href)}" class="text-sm font-medium text-primary hover:text-foreground">Open package activity</a></dd></div>`
      : "";
    const locatorMarkup = typeof event.package_locator === "string" && event.package_locator.length > 0
      ? `<div class="grid gap-1 sm:col-span-2"><dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Locator</dt><dd class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">${escapeHtml(event.package_locator)}</dd></div>`
      : "";
    const packageField = event.package_name
      ? `<div class="grid gap-1"><dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Package</dt><dd class="text-sm text-foreground">${escapeHtml(event.package_name)}</dd></div>`
      : "";
    const versionField = event.package_version
      ? `<div class="grid gap-1"><dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Version</dt><dd class="text-sm text-foreground">${escapeHtml(event.package_version)}</dd></div>`
      : "";

    return `
      <details class="group overflow-hidden rounded-md border border-border bg-card" data-event-id="${escapeHtml(event.event_id)}">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-3 marker:hidden">
          <div class="min-w-0 flex-1">
            <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
              <time class="shrink-0 text-xs text-muted-foreground" datetime="${escapeHtml(event.created_at)}">${escapeHtml(formatTimestamp(event.created_at, true))}</time>
              <span class="inline-flex items-center rounded-sm border px-2 py-0.5 text-[11px] font-medium ${eventTone(event.event_type)}">${escapeHtml(eventLabel(event.event_type))}</span>
              ${packageMarkup}
              ${factsSummary}
            </div>
          </div>
          <span class="shrink-0 text-xs text-muted-foreground group-open:hidden">Details</span>
          <span class="hidden shrink-0 text-xs text-muted-foreground group-open:inline">Hide</span>
        </summary>

        <div class="grid gap-4 border-t border-border px-4 py-3">
          <dl class="grid gap-3 sm:grid-cols-2">
            <div class="grid gap-1">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">When</dt>
              <dd class="text-sm text-foreground">${escapeHtml(formatTimestamp(event.created_at))}</dd>
            </div>
            <div class="grid gap-1">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Event</dt>
              <dd><span class="inline-flex w-fit items-center rounded-sm border px-2 py-0.5 text-xs font-medium ${eventTone(event.event_type)}">${escapeHtml(eventLabel(event.event_type))}</span></dd>
            </div>
            ${packageField}
            ${versionField}
            ${locatorMarkup}
            ${inspectMarkup}
          </dl>
          ${factsMarkup}
          ${payloadMarkup}
        </div>
      </details>
    `;
  };

  const prependEvents = (events) => {
    if (!feed || events.length === 0) {
      return;
    }

    for (const event of events) {
      feed.insertAdjacentHTML("afterbegin", renderEvent(event));
    }

    emptyState?.classList.add("hidden");
  };

  const poll = async () => {
    if (!feed) {
      return;
    }

    const after = feed.dataset.after ?? "";
    const searchParams = new URLSearchParams({
      limit: "100",
    });
    if (after.length > 0) {
      searchParams.set("after", after);
    }
    const response = await fetch(
      `${registryBaseUrl}/v1/events?${searchParams.toString()}`,
      {
        headers: {
          accept: "application/json",
        },
      },
    );

    if (!response.ok) {
      return;
    }

    const payload = await response.json();
    const events = Array.isArray(payload.events) ? payload.events : [];
    if (events.length === 0) {
      return;
    }

    prependEvents(events);
    const last = events[events.length - 1];
    if (last && typeof last.event_id === "string") {
      feed.dataset.after = last.event_id;
    }
  };

  window.setInterval(() => {
    void poll();
  }, 5_000);
</script>
