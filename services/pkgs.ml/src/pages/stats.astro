---
import StatsDashboard from "@/components/StatsDashboard";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchRegistryStatsDashboard } from "@/lib/web-views";
import type { StatsLatestRelease, StatsTopPackage } from "@/lib/types";

const windows = ["all", "year", "30d", "7d"] as const;
const dashboards = Object.fromEntries(
  await Promise.all(
    windows.map(async (window) => [window, await fetchRegistryStatsDashboard(window)]),
  ),
);
const dashboard = dashboards["30d"];
const integer = new Intl.NumberFormat("en-US");
const decimal = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 1,
  minimumFractionDigits: 0,
});
const timestamp = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
});

const summaryCards = [
  ["Package installs", integer.format(dashboard.summary.total_package_downloads)],
  ["Riot installs", integer.format(dashboard.summary.total_riot_downloads)],
  ["OCaml installs", integer.format(dashboard.summary.total_ocaml_downloads)],
  ["Index refreshes", integer.format(dashboard.summary.total_index_reads)],
  ["Packages", integer.format(dashboard.summary.total_packages)],
  ["Versions", integer.format(dashboard.summary.total_versions)],
  ["Users", integer.format(dashboard.summary.total_users)],
  ["Mean installs / package", decimal.format(dashboard.summary.mean_package_downloads_per_package)],
] as const;
---

<SiteLayout
  title="Stats · pkgs.ml"
  description="Anonymous install, release, and index metrics for Riot’s package registry."
>
  <section class="border-b border-border">
    <div class="mx-auto grid w-full max-w-6xl gap-2 px-4 py-8 sm:px-6">
      <h1 class="font-heading text-2xl font-semibold tracking-tight text-foreground">
        Registry stats
      </h1>
      <p class="max-w-3xl text-base leading-7 text-muted-foreground">
        Anonymous download, release, and index activity across pkgs.ml. We count artifacts and index
        reads, not IP addresses.
      </p>
    </div>
  </section>

  <section class="py-6">
    <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 sm:px-6">
      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {
          summaryCards.map(([label, value]) => (
            <div class="rounded-md border border-border bg-card px-4 py-3">
              <div class="text-[11px] font-medium uppercase tracking-wide text-muted-foreground">
                {label}
              </div>
              <div class="mt-1 text-2xl font-semibold tracking-tight text-foreground">{value}</div>
            </div>
          ))
        }
      </div>

      <StatsDashboard client:load initialDashboards={dashboards} />

      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Most installed packages</CardTitle>
            <CardDescription>All-time package artifact downloads recorded by the CDN worker.</CardDescription>
          </CardHeader>
          <CardContent className="px-0">
            {
              dashboard.top_packages.length === 0 ? (
                <p class="px-4 py-4 text-base text-muted-foreground">No package downloads have been recorded yet.</p>
              ) : (
                <>
                  <div class="grid gap-0 md:hidden">
                    {
                      dashboard.top_packages.map((item: StatsTopPackage) => (
                        <article class="grid gap-2 border-b border-border/70 px-4 py-3 last:border-b-0">
                          <div class="flex items-start justify-between gap-3">
                            <div class="grid gap-1">
                              <a href={item.package_path} class="font-medium text-foreground hover:text-primary">
                                {item.package_name}
                              </a>
                              <p class="text-sm text-muted-foreground">
                                {item.description ?? "Published OCaml package"}
                              </p>
                            </div>
                            <span class="shrink-0 text-sm text-muted-foreground">v{item.latest_version}</span>
                          </div>
                          <div class="text-sm text-muted-foreground">
                            {integer.format(item.download_count)} installs
                          </div>
                        </article>
                      ))
                    }
                  </div>

                  <div class="hidden overflow-x-auto md:block">
                    <table class="w-full min-w-[520px] text-left text-sm">
                      <thead class="border-b border-border text-muted-foreground">
                        <tr>
                          <th class="px-4 py-2 font-medium">Package</th>
                          <th class="px-4 py-2 font-medium">Latest</th>
                          <th class="px-4 py-2 font-medium">Installs</th>
                        </tr>
                      </thead>
                      <tbody>
                        {
                          dashboard.top_packages.map((item: StatsTopPackage) => (
                            <tr class="border-b border-border/70 last:border-b-0">
                              <td class="px-4 py-3 align-top">
                                <div class="grid gap-1">
                                  <a href={item.package_path} class="font-medium text-foreground hover:text-primary">
                                    {item.package_name}
                                  </a>
                                  <p class="text-muted-foreground">
                                    {item.description ?? "Published OCaml package"}
                                  </p>
                                </div>
                              </td>
                              <td class="px-4 py-3 align-top text-foreground">v{item.latest_version}</td>
                              <td class="px-4 py-3 align-top text-foreground">
                                {integer.format(item.download_count)}
                              </td>
                            </tr>
                          ))
                        }
                      </tbody>
                    </table>
                  </div>
                </>
              )
            }
          </CardContent>
        </Card>

        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Latest releases</CardTitle>
            <CardDescription>Most recently published package versions in the registry.</CardDescription>
          </CardHeader>
          <CardContent className="grid gap-0 px-0">
            {
              dashboard.latest_releases.length === 0 ? (
                <p class="px-4 py-4 text-base text-muted-foreground">No releases have been published yet.</p>
              ) : (
                dashboard.latest_releases.map((release: StatsLatestRelease) => (
                  <article class="grid gap-1 border-b border-border/70 px-4 py-3 last:border-b-0">
                    <div class="flex items-start justify-between gap-3">
                      <a href={release.package_path} class="font-medium text-foreground hover:text-primary">
                        {release.package_name}
                      </a>
                      <span class="shrink-0 text-muted-foreground">v{release.package_version}</span>
                    </div>
                    <p class="text-sm text-muted-foreground">
                      {timestamp.format(new Date(release.published_at))}
                    </p>
                  </article>
                ))
              )
            }
          </CardContent>
        </Card>
      </div>

      <p class="text-sm text-muted-foreground">
        Stats are collected in aggregate without storing IP addresses. See{" "}
        <a href="/privacy" class="font-medium text-foreground underline decoration-border underline-offset-3 hover:text-primary">
          Privacy
        </a>.
      </p>
    </div>
  </section>
</SiteLayout>
