---
import HomeHero from "../components/HomeHero.astro";
import SearchResults from "../components/SearchResults.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { fetchSearchResults } from "../lib/search.ts";

const query = Astro.url.searchParams.get("q")?.trim() ?? "";
const hasQuery = query.length > 0;
const search = hasQuery ? await fetchSearchResults(query) : null;
const title = hasQuery ? `${query} · pkgs.ml` : "pkgs.ml · OCaml packages";
---

<SiteLayout
  title={title}
  description="Search, explore, and publish OCaml packages."
  showNavSearch={hasQuery}
  searchQuery={query}
>
  {hasQuery && search !== null ? <SearchResults query={query} response={search} /> : <HomeHero />}
</SiteLayout>
