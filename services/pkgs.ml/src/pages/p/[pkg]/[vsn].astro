---
import PackageDocsScaffold from "../../../../src/components/PackageDocsScaffold.astro";
import PackageHero from "../../../../src/components/PackageHero.astro";
import SiteLayout from "../../../../src/layouts/SiteLayout.astro";
import { fetchPackageRelease } from "../../../../src/lib/package-index.ts";

const packageName = Astro.params.pkg ?? "";
const version = Astro.params.vsn ?? "";
const resolved = await fetchPackageRelease(packageName, version);

if (resolved === null) {
  Astro.response.status = 404;
}
---

<SiteLayout
  title={
    resolved
      ? `${resolved.document.name} ${resolved.release.version} · pkgs.ml`
      : "Release not found · pkgs.ml"
  }
  description={resolved?.release.description || "Versioned package details on pkgs.ml"}
  showNavSearch
>
  {
    resolved ? (
      <>
        <PackageHero
          document={resolved.document}
          release={resolved.release}
          selectedVersion={resolved.release.version}
        />
        <PackageDocsScaffold document={resolved.document} release={resolved.release} />
      </>
    ) : (
      <section class="section-block">
        <div class="shell">
          <section class="content-card empty-state">
            <h1>Release not found</h1>
            <p>
              The release <code>{packageName}@{version}</code> could not be found in the package
              index.
            </p>
          </section>
        </div>
      </section>
    )
  }
</SiteLayout>
