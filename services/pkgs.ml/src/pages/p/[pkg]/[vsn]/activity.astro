---
import PackageActivity from "@/components/PackageActivity.astro";
import { Card, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchPackageRelease } from "@/lib/package-index.ts";
import { fetchPackageEvents } from "@/lib/web-views.ts";

const packageName = Astro.params.pkg ?? "";
const version = Astro.params.vsn ?? "";
const resolved = await fetchPackageRelease(packageName, version);
const events =
  resolved === null
    ? { events: [] }
    : await fetchPackageEvents(packageName, { version, limit: 100 });

if (resolved === null) {
  Astro.response.status = 404;
}
---

<SiteLayout
  title={
    resolved
      ? `${resolved.document.name} ${resolved.release.version} activity · pkgs.ml`
      : "Package activity not found · pkgs.ml"
  }
  description={resolved ? `Registry events for ${resolved.document.name} ${resolved.release.version}` : "Package activity on pkgs.ml"}
  navSearchQuery=""
>
  {
    resolved ? (
      <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
        <div class="grid gap-4">
          <div class="grid gap-2 border-b border-border pb-4">
            <div class="flex flex-wrap items-end justify-between gap-3">
              <div class="grid gap-1">
                <div class="text-sm text-muted-foreground">
                  <a href={`/p/${encodeURIComponent(packageName)}/${encodeURIComponent(version)}`} class="hover:text-foreground">
                    {resolved.document.name} v{resolved.release.version}
                  </a>
                </div>
                <h1 class="font-heading text-2xl font-semibold tracking-tight text-foreground">
                  Package activity
                </h1>
                <p class="text-base text-muted-foreground">
                  Publish, indexing, and post-publish processing events for this release.
                </p>
              </div>
            </div>
          </div>

          <PackageActivity
            events={events.events}
            title="Release activity"
            description={`Detailed registry events for ${resolved.document.name} ${resolved.release.version}.`}
            eventLinkMode="package"
            showListDisclosure={false}
            emptyMessage="No registry events have been recorded for this release yet."
          />
        </div>
      </section>
    ) : (
      <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader>
            <CardTitle className="text-sm">Package activity not found</CardTitle>
            <CardDescription>
              The release <code>{packageName}@{version}</code> could not be found in the package
              index.
            </CardDescription>
          </CardHeader>
        </Card>
      </section>
    )
  }
</SiteLayout>
