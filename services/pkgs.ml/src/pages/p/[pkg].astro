---
import PackageDetails from "@/components/PackageDetails.astro";
import PackageHero from "@/components/PackageHero.astro";
import { Card, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchPackageRelease } from "@/lib/package-index.ts";
import { fetchPackageOverview, fetchPackageRelations } from "@/lib/web-views.ts";

const packageName = Astro.params.pkg ?? "";
const resolved = await fetchPackageRelease(packageName);
const [overview, relations] =
  resolved === null
    ? [null, null]
    : await Promise.all([
        fetchPackageOverview(packageName),
        fetchPackageRelations(packageName),
      ]);

if (resolved === null) {
  Astro.response.status = 404;
}
---

<SiteLayout
  title={resolved ? `${resolved.document.name} · pkgs.ml` : "Package not found · pkgs.ml"}
  description={resolved?.release.description || "Package details on pkgs.ml"}
  navSearchQuery=""
>
  {
    resolved ? (
      <>
        <PackageHero
          document={resolved.document}
          release={resolved.release}
          selectedVersion={resolved.release.version}
        />
        <PackageDetails
          document={resolved.document}
          release={resolved.release}
          overview={overview}
          relations={relations}
        />
      </>
    ) : (
      <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader>
            <CardTitle className="text-sm">Package not found</CardTitle>
            <CardDescription>
              The package <code>{packageName}</code> has not been published yet.
            </CardDescription>
          </CardHeader>
        </Card>
      </section>
    )
  }
</SiteLayout>
