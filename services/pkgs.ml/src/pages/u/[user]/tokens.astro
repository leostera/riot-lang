---
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { fetchApiTokens, fetchSession } from "../../../lib/auth";
import { fetchOwnerPackages } from "../../../lib/web-views.ts";

const user = Astro.params.user ?? "user";
const session = await fetchSession(Astro.request);

if (!session.authenticated || !session.user) {
  return Astro.redirect(`/login?return_to=${encodeURIComponent(Astro.url.toString())}`);
}

if (session.user.github_login.toLowerCase() !== user.toLowerCase()) {
  return Astro.redirect(`/u/${session.user.github_login}/tokens`);
}

const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";
const tokenResponse = await fetchApiTokens(Astro.request);
---

<SiteLayout
  title={`${user} tokens · pkgs.ml`}
  description="Publish token management on pkgs.ml"
  navSearchQuery={user}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <a href={`/u/${user}`} class="hover:text-foreground">@{user}</a>
        <span>/</span>
        <span class="text-foreground">tokens</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="lg:self-start">
          <AdminSidebar
            user={user}
            ownerAvatarUrl={ownerView?.owner_github_avatar_url ?? session.user.github_avatar_url}
            packageCount={ownerView?.package_count ?? packages.length}
            latestUpdateLabel={latestUpdate}
            activeSection="tokens"
          />
        </div>

        <div class="grid gap-4">
          <Card className="rounded-md shadow-none">
            <CardHeader className="border-b border-border">
              <CardTitle className="text-base">API Tokens</CardTitle>
              <CardDescription>
                Create and revoke publish credentials used by <code>riot publish</code>.
              </CardDescription>
            </CardHeader>
            <CardContent className="grid gap-3 py-4">
              <form id="create-token-form" class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
                <label class="grid gap-2 text-sm text-muted-foreground">
                  Token name
                  <Input
                    id="create-token-name"
                    name="name"
                    type="text"
                    placeholder="CI publish"
                    className="rounded-md text-base"
                    required
                  />
                </label>
                <Button id="create-token-button" type="submit" className="rounded-md">
                  Create token
                </Button>
              </form>

              <div
                id="token-error"
                class="hidden rounded-md border border-destructive/20 bg-destructive/5 px-3 py-2 text-sm text-destructive"
              />
            </CardContent>
          </Card>

          <Card className="rounded-md shadow-none">
            <CardHeader className="border-b border-border">
              <CardTitle className="text-base">Active tokens</CardTitle>
              <CardDescription>
                Token usage is tracked. Revocation is immediate.
              </CardDescription>
            </CardHeader>
            <CardContent className="grid gap-3 py-4">
              {
                tokenResponse.tokens.length === 0 ? (
                  <div
                    id="empty-token-state"
                    class="rounded-md border border-dashed border-border bg-muted/30 px-4 py-5 text-sm text-muted-foreground"
                  >
                    No active publish tokens yet.
                  </div>
                ) : null
              }

              <div id="token-list" class="grid gap-3">
                {tokenResponse.tokens.map((token) => (
                  <div
                    data-token-row
                    data-token-id={token.token_id}
                    class="grid gap-3 rounded-md border border-border bg-background px-4 py-4 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start"
                  >
                    <div class="grid gap-1">
                      <div class="text-base font-medium text-foreground">{token.name}</div>
                      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
                        <span>Created {new Date(token.created_at).toLocaleDateString("en")}</span>
                        <span>
                          Last used{" "}
                          {token.last_used_at
                            ? new Date(token.last_used_at).toLocaleDateString("en")
                            : "never"}
                        </span>
                        <span>{token.capabilities.join(", ")}</span>
                      </div>
                    </div>

                    <Button
                      type="button"
                      variant="outline"
                      className="rounded-md"
                      data-token-revoke
                      data-token-id={token.token_id}
                    >
                      Revoke
                    </Button>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <dialog
    id="new-token-dialog"
    class="fixed inset-0 m-auto w-full max-w-xl rounded-md border border-border bg-background p-0 text-foreground shadow-lg backdrop:bg-black/50"
  >
    <div class="grid gap-4 p-5">
      <div class="grid gap-1">
        <div class="text-base font-semibold text-foreground">New publish token created</div>
        <p class="text-base text-muted-foreground">
          Save this token now. It will not be shown again after you close this dialog.
        </p>
      </div>

      <div class="grid gap-2">
        <div class="text-sm text-muted-foreground">
          Token name: <span id="dialog-token-name" class="font-medium text-foreground"></span>
        </div>
        <code
          id="dialog-token-value"
          class="overflow-x-auto rounded-md border border-emerald-700/20 bg-emerald-50 px-3 py-2 text-sm text-emerald-950"
        />
      </div>

      <div class="flex items-center justify-end gap-2">
        <Button id="copy-token-button" type="button" variant="outline" className="rounded-md">
          Copy
        </Button>
        <Button id="close-token-dialog" type="button" className="rounded-md">
          Close
        </Button>
      </div>
    </div>
  </dialog>
</SiteLayout>

<script is:inline define:vars={{ currentUrl: Astro.url.toString() }}>
  const createForm = document.getElementById("create-token-form");
  const createButton = document.getElementById("create-token-button");
  const errorBox = document.getElementById("token-error");
  const dialog = document.getElementById("new-token-dialog");
  const dialogTokenName = document.getElementById("dialog-token-name");
  const dialogTokenValue = document.getElementById("dialog-token-value");
  const copyButton = document.getElementById("copy-token-button");
  const closeButton = document.getElementById("close-token-dialog");
  const emptyState = document.getElementById("empty-token-state");
  const tokenList = document.getElementById("token-list");

  const showError = (message) => {
    if (!(errorBox instanceof HTMLElement)) {
      return;
    }

    errorBox.textContent = message;
    errorBox.classList.remove("hidden");
  };

  const clearError = () => {
    if (!(errorBox instanceof HTMLElement)) {
      return;
    }

    errorBox.textContent = "";
    errorBox.classList.add("hidden");
  };

  const setBusy = (busy) => {
    if (createButton instanceof HTMLButtonElement) {
      createButton.disabled = busy;
    }
  };

  const reloadAfterDialog = () => {
    window.location.reload();
  };

  createForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearError();

    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    const formData = new FormData(form);
    const name = String(formData.get("name") ?? "").trim();
    if (name.length === 0) {
      showError("Token name must be a non-empty string.");
      return;
    }

    setBusy(true);

    try {
      const response = await fetch("/api/me/tokens", {
        method: "POST",
        headers: {
          accept: "application/json",
          "content-type": "application/json",
        },
        body: JSON.stringify({ name }),
      });

      if (response.status === 401) {
        window.location.href = `/login?return_to=${encodeURIComponent(currentUrl)}`;
        return;
      }

      const payload = await response.json();
      if (!response.ok) {
        showError(payload?.message ?? `Token creation failed: ${response.status}`);
        return;
      }

      if (dialogTokenName instanceof HTMLElement) {
        dialogTokenName.textContent = payload.token.name;
      }

      if (dialogTokenValue instanceof HTMLElement) {
        dialogTokenValue.textContent = payload.plaintext_token;
      }

      form.reset();

      if (emptyState instanceof HTMLElement && tokenList instanceof HTMLElement) {
        emptyState.classList.add("hidden");
      }

      if (dialog instanceof HTMLDialogElement) {
        dialog.dataset.reloadOnClose = "true";
        dialog.showModal();
      } else if (dialog instanceof HTMLElement) {
        dialog.setAttribute("open", "");
      }
    } catch (error) {
      showError(error instanceof Error ? error.message : "Token creation failed.");
    } finally {
      setBusy(false);
    }
  });

  tokenList?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }

    const button = target.closest("[data-token-revoke]");
    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const tokenId = button.dataset.tokenId;
    if (!tokenId) {
      return;
    }

    clearError();
    button.disabled = true;

    try {
      const response = await fetch(`/api/me/tokens/${encodeURIComponent(tokenId)}`, {
        method: "DELETE",
        headers: {
          accept: "application/json",
        },
      });

      if (response.status === 401) {
        window.location.href = `/login?return_to=${encodeURIComponent(currentUrl)}`;
        return;
      }

      const payload = await response.json();
      if (!response.ok) {
        showError(payload?.message ?? `Token revocation failed: ${response.status}`);
        button.disabled = false;
        return;
      }

      window.location.reload();
    } catch (error) {
      showError(error instanceof Error ? error.message : "Token revocation failed.");
      button.disabled = false;
    }
  });

  copyButton?.addEventListener("click", async () => {
    if (!(dialogTokenValue instanceof HTMLElement)) {
      return;
    }

    const token = dialogTokenValue.textContent ?? "";
    if (token.length === 0) {
      return;
    }

    try {
      await navigator.clipboard.writeText(token);
      if (copyButton instanceof HTMLButtonElement) {
        const original = copyButton.textContent;
        copyButton.textContent = "Copied";
        window.setTimeout(() => {
          copyButton.textContent = original ?? "Copy";
        }, 1500);
      }
    } catch {
      showError("Copy failed. Select the token manually and copy it.");
    }
  });

  closeButton?.addEventListener("click", () => {
    if (dialog instanceof HTMLDialogElement) {
      dialog.close();
    } else if (dialog instanceof HTMLElement) {
      dialog.removeAttribute("open");
      reloadAfterDialog();
    }
  });

  dialog?.addEventListener("close", () => {
    if (dialog instanceof HTMLDialogElement && dialog.dataset.reloadOnClose === "true") {
      reloadAfterDialog();
    }
  });
</script>
