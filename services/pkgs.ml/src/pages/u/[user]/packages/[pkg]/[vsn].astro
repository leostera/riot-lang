---
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import PackageActivity from "@/components/PackageActivity.astro";
import YankReleaseButton from "@/components/admin/YankReleaseButton.astro";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchSession } from "@/lib/auth";
import { fetchPackageRelease } from "@/lib/package-index.ts";
import {
  fetchOwnerPackages,
  fetchPackageEvents,
  fetchPackageExamples,
  fetchPackageReadme,
} from "@/lib/web-views.ts";

const user = Astro.params.user ?? "user";
const packageName = Astro.params.pkg ?? "";
const version = Astro.params.vsn ?? "";
const session = await fetchSession(Astro.request);

if (!session.authenticated || !session.user) {
  return Astro.redirect(`/login?return_to=${encodeURIComponent(Astro.url.toString())}`);
}

if (session.user.github_login.toLowerCase() !== user.toLowerCase()) {
  return Astro.redirect(`/u/${session.user.github_login}/packages`);
}

const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const pkg = packages.find((candidate) => candidate.package_name === packageName);
const releaseSummary = pkg?.releases.find((candidate) => candidate.version === version);
const [resolved, readme, examples, events] = await Promise.all([
  pkg ? fetchPackageRelease(packageName, version) : Promise.resolve(null),
  pkg ? fetchPackageReadme(packageName, { version }) : Promise.resolve(null),
  pkg ? fetchPackageExamples(packageName, { version }) : Promise.resolve(null),
  pkg ? fetchPackageEvents(packageName, { version, limit: 25 }) : Promise.resolve({ events: [] }),
]);

if (pkg === undefined || releaseSummary === undefined) {
  Astro.response.status = 404;
}

const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";

const release = resolved?.release;
const dependencyCount = release?.dependencies.length ?? 0;
---

<SiteLayout
  title={pkg ? `${pkg.package_name} ${version} admin · pkgs.ml` : "Release not found · pkgs.ml"}
  description="Release administration on pkgs.ml"
  navSearchQuery={packageName}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <a href={`/u/${user}`} class="hover:text-foreground">@{user}</a>
        <span>/</span>
        <a href={`/u/${user}/packages`} class="hover:text-foreground">packages</a>
        <span>/</span>
        <a href={`/u/${user}/packages/${packageName}`} class="hover:text-foreground">{packageName}</a>
        <span>/</span>
        <span class="text-foreground">{version}</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="lg:self-start">
          <AdminSidebar
            user={user}
            ownerAvatarUrl={ownerView?.owner_github_avatar_url ?? session.user.github_avatar_url}
            packageCount={ownerView?.package_count ?? packages.length}
            latestUpdateLabel={latestUpdate}
            activeSection="packages"
          />
        </div>

        {
          pkg && releaseSummary ? (
            <div class="grid gap-4">
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <div class="grid gap-2">
                      <div class="flex flex-wrap items-center gap-2">
                        <CardTitle className="text-base">{pkg.package_name}</CardTitle>
                        <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                          v{version}
                        </span>
                        {
                          releaseSummary.yanked ? (
                            <span class="rounded-full border border-amber-700/20 bg-amber-50 px-2 py-0.5 text-[11px] font-medium text-amber-900">
                              Yanked
                            </span>
                          ) : (
                            <span class="rounded-full border border-emerald-700/20 bg-emerald-50 px-2 py-0.5 text-[11px] font-medium text-emerald-900">
                              Active
                            </span>
                          )
                        }
                        {
                          pkg.latest_version === version && !releaseSummary.yanked ? (
                            <span class="rounded-full border border-sky-700/20 bg-sky-50 px-2 py-0.5 text-[11px] font-medium text-sky-900">
                              Latest
                            </span>
                          ) : null
                        }
                      </div>
                      <CardDescription>
                        {pkg.description || "No package description has been published yet."}
                      </CardDescription>
                    </div>

                    <div class="flex flex-wrap gap-2">
                      <a href={`/p/${pkg.package_name}/${version}`} class="inline-flex">
                        <Button variant="outline" size="sm" className="rounded-md">
                          Public release page
                        </Button>
                      </a>
                      <a
                        href={pkg.repository ?? pkg.repo_url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex"
                      >
                        <Button variant="outline" size="sm" className="rounded-md">
                          Repository
                        </Button>
                      </a>
                      {releaseSummary.yanked ? null : (
                        <YankReleaseButton packageName={pkg.package_name} version={version} compact={true} />
                      )}
                    </div>
                  </div>
                </CardHeader>
                <CardContent className="grid gap-3 py-4 sm:grid-cols-2 xl:grid-cols-4">
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Published</div>
                    <div class="text-base font-medium text-foreground">
                      {new Date(releaseSummary.published_at).toLocaleDateString("en")}
                    </div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Dependencies</div>
                    <div class="text-base font-medium text-foreground">{dependencyCount}</div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Examples</div>
                    <div class="text-base font-medium text-foreground">{examples?.examples.length ?? 0}</div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">README</div>
                    <div class="text-base font-medium text-foreground">
                      {readme ? readme.readme_path : "Missing"}
                    </div>
                  </div>
                </CardContent>
              </Card>

              <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(280px,340px)]">
                <Card className="rounded-md shadow-none">
                  <CardHeader className="border-b border-border">
                    <CardTitle className="text-base">Release metadata</CardTitle>
                    <CardDescription>
                      Inspect the stored install artifact and the release’s current status.
                    </CardDescription>
                  </CardHeader>
                  <CardContent className="grid gap-3 py-4">
                    <div class="grid gap-3 text-sm">
                      <div class="grid gap-1 rounded-md border border-border px-4 py-3">
                        <div class="text-muted-foreground">Package</div>
                        <div class="font-medium text-foreground">{pkg.package_name}</div>
                      </div>
                      <div class="grid gap-1 rounded-md border border-border px-4 py-3">
                        <div class="text-muted-foreground">Version</div>
                        <div class="font-medium text-foreground">v{version}</div>
                      </div>
                      <div class="grid gap-1 rounded-md border border-border px-4 py-3">
                        <div class="text-muted-foreground">Artifact SHA-256</div>
                        <code class="overflow-x-auto text-xs text-foreground">
                          {release?.artifact_sha256 ?? "Unavailable"}
                        </code>
                      </div>
                      <div class="grid gap-1 rounded-md border border-border px-4 py-3">
                        <div class="text-muted-foreground">Manifest key</div>
                        <code class="overflow-x-auto text-xs text-foreground">
                          {release?.manifest_key ?? "Unavailable"}
                        </code>
                      </div>
                      <div class="grid gap-1 rounded-md border border-border px-4 py-3">
                        <div class="text-muted-foreground">Source archive key</div>
                        <code class="overflow-x-auto text-xs text-foreground">
                          {release?.source_key ?? "Unavailable"}
                        </code>
                      </div>
                      {
                        releaseSummary.yanked ? (
                          <div class="grid gap-1 rounded-md border border-amber-700/20 bg-amber-50 px-4 py-3 text-amber-950">
                            <div class="font-medium">This version has been yanked.</div>
                            <div class="text-sm">
                              {releaseSummary.yanked_at
                                ? `Yanked ${new Date(releaseSummary.yanked_at).toLocaleString("en")}`
                                : "Yanked at an unknown time"}
                              {releaseSummary.yanked_by_github_login
                                ? ` by @${releaseSummary.yanked_by_github_login}`
                                : ""}
                              .
                            </div>
                          </div>
                        ) : null
                      }
                    </div>
                  </CardContent>
                </Card>

                <Card className="rounded-md shadow-none">
                  <CardHeader className="border-b border-border">
                    <CardTitle className="text-base">Quick links</CardTitle>
                    <CardDescription>
                      Jump between the public page, admin package view, and version activity.
                    </CardDescription>
                  </CardHeader>
                  <CardContent className="grid gap-2 py-4 text-sm">
                    <a
                      href={`/u/${user}/packages/${pkg.package_name}`}
                      class="rounded-md px-3 py-2 text-foreground hover:bg-muted"
                    >
                      Package admin view
                    </a>
                    <a
                      href={`/p/${pkg.package_name}/${version}`}
                      class="rounded-md px-3 py-2 text-foreground hover:bg-muted"
                    >
                      Public release page
                    </a>
                    <a
                      href={`/p/${pkg.package_name}/${version}/activity`}
                      class="rounded-md px-3 py-2 text-foreground hover:bg-muted"
                    >
                      Public activity page
                    </a>
                    {
                      examples && examples.examples.length > 0 ? (
                        <a
                          href={`https://play.riot.ml/p/${encodeURIComponent(pkg.package_name)}/${encodeURIComponent(version)}/examples/${encodeURIComponent(examples.examples[0]?.name ?? "")}`}
                          class="rounded-md px-3 py-2 text-foreground hover:bg-muted"
                        >
                          Open first example in playground
                        </a>
                      ) : null
                    }
                  </CardContent>
                </Card>
              </div>

              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">Release activity</CardTitle>
                  <CardDescription>
                    Registry events for this specific package version.
                  </CardDescription>
                </CardHeader>
                <CardContent className="py-4">
                  <PackageActivity
                    events={events.events}
                    title="Release activity"
                    description="Registry events recorded for this specific package version."
                    showListDisclosure={false}
                  />
                </CardContent>
              </Card>
            </div>
          ) : (
            <Card className="rounded-md shadow-none">
              <CardHeader>
                <CardTitle className="text-sm">Release not found</CardTitle>
                <CardDescription>
                  <code>{packageName}@{version}</code> is not published under <code>{user}</code>.
                </CardDescription>
              </CardHeader>
            </Card>
          )
        }
      </div>
    </div>
  </section>
</SiteLayout>
