---
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchSession } from "@/lib/auth";
import { fetchOwnerPackages } from "@/lib/web-views.ts";

const user = Astro.params.user ?? "user";
const session = await fetchSession(Astro.request);

if (!session.authenticated || !session.user) {
  return Astro.redirect(`/login?return_to=${encodeURIComponent(Astro.url.toString())}`);
}

if (session.user.github_login.toLowerCase() !== user.toLowerCase()) {
  return Astro.redirect(`/u/${session.user.github_login}/packages`);
}

const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";
---

<SiteLayout
  title={`${user} packages · pkgs.ml`}
  description="Package administration on pkgs.ml"
  navSearchQuery={user}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <a href={`/u/${user}`} class="hover:text-foreground">@{user}</a>
        <span>/</span>
        <span class="text-foreground">packages</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="lg:self-start">
          <AdminSidebar
            user={user}
            ownerAvatarUrl={ownerView?.owner_github_avatar_url ?? session.user.github_avatar_url}
            packageCount={ownerView?.package_count ?? packages.length}
            latestUpdateLabel={latestUpdate}
            activeSection="packages"
          />
        </div>

        <Card className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Packages</CardTitle>
            <CardDescription>
              Manage published packages, inspect versions, and open per-release controls.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-4 py-4">
            {
              packages.length === 0 ? (
                <div class="grid gap-2 rounded-md border border-dashed border-border bg-muted/30 p-4">
                  <h3 class="text-base font-semibold tracking-tight text-foreground">
                    No packages published yet
                  </h3>
                  <p class="text-sm leading-6 text-muted-foreground">
                    Publish a package with <code>riot publish</code> and it will show up here.
                  </p>
                </div>
              ) : (
                <div class="overflow-x-auto">
                  <table class="w-full min-w-[760px] text-left text-sm">
                    <thead class="text-muted-foreground">
                      <tr class="border-b border-border">
                        <th class="px-3 py-3 font-medium">Package</th>
                        <th class="px-3 py-3 font-medium">Latest</th>
                        <th class="px-3 py-3 font-medium">Versions</th>
                        <th class="px-3 py-3 font-medium">Yanked</th>
                        <th class="px-3 py-3 font-medium">Updated</th>
                        <th class="px-3 py-3 font-medium text-right">Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {packages.map((pkg) => (
                        <tr class="border-b border-border align-top last:border-b-0">
                          <td class="px-3 py-4">
                            <div class="grid gap-1">
                              <a
                                href={`/u/${user}/packages/${pkg.package_name}`}
                                class="font-medium text-foreground hover:text-primary"
                              >
                                {pkg.package_name}
                              </a>
                              <p class="max-w-xl text-sm leading-6 text-muted-foreground">
                                {pkg.description || "No package description has been published yet."}
                              </p>
                            </div>
                          </td>
                          <td class="px-3 py-4 text-foreground">v{pkg.latest_version}</td>
                          <td class="px-3 py-4 text-muted-foreground">{pkg.release_count}</td>
                          <td class="px-3 py-4 text-muted-foreground">{pkg.yanked_release_count}</td>
                          <td class="px-3 py-4 text-muted-foreground">
                            {new Date(pkg.updated_at).toLocaleDateString("en")}
                          </td>
                          <td class="px-3 py-4">
                            <div class="flex justify-end gap-2">
                              <a
                                href={`/u/${user}/packages/${pkg.package_name}`}
                                class="inline-flex"
                              >
                                <Button size="sm" className="rounded-md">Manage</Button>
                              </a>
                              <a
                                href={`/p/${pkg.package_name}`}
                                class="inline-flex"
                              >
                                <Button size="sm" variant="outline" className="rounded-md">
                                  Public page
                                </Button>
                              </a>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )
            }
          </CardContent>
        </Card>
      </div>
    </div>
  </section>
</SiteLayout>
