---
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import YankReleaseButton from "@/components/admin/YankReleaseButton.astro";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { fetchSession } from "@/lib/auth";
import { fetchOwnerPackages } from "@/lib/web-views.ts";

const user = Astro.params.user ?? "user";
const packageName = Astro.params.pkg ?? "";
const session = await fetchSession(Astro.request);

if (!session.authenticated || !session.user) {
  return Astro.redirect(`/login?return_to=${encodeURIComponent(Astro.url.toString())}`);
}

if (session.user.github_login.toLowerCase() !== user.toLowerCase()) {
  return Astro.redirect(`/u/${session.user.github_login}/packages`);
}

const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const pkg = packages.find((candidate) => candidate.package_name === packageName);

if (pkg === undefined) {
  Astro.response.status = 404;
}

const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";
---

<SiteLayout
  title={pkg ? `${pkg.package_name} admin · pkgs.ml` : "Package not found · pkgs.ml"}
  description="Package administration on pkgs.ml"
  navSearchQuery={packageName}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <a href={`/u/${user}`} class="hover:text-foreground">@{user}</a>
        <span>/</span>
        <a href={`/u/${user}/packages`} class="hover:text-foreground">packages</a>
        <span>/</span>
        <span class="text-foreground">{packageName}</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="lg:self-start">
          <AdminSidebar
            user={user}
            ownerAvatarUrl={ownerView?.owner_github_avatar_url ?? session.user.github_avatar_url}
            packageCount={ownerView?.package_count ?? packages.length}
            latestUpdateLabel={latestUpdate}
            activeSection="packages"
          />
        </div>

        {
          pkg ? (
            <div class="grid gap-4">
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <div class="grid gap-2">
                      <CardTitle className="text-base">{pkg.package_name}</CardTitle>
                      <CardDescription>
                        {pkg.description || "No package description has been published yet."}
                      </CardDescription>
                    </div>

                    <div class="flex flex-wrap gap-2">
                      <a href={`/p/${pkg.package_name}`} class="inline-flex">
                        <Button variant="outline" size="sm" className="rounded-md">
                          Public page
                        </Button>
                      </a>
                      <a
                        href={pkg.repository ?? pkg.repo_url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex"
                      >
                        <Button variant="outline" size="sm" className="rounded-md">
                          Repository
                        </Button>
                      </a>
                    </div>
                  </div>
                </CardHeader>
                <CardContent className="grid gap-3 py-4 sm:grid-cols-2 xl:grid-cols-4">
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Latest installable</div>
                    <div class="text-base font-medium text-foreground">v{pkg.latest_version}</div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Published versions</div>
                    <div class="text-base font-medium text-foreground">{pkg.release_count}</div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Yanked versions</div>
                    <div class="text-base font-medium text-foreground">{pkg.yanked_release_count}</div>
                  </div>
                  <div class="grid gap-1 rounded-md border border-border bg-muted/20 px-4 py-3">
                    <div class="text-sm text-muted-foreground">Updated</div>
                    <div class="text-base font-medium text-foreground">
                      {new Date(pkg.updated_at).toLocaleDateString("en")}
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">Versions</CardTitle>
                  <CardDescription>
                    Open a release to inspect metadata and yank it if needed.
                  </CardDescription>
                </CardHeader>
                <CardContent className="grid gap-4 py-4">
                  <div class="overflow-x-auto">
                    <table class="w-full min-w-[760px] text-left text-sm">
                      <thead class="text-muted-foreground">
                        <tr class="border-b border-border">
                          <th class="px-3 py-3 font-medium">Version</th>
                          <th class="px-3 py-3 font-medium">Status</th>
                          <th class="px-3 py-3 font-medium">Published</th>
                          <th class="px-3 py-3 font-medium">Yanked</th>
                          <th class="px-3 py-3 font-medium text-right">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {pkg.releases.map((release) => (
                          <tr class="border-b border-border align-top last:border-b-0">
                            <td class="px-3 py-4">
                              <a
                                href={`/u/${user}/packages/${pkg.package_name}/${release.version}`}
                                class="font-medium text-foreground hover:text-primary"
                              >
                                v{release.version}
                              </a>
                            </td>
                            <td class="px-3 py-4">
                              <div class="flex flex-wrap gap-2">
                                {
                                  release.yanked ? (
                                    <span class="rounded-full border border-amber-700/20 bg-amber-50 px-2 py-0.5 text-[11px] font-medium text-amber-900">
                                      Yanked
                                    </span>
                                  ) : (
                                    <span class="rounded-full border border-emerald-700/20 bg-emerald-50 px-2 py-0.5 text-[11px] font-medium text-emerald-900">
                                      Active
                                    </span>
                                  )
                                }
                                {
                                  pkg.latest_version === release.version && !release.yanked ? (
                                    <span class="rounded-full border border-sky-700/20 bg-sky-50 px-2 py-0.5 text-[11px] font-medium text-sky-900">
                                      Latest
                                    </span>
                                  ) : null
                                }
                              </div>
                            </td>
                            <td class="px-3 py-4 text-muted-foreground">
                              {new Date(release.published_at).toLocaleDateString("en")}
                            </td>
                            <td class="px-3 py-4 text-muted-foreground">
                              {release.yanked_at
                                ? new Date(release.yanked_at).toLocaleDateString("en")
                                : "—"}
                            </td>
                            <td class="px-3 py-4">
                              <div class="flex justify-end gap-2">
                                <a
                                  href={`/u/${user}/packages/${pkg.package_name}/${release.version}`}
                                  class="inline-flex"
                                >
                                  <Button size="sm" className="rounded-md">Inspect</Button>
                                </a>
                                {release.yanked ? null : (
                                  <YankReleaseButton
                                    packageName={pkg.package_name}
                                    version={release.version}
                                    compact={true}
                                  />
                                )}
                              </div>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </CardContent>
              </Card>
            </div>
          ) : (
            <Card className="rounded-md shadow-none">
              <CardHeader>
                <CardTitle className="text-sm">Package not found</CardTitle>
                <CardDescription>
                  <code>{packageName}</code> is not published under <code>{user}</code>.
                </CardDescription>
              </CardHeader>
            </Card>
          )
        }
      </div>
    </div>
  </section>
</SiteLayout>
