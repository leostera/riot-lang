---
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { fetchSession } from "../../lib/auth";
import { fetchOwnerPackages } from "../../lib/web-views.ts";

const user = Astro.params.user ?? "user";
const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const session = await fetchSession(Astro.request);
const isCurrentUser =
  session.authenticated &&
  session.user !== undefined &&
  session.user.github_login.toLowerCase() === user.toLowerCase();
const ownerAvatarUrl =
  ownerView?.owner_github_avatar_url ??
  (isCurrentUser ? session.user?.github_avatar_url : undefined);

const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";
---

<SiteLayout
  title={`@${user} · pkgs.ml`}
  description={`Published OCaml packages for @${user}.`}
  navSearchQuery={user}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <span class="text-foreground">@{user}</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="grid gap-4 lg:self-start">
          {
            isCurrentUser ? (
              <AdminSidebar
                user={user}
                ownerAvatarUrl={ownerAvatarUrl}
                packageCount={ownerView?.package_count ?? packages.length}
                latestUpdateLabel={latestUpdate}
                activeSection="overview"
              />
            ) : (
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">
                    <a href={`/u/${user}`} class="text-foreground hover:text-primary">
                      @{user}
                    </a>
                  </CardTitle>
                </CardHeader>
                <CardContent className="grid gap-4 py-4">
                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">Published packages</div>
                    <div class="text-base font-medium text-foreground">
                      {ownerView?.package_count ?? packages.length} package{(ownerView?.package_count ?? packages.length) === 1 ? "" : "s"}
                    </div>
                  </div>

                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">Latest update</div>
                    <div class="text-base text-foreground">{latestUpdate}</div>
                  </div>

                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">Source provider</div>
                    <div class="text-base text-foreground">GitHub</div>
                  </div>

                  <div class="grid gap-2 border-t border-border pt-4 text-sm text-muted-foreground">
                    <a
                      href={`https://github.com/${user}`}
                      target="_blank"
                      rel="noreferrer"
                      class="hover:text-foreground"
                    >
                      GitHub profile
                    </a>
                    <a href={`/?q=${encodeURIComponent(user)}`} class="hover:text-foreground">
                      Search by owner
                    </a>
                  </div>
                </CardContent>
              </Card>
            )
          }

          {
            isCurrentUser ? (
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">Administration</CardTitle>
                  <CardDescription>
                    Manage packages, releases, and publish credentials from a dedicated admin view.
                  </CardDescription>
                </CardHeader>
                <CardContent className="grid gap-3 py-4">
                  <a
                    href={`/u/${user}/packages`}
                    class="rounded-md border border-border bg-muted/20 px-4 py-3 text-sm transition-colors hover:bg-muted"
                  >
                    <div class="font-medium text-foreground">Manage packages</div>
                    <div class="mt-1 text-muted-foreground">
                      Browse package versions, inspect release details, and yank a version.
                    </div>
                  </a>

                  <a
                    href={`/u/${user}/tokens`}
                    class="rounded-md border border-border bg-muted/20 px-4 py-3 text-sm transition-colors hover:bg-muted"
                  >
                    <div class="font-medium text-foreground">Manage API tokens</div>
                    <div class="mt-1 text-muted-foreground">
                      Create and revoke publish credentials for local use and CI.
                    </div>
                  </a>
                </CardContent>
              </Card>
            ) : null
          }

          {
            isCurrentUser ? null : (
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">Packages</CardTitle>
                  <CardDescription>
                    Public package registry activity for <code>@{user}</code>.
                  </CardDescription>
                </CardHeader>
                <CardContent className="grid gap-3 py-4">
                  <p class="text-sm leading-6 text-muted-foreground">
                    Browse published packages and open their public package pages from the list on
                    the right.
                  </p>
                </CardContent>
              </Card>
            )
          }
        </div>

        <Card className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">
              {isCurrentUser ? "Recently updated packages" : "Recently published packages"}
            </CardTitle>
            <CardDescription>
              {isCurrentUser
                ? "Start in the package admin panel for per-release controls, then jump to public package pages when you need them."
                : "Public packages indexed from repositories owned by this user, ordered by latest release."}
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 py-4">
            {
              packages.length === 0 ? (
                <div class="grid gap-2 rounded-md border border-dashed border-border bg-muted/30 p-4">
                  <h3 class="text-base font-semibold tracking-tight text-foreground">
                    No public packages yet
                  </h3>
                  <p class="text-sm leading-6 text-muted-foreground">
                    No indexed packages currently match repositories owned by <code>{user}</code>.
                  </p>
                </div>
              ) : (
                <div class="grid gap-3">
                  {packages.slice(0, isCurrentUser ? 8 : packages.length).map((result) => (
                    <Card size="sm" className="rounded-md shadow-none">
                      <CardContent className="grid gap-3 py-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start">
                        <div class="grid gap-2">
                          <div class="flex flex-wrap items-center gap-2">
                            <a
                              href={`/p/${result.package_name}`}
                              class="text-base font-semibold tracking-tight text-foreground hover:text-primary"
                            >
                              {result.package_name}
                            </a>
                            <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                              v{result.latest_version}
                            </span>
                          </div>

                          <p class="text-sm leading-6 text-muted-foreground">
                            {result.description || "No package description has been published yet."}
                          </p>

                          <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
                            <span>{result.subdir || "repo root"}</span>
                            <span>
                              {result.release_count} version{result.release_count === 1 ? "" : "s"}
                            </span>
                            {
                              result.yanked_release_count > 0 ? (
                                <span>
                                  {result.yanked_release_count} yanked
                                </span>
                              ) : null
                            }
                            <span>{result.license || "License pending"}</span>
                          </div>
                        </div>

                        <div class="flex flex-wrap gap-2 text-sm sm:justify-end">
                          {
                            isCurrentUser ? (
                              <a
                                class="text-muted-foreground hover:text-foreground"
                                href={`/u/${user}/packages/${result.package_name}`}
                              >
                                Manage package
                              </a>
                            ) : null
                          }
                          <a
                            class="text-muted-foreground hover:text-foreground"
                            href={`/p/${result.package_name}`}
                          >
                            Package page
                          </a>
                          <a
                            class="text-muted-foreground hover:text-foreground"
                            href={result.repository ?? result.repo_url}
                            target="_blank"
                            rel="noreferrer"
                          >
                            Repository
                          </a>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              )
            }

            {
              isCurrentUser && packages.length > 8 ? (
                <a
                  href={`/u/${user}/packages`}
                  class="text-sm font-medium text-foreground hover:text-primary"
                >
                  View all packages
                </a>
              ) : null
            }
          </CardContent>
        </Card>
      </div>
    </div>
  </section>
</SiteLayout>
