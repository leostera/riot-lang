---
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import GitHubAvatar from "@/components/GitHubAvatar.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { fetchSession } from "../../lib/auth";
import { fetchOwnerPackages } from "../../lib/web-views.ts";

const user = Astro.params.user ?? "user";
const ownerView = await fetchOwnerPackages(user);
const packages = ownerView?.packages ?? [];
const session = await fetchSession(Astro.request);
const isCurrentUser =
  session.authenticated &&
  session.user !== undefined &&
  session.user.github_login.toLowerCase() === user.toLowerCase();
const ownerAvatarUrl =
  ownerView?.owner_github_avatar_url ??
  (isCurrentUser ? session.user?.github_avatar_url : undefined);

const latestUpdate = ownerView?.latest_update_at
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(ownerView.latest_update_at))
  : "No packages yet";
---

<SiteLayout
  title={`@${user} · pkgs.ml`}
  description={`Published OCaml packages for @${user}.`}
  navSearchQuery={user}
>
  <section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
    <div class="grid gap-4">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">All packages</a>
        <span>/</span>
        <span class="text-foreground">@{user}</span>
      </nav>

      <div class="grid gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
        <div class="grid gap-4 lg:self-start">
          <Card className="rounded-md shadow-none">
            <CardHeader className="border-b border-border">
              <CardTitle className="text-base">
                <GitHubAvatar login={user} avatarUrl={ownerAvatarUrl} href={`/u/${user}`} />
              </CardTitle>
            </CardHeader>
            <CardContent className="grid gap-4 py-4">
              <div class="grid gap-1">
                <div class="text-sm text-muted-foreground">Published packages</div>
                <div class="text-base font-medium text-foreground">
                  {ownerView?.package_count ?? packages.length} package{(ownerView?.package_count ?? packages.length) === 1 ? "" : "s"}
                </div>
              </div>

              <div class="grid gap-1">
                <div class="text-sm text-muted-foreground">Latest update</div>
                <div class="text-base text-foreground">{latestUpdate}</div>
              </div>

              <div class="grid gap-1">
                <div class="text-sm text-muted-foreground">Source provider</div>
                <div class="text-base text-foreground">GitHub</div>
              </div>

              <div class="grid gap-2 border-t border-border pt-4 text-sm text-muted-foreground">
                <a
                  href={`https://github.com/${user}`}
                  target="_blank"
                  rel="noreferrer"
                  class="hover:text-foreground"
                >
                  GitHub profile
                </a>
                <a href={`/?q=${encodeURIComponent(user)}`} class="hover:text-foreground">
                  Search by owner
                </a>
              </div>
            </CardContent>
          </Card>

          {
            isCurrentUser ? (
              <Card className="rounded-md shadow-none">
                <CardHeader className="border-b border-border">
                  <CardTitle className="text-base">API Tokens</CardTitle>
                  <CardDescription>
                    Manage publish credentials for <code>riot publish</code>.
                  </CardDescription>
                </CardHeader>
                <CardContent className="grid gap-3 py-4">
                  <p class="text-sm leading-6 text-muted-foreground">
                    Create and revoke publish tokens for local development, CI, and release
                    automation.
                  </p>

                  <a
                    href={`/u/${user}/tokens`}
                    class="text-sm font-medium text-foreground hover:text-primary"
                  >
                    Manage API tokens
                  </a>
                </CardContent>
              </Card>
            ) : null
          }
        </div>

        <Card className="rounded-md shadow-none">
          <CardHeader className="border-b border-border">
            <CardTitle className="text-base">Recently published packages</CardTitle>
            <CardDescription>
              Public packages indexed from repositories owned by this user, ordered by latest
              release.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 py-4">
            {
              packages.length === 0 ? (
                <div class="grid gap-2 rounded-md border border-dashed border-border bg-muted/30 p-4">
                  <h3 class="text-base font-semibold tracking-tight text-foreground">
                    No public packages yet
                  </h3>
                  <p class="text-sm leading-6 text-muted-foreground">
                    No indexed packages currently match repositories owned by <code>{user}</code>.
                  </p>
                </div>
              ) : (
                <div class="grid gap-3">
                  {packages.map((result) => (
                    <Card size="sm" className="rounded-md shadow-none">
                      <CardContent className="grid gap-3 py-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start">
                        <div class="grid gap-2">
                          <div class="flex flex-wrap items-center gap-2">
                            <a
                              href={`/p/${result.package_name}`}
                              class="text-base font-semibold tracking-tight text-foreground hover:text-primary"
                            >
                              {result.package_name}
                            </a>
                            <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                              v{result.latest_version}
                            </span>
                          </div>

                          <p class="text-sm leading-6 text-muted-foreground">
                            {result.description || "No package description has been published yet."}
                          </p>

                          <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
                            <span>{result.subdir || "repo root"}</span>
                            <span>
                              {result.release_count} version{result.release_count === 1 ? "" : "s"}
                            </span>
                            {
                              result.yanked_release_count > 0 ? (
                                <span>
                                  {result.yanked_release_count} yanked
                                </span>
                              ) : null
                            }
                            <span>{result.license || "License pending"}</span>
                          </div>

                          {
                            isCurrentUser && result.releases.length > 0 ? (
                              <div class="grid gap-2 rounded-md border border-border bg-muted/20 p-3">
                                <div class="text-sm font-medium text-foreground">Release management</div>
                                <div class="grid gap-2">
                                  {result.releases.map((release) => (
                                    <div class="grid gap-2 rounded-md border border-border bg-background px-3 py-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
                                      <div class="grid gap-1">
                                        <div class="flex flex-wrap items-center gap-2">
                                          <a
                                            href={release.package_path}
                                            class="text-sm font-medium text-foreground hover:text-primary"
                                          >
                                            v{release.version}
                                          </a>
                                          {
                                            release.yanked ? (
                                              <span class="rounded-full border border-amber-700/20 bg-amber-50 px-2 py-0.5 text-[11px] font-medium text-amber-900">
                                                Yanked
                                              </span>
                                            ) : null
                                          }
                                          {
                                            result.latest_version === release.version && !release.yanked ? (
                                              <span class="rounded-full border border-emerald-700/20 bg-emerald-50 px-2 py-0.5 text-[11px] font-medium text-emerald-900">
                                                Latest
                                              </span>
                                            ) : null
                                          }
                                        </div>
                                        <div class="text-xs text-muted-foreground">
                                          Published {new Date(release.published_at).toLocaleDateString("en")}
                                          {release.yanked_at
                                            ? ` · yanked ${new Date(release.yanked_at).toLocaleDateString("en")}`
                                            : ""}
                                        </div>
                                      </div>

                                      {
                                        release.yanked ? null : (
                                          <form
                                            data-yank-form
                                            data-package-name={result.package_name}
                                            data-package-version={release.version}
                                            class="sm:justify-self-end"
                                          >
                                            <Button
                                              type="submit"
                                              variant="outline"
                                              size="sm"
                                              className="rounded-md border-destructive/20 text-destructive hover:bg-destructive/10 hover:text-destructive"
                                            >
                                              Yank
                                            </Button>
                                          </form>
                                        )
                                      }
                                    </div>
                                  ))}
                                </div>
                              </div>
                            ) : null
                          }
                        </div>

                        <div class="flex flex-wrap gap-2 text-sm sm:justify-end">
                          <a
                            class="text-muted-foreground hover:text-foreground"
                            href={`/p/${result.package_name}`}
                          >
                            Package page
                          </a>
                          <a
                            class="text-muted-foreground hover:text-foreground"
                            href={result.repository ?? result.repo_url}
                            target="_blank"
                            rel="noreferrer"
                          >
                            Repository
                          </a>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              )
            }
          </CardContent>
        </Card>
      </div>
    </div>
  </section>
</SiteLayout>

{
  isCurrentUser ? (
    <script is:inline define:vars={{ currentUrl: Astro.url.toString() }}>
      const yankForms = Array.from(document.querySelectorAll("[data-yank-form]"));

      for (const form of yankForms) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          const currentForm = event.currentTarget;
          if (!(currentForm instanceof HTMLFormElement)) {
            return;
          }

          const packageName = currentForm.dataset.packageName ?? "";
          const version = currentForm.dataset.packageVersion ?? "";
          if (packageName.length === 0 || version.length === 0) {
            return;
          }

          const confirmed = window.confirm(`Yank ${packageName}@${version}?`);
          if (!confirmed) {
            return;
          }

          const submitButton = currentForm.querySelector("button");
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = true;
          }

          try {
            const response = await fetch(
              `/api/me/packages/${encodeURIComponent(packageName)}/versions/${encodeURIComponent(version)}/yank`,
              {
                method: "POST",
                headers: {
                  accept: "application/json",
                },
              },
            );

            if (response.status === 401) {
              window.location.href = `/login?return_to=${encodeURIComponent(currentUrl)}`;
              return;
            }

            const payload = await response.json();
            if (!response.ok) {
              window.alert(payload?.message ?? `Failed to yank ${packageName}@${version}.`);
              return;
            }

            window.location.reload();
          } finally {
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = false;
            }
          }
        });
      }
    </script>
  ) : null
}
