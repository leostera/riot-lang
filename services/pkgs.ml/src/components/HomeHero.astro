---
import SearchForm from "./SearchForm.astro";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";
import type {
  CategoriesIndexDocument,
  PopularPackagesDocument,
  RecentPackagesDocument,
} from "@/lib/types.ts";

interface Props {
  categories: CategoriesIndexDocument | null;
  popular: PopularPackagesDocument | null;
  recent: RecentPackagesDocument | null;
}

const { categories, popular, recent } = Astro.props;
---

<section class="border-b border-border">
  <div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6">
    <div class="mx-auto grid max-w-3xl gap-5 text-center">
      <p class="text-sm text-muted-foreground">
        The Riot&apos;s community package registry
      </p>

      <SearchForm
        large
        autofocus
        placeholder="Search packages, descriptions, owners, or repositories..."
      />
    </div>
  </div>
</section>

<section class="py-8">
  <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 sm:grid-cols-3 sm:px-6">
    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Popular categories</CardTitle>
        <CardDescription>Jump into the ecosystem through common areas of development.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-3">
        {
          (categories?.categories.length ?? 0) === 0 ? (
            <p class="text-xs leading-5 text-muted-foreground">No categories have been published yet.</p>
          ) : (
            categories?.categories.slice(0, 6).map((category) => (
              <article class="grid gap-1 border-b border-border/70 pb-3 last:border-b-0 last:pb-0">
                <h3 class="text-sm font-medium text-foreground">{category.name}</h3>
                <p class="text-xs leading-5 text-muted-foreground">
                  {category.package_count} package{category.package_count === 1 ? "" : "s"}
                </p>
                <div class="flex flex-wrap gap-1">
                  {category.packages.slice(0, 3).map((packageName) => (
                    <a
                      href={`/p/${packageName}`}
                      class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground hover:text-foreground"
                    >
                      {packageName}
                    </a>
                  ))}
                </div>
              </article>
            ))
          )
        }
      </CardContent>
    </Card>

    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Popular packages</CardTitle>
        <CardDescription>Packages with the strongest usage signal in the registry.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-2">
        {
          (popular?.packages.length ?? 0) === 0 ? (
            <p class="text-xs leading-5 text-muted-foreground">No popular packages available yet.</p>
          ) : (
            popular?.packages.slice(0, 6).map((item) => (
              <article class="grid gap-1 border-b border-border/70 pb-2 last:border-b-0 last:pb-0">
                <div class="flex items-start justify-between gap-2">
                  <div class="grid gap-1">
                    <a href={item.package_path} class="text-sm font-medium text-foreground hover:text-primary">
                      {item.package_name}
                    </a>
                    <p class="text-xs leading-5 text-muted-foreground">
                      {item.description ?? "Published OCaml package"}
                    </p>
                  </div>
                  <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                    v{item.latest_version}
                  </span>
                </div>
              </article>
            ))
          )
        }
      </CardContent>
    </Card>

    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Recently updated</CardTitle>
        <CardDescription>Fresh registry activity and package updates.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-2">
        {
          (recent?.packages.length ?? 0) === 0 ? (
            <p class="text-xs leading-5 text-muted-foreground">No package releases have been indexed yet.</p>
          ) : (
            recent?.packages.slice(0, 6).map((item) => (
              <article class="grid gap-1 border-b border-border/70 pb-2 last:border-b-0 last:pb-0">
                <a href={item.package_path} class="text-sm font-medium text-foreground hover:text-primary">
                  {item.package_name}
                </a>
                <p class="text-xs leading-5 text-muted-foreground">
                  v{item.latest_version} · updated {new Intl.DateTimeFormat("en", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  }).format(new Date(item.updated_at))}
                </p>
              </article>
            ))
          )
        }
      </CardContent>
    </Card>
  </div>
</section>
