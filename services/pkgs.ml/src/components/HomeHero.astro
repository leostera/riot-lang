---
import SearchForm from "./SearchForm.astro";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";

const categories = [
  {
    title: "Web programming",
    description: "Frameworks, HTTP clients, servers, and real-time primitives.",
    tags: ["http", "server", "websocket"],
  },
  {
    title: "Actors and concurrency",
    description: "Schedulers, mailboxes, timers, and concurrent runtime building blocks.",
    tags: ["actors", "runtime", "mailbox"],
  },
  {
    title: "Developer tooling",
    description: "Build planning, formatters, linters, and workspace automation.",
    tags: ["build", "cli", "formatting"],
  },
  {
    title: "Data and storage",
    description: "JSON, SQL, SQLite, Postgres, and persistence-oriented packages.",
    tags: ["json", "sqlite", "postgres"],
  },
];

const featured = [
  {
    name: "kernel",
    version: "0.0.1",
    description: "Low-level runtime and event loop primitives for the Riot stack.",
  },
  {
    name: "miniriot",
    version: "0.0.1",
    description: "Actor runtime building blocks and scheduler infrastructure.",
  },
  {
    name: "suri",
    version: "0.0.1",
    description: "Web framework components for routing, middleware, and live views.",
  },
];

const recent = [
  { name: "kernel", note: "Core runtime updates and release metadata." },
  { name: "miniriot", note: "Actor runtime release published from source." },
  { name: "suri", note: "Package index metadata refreshed." },
];
---

<section class="border-b border-border">
  <div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6">
    <div class="mx-auto grid max-w-3xl gap-5 text-center">
      <p class="text-sm text-muted-foreground">
        The Riot&apos;s community package registry
      </p>

      <SearchForm
        large
        autofocus
        placeholder="Search packages, descriptions, owners, or repositories..."
      />
    </div>
  </div>
</section>

<section class="py-8">
  <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 sm:grid-cols-3 sm:px-6">
    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Popular categories</CardTitle>
        <CardDescription>Jump into the ecosystem through common areas of development.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-3">
        {categories.map((category) => (
          <article class="grid gap-1 border-b border-border/70 pb-3 last:border-b-0 last:pb-0">
            <h3 class="text-sm font-medium text-foreground">{category.title}</h3>
            <p class="text-xs leading-5 text-muted-foreground">{category.description}</p>
            <div class="flex flex-wrap gap-1">
              {category.tags.map((tag) => (
                <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))}
      </CardContent>
    </Card>

    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Featured packages</CardTitle>
        <CardDescription>Useful packages to start exploring the registry.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-2">
        {featured.map((item) => (
          <article class="grid gap-1 border-b border-border/70 pb-2 last:border-b-0 last:pb-0">
            <div class="flex items-start justify-between gap-2">
              <div class="grid gap-1">
                <a href={`/p/${item.name}`} class="text-sm font-medium text-foreground hover:text-primary">
                  {item.name}
                </a>
                <p class="text-xs leading-5 text-muted-foreground">{item.description}</p>
              </div>
              <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                v{item.version}
              </span>
            </div>
          </article>
        ))}
      </CardContent>
    </Card>

    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-sm">Recently updated</CardTitle>
        <CardDescription>Fresh registry activity and package updates.</CardDescription>
      </CardHeader>
      <CardContent className="grid gap-2">
        {recent.map((item) => (
          <article class="grid gap-1 border-b border-border/70 pb-2 last:border-b-0 last:pb-0">
            <a href={`/?q=${encodeURIComponent(item.name)}`} class="text-sm font-medium text-foreground hover:text-primary">
              {item.name}
            </a>
            <p class="text-xs leading-5 text-muted-foreground">{item.note}</p>
          </article>
        ))}
      </CardContent>
    </Card>
  </div>
</section>
