---
import PackageActivity from "@/components/PackageActivity.astro";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import type {
  IndexedPackageRelease,
  PackageIndexDocument,
  PackageOverviewDocument,
  PackageRelationsDocument,
  RegistryEventRecord,
} from "../lib/types.ts";

interface Props {
  document: PackageIndexDocument;
  release: IndexedPackageRelease;
  overview?: PackageOverviewDocument | null;
  relations?: PackageRelationsDocument | null;
  events?: RegistryEventRecord[];
}

const { document, release, relations = null, events = [] } = Astro.props;
const dependencyRows =
  relations?.dependencies ??
  release.dependencies.map((dependency) => {
    const record = dependency as Record<string, unknown>;
    const name =
      typeof record.package === "string"
        ? record.package
        : typeof record.name === "string"
          ? record.name
          : "unknown";
    const requirement =
      typeof record.version === "string"
        ? record.version
        : typeof record.raw === "string"
          ? record.raw
          : typeof record.requirement === "string"
            ? record.requirement
            : "unspecified";

    return { package_name: name, requirement };
  });
---

<section class="w-full px-4 pb-10 sm:px-6 xl:px-8">
  <div class="mx-auto grid w-full max-w-6xl gap-4">
    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-base">Dependencies</CardTitle>
        <CardDescription>
          Dependencies declared for this release.
        </CardDescription>
      </CardHeader>
      <CardContent className="py-3">
        {
          dependencyRows.length === 0 ? (
            <p class="text-sm text-muted-foreground">No dependencies declared for this release.</p>
          ) : (
            <ul class="grid gap-2">
              {dependencyRows.map((dependency) => (
                <li class="flex flex-wrap items-center justify-between gap-2 border-b border-border/70 pb-2 text-base last:border-b-0 last:pb-0">
                  <a href={`/p/${dependency.package_name}`} class="font-medium text-foreground hover:text-primary">
                    {dependency.package_name}
                  </a>
                  <code class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[11px] text-foreground">
                    {dependency.requirement}
                  </code>
                </li>
              ))}
            </ul>
          )
        }
      </CardContent>
    </Card>

    <Card size="sm" className="rounded-md shadow-none">
      <CardHeader className="border-b border-border">
        <CardTitle className="text-base">Dependents</CardTitle>
        <CardDescription>
          Packages that currently depend on {document.name}.
        </CardDescription>
      </CardHeader>
      <CardContent className="py-3">
        {
          (relations?.dependents.length ?? 0) === 0 ? (
            <p class="text-sm text-muted-foreground">No indexed dependents yet.</p>
          ) : (
            <ul class="grid gap-2">
              {relations?.dependents.map((dependent) => (
                <li class="flex flex-wrap items-center justify-between gap-2 border-b border-border/70 pb-2 text-base last:border-b-0 last:pb-0">
                  <a href={`/p/${dependent.package_name}`} class="font-medium text-foreground hover:text-primary">
                    {dependent.package_name}
                  </a>
                  <code class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[11px] text-foreground">
                    {dependent.requirement}
                  </code>
                </li>
              ))}
            </ul>
          )
        }
      </CardContent>
    </Card>

    <PackageActivity events={events} />
  </div>
</section>
