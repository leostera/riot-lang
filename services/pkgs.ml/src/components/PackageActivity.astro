---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import {
  eventLabel,
  eventTone,
  formatEventTimestamp,
  formatEventTimestampCompact,
  packageActivityHref,
  packageHref,
  packageLabel,
  secondaryFacts,
} from "@/lib/registry-events.ts";
import type { RegistryEventRecord } from "../lib/types.ts";

interface Props {
  events: RegistryEventRecord[];
  collapsedByDefault?: boolean;
  showListDisclosure?: boolean;
  fullActivityHref?: string;
  title?: string;
  description?: string;
  eventLinkMode?: "package" | "activity" | "none";
  emptyMessage?: string;
}

const {
  events,
  collapsedByDefault = false,
  showListDisclosure = true,
  fullActivityHref,
  title = "Recent activity",
  description = "Latest publication, indexing, and post-publish pipeline events recorded for this package.",
  eventLinkMode = "none",
  emptyMessage = "No activity has been recorded for this package yet.",
} = Astro.props;

function eventTargetHref(event: RegistryEventRecord): string | null {
  if (eventLinkMode === "activity") {
    return packageActivityHref(event);
  }

  if (eventLinkMode === "package") {
    return packageHref(event);
  }

  return null;
}

const renderedEvents = events.map((event) => ({
  event,
  facts: secondaryFacts(event),
  targetHref: eventTargetHref(event),
  payloadJson:
    Object.keys(event.payload).length > 0
      ? JSON.stringify(event.payload, null, 2)
      : null,
}));
---

<Card size="sm" className="rounded-md shadow-none">
  <CardHeader className="border-b border-border">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="grid gap-1">
        <CardTitle className="text-base">{title}</CardTitle>
        <CardDescription>
          {description}
        </CardDescription>
      </div>

      {
        fullActivityHref ? (
          <a
            href={fullActivityHref}
            class="text-sm font-medium text-primary hover:text-foreground"
          >
            Open full activity
          </a>
        ) : null
      }
    </div>
  </CardHeader>
  <CardContent className="py-3">
    {
      showListDisclosure ? (
        <details class="group" open={!collapsedByDefault}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-medium text-foreground marker:hidden">
            <span>{events.length === 0 ? "No activity recorded yet" : `Show ${events.length} recent events`}</span>
            <span class="text-xs text-muted-foreground group-open:hidden">Expand</span>
            <span class="hidden text-xs text-muted-foreground group-open:inline">Collapse</span>
          </summary>

          <div class="mt-3">
            {
              renderedEvents.length === 0 ? (
                <p class="text-base text-muted-foreground">{emptyMessage}</p>
              ) : (
                <ul class="grid gap-2">
                  {renderedEvents.map(({ event, facts, targetHref, payloadJson }) => (
                    <li>
                      <details class="group overflow-hidden rounded-md border border-border bg-card">
                        <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-3 marker:hidden">
                          <div class="min-w-0 flex-1">
                            <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                              <time class="shrink-0 text-xs text-muted-foreground" datetime={event.created_at}>
                                {formatEventTimestampCompact(event.created_at)}
                              </time>
                              <span class:list={["inline-flex items-center rounded-sm border px-2 py-0.5 text-[11px] font-medium", eventTone(event.event_type)]}>
                                {eventLabel(event.event_type)}
                              </span>
                              {
                                targetHref ? (
                                  <a href={targetHref} class="min-w-0 text-sm font-medium text-foreground hover:text-primary">
                                    {packageLabel(event)}
                                  </a>
                                ) : (
                                  <span class="min-w-0 text-sm font-medium text-foreground">
                                    {packageLabel(event)}
                                  </span>
                                )
                              }
                              {
                                facts.length > 0 ? (
                                  <span class="min-w-0 text-sm text-muted-foreground sm:truncate">
                                    {facts.join(" · ")}
                                  </span>
                                ) : null
                              }
                            </div>
                          </div>

                          <span class="shrink-0 text-xs text-muted-foreground group-open:hidden">Details</span>
                          <span class="hidden shrink-0 text-xs text-muted-foreground group-open:inline">Hide</span>
                        </summary>

                        <div class="grid gap-4 border-t border-border px-4 py-3">
                          <dl class="grid gap-3 sm:grid-cols-2">
                            <div class="grid gap-1">
                              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">When</dt>
                              <dd class="text-sm text-foreground">{formatEventTimestamp(event.created_at)}</dd>
                            </div>

                            <div class="grid gap-1">
                              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Event</dt>
                              <dd>
                                <span class:list={["inline-flex w-fit items-center rounded-sm border px-2 py-0.5 text-xs font-medium", eventTone(event.event_type)]}>
                                  {eventLabel(event.event_type)}
                                </span>
                              </dd>
                            </div>

                            {
                              event.package_name ? (
                                <div class="grid gap-1">
                                  <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Package</dt>
                                  <dd class="text-sm text-foreground">{event.package_name}</dd>
                                </div>
                              ) : null
                            }

                            {
                              event.package_version ? (
                                <div class="grid gap-1">
                                  <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Version</dt>
                                  <dd class="text-sm text-foreground">{event.package_version}</dd>
                                </div>
                              ) : null
                            }

                            {
                              event.package_locator ? (
                                <div class="grid gap-1 sm:col-span-2">
                                  <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Locator</dt>
                                  <dd class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                                    {event.package_locator}
                                  </dd>
                                </div>
                              ) : null
                            }

                            {
                              targetHref ? (
                                <div class="grid gap-1 sm:col-span-2">
                                  <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Inspect</dt>
                                  <dd>
                                    <a href={targetHref} class="text-sm font-medium text-primary hover:text-foreground">
                                      {eventLinkMode === "activity" ? "Open package activity" : "Open package page"}
                                    </a>
                                  </dd>
                                </div>
                              ) : null
                            }
                          </dl>

                          {
                            facts.length > 0 ? (
                              <div class="grid gap-2">
                                <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Facts</div>
                                <div class="flex flex-wrap gap-2 text-sm text-muted-foreground">
                                  {facts.map((fact) => (
                                    <span class="rounded-sm border border-border bg-muted px-2 py-0.5">
                                      {fact}
                                    </span>
                                  ))}
                                </div>
                              </div>
                            ) : null
                          }

                          {
                            payloadJson ? (
                              <div class="grid gap-2">
                                <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Payload</div>
                                <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">{payloadJson}</pre>
                              </div>
                            ) : null
                          }
                        </div>
                      </details>
                    </li>
                  ))}
                </ul>
              )
            }
          </div>
        </details>
      ) : (
        renderedEvents.length === 0 ? (
          <p class="text-base text-muted-foreground">{emptyMessage}</p>
        ) : (
          <ul class="grid gap-2">
            {renderedEvents.map(({ event, facts, targetHref, payloadJson }) => (
              <li>
                <details class="group overflow-hidden rounded-md border border-border bg-card">
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-3 marker:hidden">
                    <div class="min-w-0 flex-1">
                      <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                        <time class="shrink-0 text-xs text-muted-foreground" datetime={event.created_at}>
                          {formatEventTimestampCompact(event.created_at)}
                        </time>
                        <span class:list={["inline-flex items-center rounded-sm border px-2 py-0.5 text-[11px] font-medium", eventTone(event.event_type)]}>
                          {eventLabel(event.event_type)}
                        </span>
                        {
                          targetHref ? (
                            <a href={targetHref} class="min-w-0 text-sm font-medium text-foreground hover:text-primary">
                              {packageLabel(event)}
                            </a>
                          ) : (
                            <span class="min-w-0 text-sm font-medium text-foreground">
                              {packageLabel(event)}
                            </span>
                          )
                        }
                        {
                          facts.length > 0 ? (
                            <span class="min-w-0 text-sm text-muted-foreground sm:truncate">
                              {facts.join(" · ")}
                            </span>
                          ) : null
                        }
                      </div>
                    </div>

                    <span class="shrink-0 text-xs text-muted-foreground group-open:hidden">Details</span>
                    <span class="hidden shrink-0 text-xs text-muted-foreground group-open:inline">Hide</span>
                  </summary>

                  <div class="grid gap-4 border-t border-border px-4 py-3">
                    <dl class="grid gap-3 sm:grid-cols-2">
                      <div class="grid gap-1">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">When</dt>
                        <dd class="text-sm text-foreground">{formatEventTimestamp(event.created_at)}</dd>
                      </div>

                      <div class="grid gap-1">
                        <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Event</dt>
                        <dd>
                          <span class:list={["inline-flex w-fit items-center rounded-sm border px-2 py-0.5 text-xs font-medium", eventTone(event.event_type)]}>
                            {eventLabel(event.event_type)}
                          </span>
                        </dd>
                      </div>

                      {
                        event.package_name ? (
                          <div class="grid gap-1">
                            <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Package</dt>
                            <dd class="text-sm text-foreground">{event.package_name}</dd>
                          </div>
                        ) : null
                      }

                      {
                        event.package_version ? (
                          <div class="grid gap-1">
                            <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Version</dt>
                            <dd class="text-sm text-foreground">{event.package_version}</dd>
                          </div>
                        ) : null
                      }

                      {
                        event.package_locator ? (
                          <div class="grid gap-1 sm:col-span-2">
                            <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Locator</dt>
                            <dd class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                              {event.package_locator}
                            </dd>
                          </div>
                        ) : null
                      }

                      {
                        targetHref ? (
                          <div class="grid gap-1 sm:col-span-2">
                            <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Inspect</dt>
                            <dd>
                              <a href={targetHref} class="text-sm font-medium text-primary hover:text-foreground">
                                {eventLinkMode === "activity" ? "Open package activity" : "Open package page"}
                              </a>
                            </dd>
                          </div>
                        ) : null
                      }
                    </dl>

                    {
                      facts.length > 0 ? (
                        <div class="grid gap-2">
                          <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Facts</div>
                          <div class="flex flex-wrap gap-2 text-sm text-muted-foreground">
                            {facts.map((fact) => (
                              <span class="rounded-sm border border-border bg-muted px-2 py-0.5">
                                {fact}
                              </span>
                            ))}
                          </div>
                        </div>
                      ) : null
                    }

                    {
                      payloadJson ? (
                        <div class="grid gap-2">
                          <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Payload</div>
                          <pre class="overflow-x-auto rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">{payloadJson}</pre>
                        </div>
                      ) : null
                    }
                  </div>
                </details>
              </li>
            ))}
          </ul>
        )
      )
    }
  </CardContent>
</Card>
