---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import RegistryEventItem from "@/components/RegistryEventItem.astro";
import {
  packageActivityHref,
  packageHref,
  secondaryFacts,
} from "@/lib/registry-events.ts";
import type { RegistryEventRecord } from "../lib/types.ts";

interface Props {
  events: RegistryEventRecord[];
  collapsedByDefault?: boolean;
  collapseOnMobileOnly?: boolean;
  showListDisclosure?: boolean;
  fullActivityHref?: string;
  title?: string;
  description?: string;
  eventLinkMode?: "package" | "activity" | "none";
  emptyMessage?: string;
}

const {
  events,
  collapsedByDefault = false,
  collapseOnMobileOnly = false,
  showListDisclosure = true,
  fullActivityHref,
  title = "Recent activity",
  description = "Latest publication, indexing, and post-publish pipeline events recorded for this package.",
  eventLinkMode = "none",
  emptyMessage = "No activity has been recorded for this package yet.",
} = Astro.props;

function eventTargetHref(event: RegistryEventRecord): string | null {
  if (eventLinkMode === "activity") {
    return packageActivityHref(event);
  }

  if (eventLinkMode === "package") {
    return packageHref(event);
  }

  return null;
}

const inspectLabel = eventLinkMode === "activity" ? "Open package activity" : "Open package page";
const renderedEvents = events.map((event) => {
  const facts = secondaryFacts(event);

  return {
    event,
    facts,
    targetHref: eventTargetHref(event),
    factsText: facts.join(" · "),
    payloadJson:
      Object.keys(event.payload).length > 0
        ? JSON.stringify(event.payload, null, 2)
        : null,
    failureSummary:
      typeof event.payload.failure_summary === "string" && event.payload.failure_summary.length > 0
        ? event.payload.failure_summary
        : typeof event.payload.status_message === "string" && event.payload.status_message.length > 0
          ? event.payload.status_message
          : null,
    resultKey:
      typeof event.payload.result_key === "string" && event.payload.result_key.length > 0
        ? event.payload.result_key
        : null,
    logsKey:
      typeof event.payload.logs_key === "string" && event.payload.logs_key.length > 0
        ? event.payload.logs_key
        : null,
  };
});
---

<Card size="sm" className="rounded-md shadow-none xl:self-start">
  <CardHeader className="border-b border-border">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="grid gap-1">
        <CardTitle className="text-base">{title}</CardTitle>
        <CardDescription>
          {description}
        </CardDescription>
      </div>

      {
        fullActivityHref ? (
          <a
            href={fullActivityHref}
            class="text-sm font-medium text-accent-foreground hover:text-foreground"
          >
            Open full activity
          </a>
        ) : null
      }
    </div>
  </CardHeader>
  <CardContent className="py-3">
    {
      showListDisclosure ? (
        collapseOnMobileOnly ? (
          <>
            <details class="group md:hidden" open={!collapsedByDefault}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-medium text-foreground marker:hidden">
                <span>{events.length === 0 ? "No activity recorded yet" : `Show ${events.length} recent events`}</span>
                <span class="text-xs text-muted-foreground group-open:hidden">Expand</span>
                <span class="hidden text-xs text-muted-foreground group-open:inline">Collapse</span>
              </summary>

              <div class="mt-3">
                {
                  renderedEvents.length === 0 ? (
                    <p class="text-base text-muted-foreground">{emptyMessage}</p>
                  ) : (
                    <ul class="grid gap-2">
                      {renderedEvents.map((renderedEvent) => (
                        <RegistryEventItem
                          {...renderedEvent}
                          inspectLabel={inspectLabel}
                        />
                      ))}
                    </ul>
                  )
                }
              </div>
            </details>

            <div class="hidden md:block">
              {
                renderedEvents.length === 0 ? (
                  <p class="text-base text-muted-foreground">{emptyMessage}</p>
                ) : (
                  <ul class="grid gap-2">
                    {renderedEvents.map((renderedEvent) => (
                      <RegistryEventItem
                        {...renderedEvent}
                        inspectLabel={inspectLabel}
                      />
                    ))}
                  </ul>
                )
              }
            </div>
          </>
        ) : (
          <details class="group" open={!collapsedByDefault}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-medium text-foreground marker:hidden">
              <span>{events.length === 0 ? "No activity recorded yet" : `Show ${events.length} recent events`}</span>
              <span class="text-xs text-muted-foreground group-open:hidden">Expand</span>
              <span class="hidden text-xs text-muted-foreground group-open:inline">Collapse</span>
            </summary>

            <div class="mt-3">
              {
                renderedEvents.length === 0 ? (
                  <p class="text-base text-muted-foreground">{emptyMessage}</p>
                ) : (
                  <ul class="grid gap-2">
                    {renderedEvents.map((renderedEvent) => (
                      <RegistryEventItem
                        {...renderedEvent}
                        inspectLabel={inspectLabel}
                      />
                    ))}
                  </ul>
                )
              }
            </div>
          </details>
        )
      ) : (
        renderedEvents.length === 0 ? (
          <p class="text-base text-muted-foreground">{emptyMessage}</p>
        ) : (
          <ul class="grid gap-2">
            {renderedEvents.map((renderedEvent) => (
              <RegistryEventItem
                {...renderedEvent}
                inspectLabel={inspectLabel}
              />
            ))}
          </ul>
        )
      )
    }
  </CardContent>
</Card>
