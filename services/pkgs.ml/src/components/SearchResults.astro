---
import type { SearchResponse } from "../lib/types.ts";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";

interface Props {
  query: string;
  response: SearchResponse;
}

const { query, response } = Astro.props;

function formatUpdatedAt(value: string): string {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return "Unknown";
  }

  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
}
---

<section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
  <div class="grid gap-4">
    <div class="grid gap-1 border-b border-border pb-4">
      <div class="grid gap-1">
        <h1 class="text-base font-semibold tracking-tight text-foreground">Search OCaml packages</h1>
        <p class="text-xs text-muted-foreground">
          {response.count} result{response.count === 1 ? "" : "s"} for <code>{query}</code>
        </p>
      </div>
    </div>

    {
      response.results.length === 0 ? (
        <Card size="sm" className="rounded-md shadow-none">
          <CardHeader>
            <CardTitle className="text-sm">No packages matched</CardTitle>
            <CardDescription>
              Try a different package name, repository owner, or keyword.
            </CardDescription>
          </CardHeader>
        </Card>
      ) : (
        <div class="grid gap-3">
          {response.results.map((result) => (
            <Card size="sm" className="rounded-md shadow-none">
              <CardContent className="grid gap-3 py-3">
                <div class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_auto_auto] sm:items-baseline sm:gap-x-4">
                  <div class="flex min-w-0 flex-wrap items-center gap-2">
                    <a
                      href={`/p/${result.package_name}`}
                      class="text-sm font-semibold tracking-tight text-foreground hover:text-primary"
                    >
                      {result.package_name}
                    </a>
                    <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                      v{result.latest_version}
                    </span>
                  </div>

                  <div class="text-[11px] text-muted-foreground sm:text-right">
                    {result.release_count} version{result.release_count === 1 ? "" : "s"}
                  </div>

                  <div class="text-[11px] text-muted-foreground sm:text-right">
                    {result.license || "License pending"}
                  </div>
                </div>

                <div class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_auto_auto] sm:items-start sm:gap-x-4">
                  <p class="min-w-0 text-xs leading-5 text-muted-foreground">
                    {result.description || "No package description has been published yet."}
                  </p>

                  <div class="text-[11px] text-muted-foreground sm:text-right">
                    Total downloads: tracking soon
                  </div>

                  <div class="text-[11px] text-muted-foreground sm:text-right">
                    Last updated: {formatUpdatedAt(result.updated_at)}
                  </div>
                </div>

                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] text-muted-foreground">
                  {result.repository ? (
                    <a
                      class="hover:text-foreground"
                      href={result.repository}
                      target="_blank"
                      rel="noreferrer"
                    >
                      Repository
                    </a>
                  ) : null}
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      )
    }
  </div>
</section>
