---
interface Props {
  login: string;
  avatarUrl?: string;
  href?: string;
  size?: "sm" | "md";
  showLogin?: boolean;
}

const {
  login,
  avatarUrl,
  href,
  size = "md",
  showLogin = true,
} = Astro.props;

const avatarClass =
  size === "sm"
    ? "h-5 w-5 text-[10px]"
    : "h-8 w-8 text-xs";
const labelClass = size === "sm" ? "text-xs" : "text-sm";
---

{
  href ? (
    <a href={href} class="inline-flex items-center gap-2 hover:text-primary">
      {
        avatarUrl ? (
          <img
            src={avatarUrl}
            alt={`@${login}`}
            class:list={[avatarClass, "rounded-full border border-border object-cover"]}
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span
            class:list={[
              avatarClass,
              "inline-flex items-center justify-center rounded-full border border-border bg-muted font-medium uppercase text-muted-foreground",
            ]}
            aria-hidden="true"
          >
            {login.slice(0, 1)}
          </span>
        )
      }
      {
        showLogin ? (
          <span class:list={[labelClass, "font-medium text-foreground"]}>@{login}</span>
        ) : null
      }
    </a>
  ) : (
    <span class="inline-flex items-center gap-2">
      {
        avatarUrl ? (
          <img
            src={avatarUrl}
            alt={`@${login}`}
            class:list={[avatarClass, "rounded-full border border-border object-cover"]}
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span
            class:list={[
              avatarClass,
              "inline-flex items-center justify-center rounded-full border border-border bg-muted font-medium uppercase text-muted-foreground",
            ]}
            aria-hidden="true"
          >
            {login.slice(0, 1)}
          </span>
        )
      }
      {
        showLogin ? (
          <span class:list={[labelClass, "font-medium text-foreground"]}>@{login}</span>
        ) : null
      }
    </span>
  )
}
