---
interface Props {
  login: string;
  avatarUrl?: string;
  href?: string;
  size?: "sm" | "md";
  showLogin?: boolean;
}

const {
  login,
  avatarUrl,
  href,
  size = "md",
  showLogin = true,
} = Astro.props;

const avatarClass =
  size === "sm"
    ? "size-5 text-[10px]"
    : "size-8 text-xs";
const labelClass = size === "sm" ? "text-xs" : "text-sm";
const rootClass = showLogin ? "inline-flex items-center gap-2" : "inline-flex shrink-0 items-center";
const imageClass = `${avatarClass} block shrink-0 rounded-full border border-border object-cover aspect-square`;
const placeholderClass = `${avatarClass} inline-flex shrink-0 items-center justify-center rounded-full border border-border bg-muted font-medium uppercase text-muted-foreground aspect-square`;
---

{
  href ? (
    <a href={href} class:list={[rootClass, "hover:text-primary"]}>
      {
        avatarUrl ? (
          <img
            src={avatarUrl}
            alt={`@${login}`}
            class={imageClass}
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span
            class={placeholderClass}
            aria-hidden="true"
          >
            {login.slice(0, 1)}
          </span>
        )
      }
      {
        showLogin ? (
          <span class:list={[labelClass, "font-medium text-foreground"]}>@{login}</span>
        ) : null
      }
    </a>
  ) : (
    <span class={rootClass}>
      {
        avatarUrl ? (
          <img
            src={avatarUrl}
            alt={`@${login}`}
            class={imageClass}
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span
            class={placeholderClass}
            aria-hidden="true"
          >
            {login.slice(0, 1)}
          </span>
        )
      }
      {
        showLogin ? (
          <span class:list={[labelClass, "font-medium text-foreground"]}>@{login}</span>
        ) : null
      }
    </span>
  )
}
