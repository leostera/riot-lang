---
import {
  eventLabel,
  eventTone,
  formatEventTimestamp,
  formatEventTimestampCompact,
  packageLabel,
} from "@/lib/registry-events.ts";
import type { RegistryEventRecord } from "../lib/types.ts";

interface Props {
  event: RegistryEventRecord;
  facts: string[];
  factsText: string;
  targetHref?: string | null;
  inspectLabel?: string;
  payloadJson?: string | null;
  failureSummary?: string | null;
  resultKey?: string | null;
  logsKey?: string | null;
}

const {
  event,
  facts,
  factsText,
  targetHref = null,
  inspectLabel = "Open package page",
  payloadJson = null,
  failureSummary = null,
  resultKey = null,
  logsKey = null,
} = Astro.props;
---

<li>
  <details class="group overflow-hidden rounded-md border border-border bg-card">
    <summary class="flex cursor-pointer list-none items-center gap-3 px-4 py-3 marker:hidden">
      <time class="shrink-0 text-xs text-muted-foreground" datetime={event.created_at}>
        {formatEventTimestampCompact(event.created_at)}
      </time>

      <span
        class:list={[
          "inline-flex shrink-0 items-center rounded-sm border px-2 py-0.5 text-[11px] font-medium",
          eventTone(event.event_type),
        ]}
      >
        {eventLabel(event.event_type)}
      </span>

      <div class="min-w-0 flex-1 overflow-hidden">
        <div class="flex min-w-0 items-center gap-2 overflow-hidden whitespace-nowrap">
          {
            targetHref ? (
              <>
                <span class="min-w-0 max-w-[14rem] truncate text-sm font-medium text-foreground md:hidden">
                  {packageLabel(event)}
                </span>
                <a
                  href={targetHref}
                  class="hidden min-w-0 max-w-[14rem] truncate text-sm font-medium text-foreground hover:text-primary md:inline-flex"
                >
                  {packageLabel(event)}
                </a>
              </>
            ) : (
              <span class="min-w-0 max-w-[14rem] truncate text-sm font-medium text-foreground">
                {packageLabel(event)}
              </span>
            )
          }

          {
            factsText.length > 0 ? (
              <span class="min-w-0 flex-1 truncate text-sm text-muted-foreground">
                {factsText}
              </span>
            ) : null
          }
        </div>
      </div>

      <span class="shrink-0 text-xs text-muted-foreground group-open:hidden">Details</span>
      <span class="hidden shrink-0 text-xs text-muted-foreground group-open:inline">Hide</span>
    </summary>

    <div class="grid gap-4 border-t border-border px-4 py-3">
      <dl class="grid gap-3 sm:grid-cols-2">
        <div class="grid gap-1">
          <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">When</dt>
          <dd class="text-sm text-foreground">{formatEventTimestamp(event.created_at)}</dd>
        </div>

        <div class="grid gap-1">
          <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Event</dt>
          <dd>
            <span
              class:list={[
                "inline-flex w-fit items-center rounded-sm border px-2 py-0.5 text-xs font-medium",
                eventTone(event.event_type),
              ]}
            >
              {eventLabel(event.event_type)}
            </span>
          </dd>
        </div>

        {
          event.package_name ? (
            <div class="grid gap-1">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Package</dt>
              <dd class="text-sm text-foreground">{event.package_name}</dd>
            </div>
          ) : null
        }

        {
          event.package_version ? (
            <div class="grid gap-1">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Version</dt>
              <dd class="text-sm text-foreground">{event.package_version}</dd>
            </div>
          ) : null
        }

        {
          event.package_locator ? (
            <div class="grid gap-1 sm:col-span-2">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Locator</dt>
              <dd class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                {event.package_locator}
              </dd>
            </div>
          ) : null
        }

        {
          targetHref ? (
            <div class="grid gap-1 sm:col-span-2">
              <dt class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Inspect</dt>
              <dd>
                <a href={targetHref} class="text-sm font-medium text-accent-foreground hover:text-foreground">
                  {inspectLabel}
                </a>
              </dd>
            </div>
          ) : null
        }
      </dl>

      {
        failureSummary ? (
          <div class="grid gap-2">
            <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Summary</div>
            <pre class="max-h-48 overflow-auto whitespace-pre-wrap break-words rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">{failureSummary}</pre>
          </div>
        ) : null
      }

      {
        facts.length > 0 ? (
          <div class="grid gap-2">
            <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Facts</div>
            <div class="flex flex-wrap gap-2 text-sm text-muted-foreground">
              {facts.map((fact) => (
                <span class="rounded-sm border border-border bg-muted px-2 py-0.5">
                  {fact}
                </span>
              ))}
            </div>
          </div>
        ) : null
      }

      {
        resultKey || logsKey ? (
          <div class="grid gap-2">
            <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Artifacts</div>
            <div class="grid gap-2">
              {
                resultKey ? (
                  <div class="grid gap-1">
                    <div class="text-xs text-muted-foreground">Result key</div>
                    <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                      {resultKey}
                    </code>
                  </div>
                ) : null
              }
              {
                logsKey ? (
                  <div class="grid gap-1">
                    <div class="text-xs text-muted-foreground">Logs key</div>
                    <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-xs text-foreground">
                      {logsKey}
                    </code>
                  </div>
                ) : null
              }
            </div>
          </div>
        ) : null
      }

      {
        payloadJson ? (
          <div class="grid gap-2">
            <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Payload</div>
            <pre class="max-h-[28rem] overflow-auto whitespace-pre-wrap break-words rounded-md border border-border bg-muted px-3 py-3 text-xs leading-6 text-foreground">{payloadJson}</pre>
          </div>
        ) : null
      }
    </div>
  </details>
</li>
