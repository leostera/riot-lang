---
import type { RegistryEventRecord, RegistryEventType } from "../lib/types.ts";

interface Props {
  events: RegistryEventRecord[];
}

interface PipelineStage {
  key: string;
  label: string;
  event_types: RegistryEventType[];
}

const { events } = Astro.props;

const stages: PipelineStage[] = [
  {
    key: "submitted",
    label: "Submitted",
    event_types: ["package.submitted"],
  },
  {
    key: "indexed",
    label: "Indexed",
    event_types: ["package.indexed"],
  },
  {
    key: "searchable",
    label: "Searchable",
    event_types: ["package.searchable"],
  },
  {
    key: "docs-ready",
    label: "Docs ready",
    event_types: ["package.docs.generated"],
  },
  {
    key: "completed",
    label: "Completed",
    event_types: ["package.processing.finished"],
  },
];

function latestStageEvent(eventTypes: RegistryEventType[]): RegistryEventRecord | null {
  let latest: RegistryEventRecord | null = null;

  for (const event of events) {
    if (!eventTypes.includes(event.event_type)) {
      continue;
    }

    if (latest === null || event.created_at > latest.created_at) {
      latest = event;
    }
  }

  return latest;
}

function formatTimestamp(value: string): string {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }).format(date);
}

const stageStates = stages.map((stage) => ({
  ...stage,
  event: latestStageEvent(stage.event_types),
}));
---

<div class="grid gap-3">
{
    events.length === 0 ? (
      <p class="text-base text-muted-foreground">No pipeline data has been recorded for this release yet.</p>
    ) : (
      <>
        <div class="grid gap-2 md:hidden">
          {stageStates.map((stage, index) => (
            <div class="flex items-start gap-3">
              <div class="flex w-4 shrink-0 flex-col items-center">
                <span
                  class:list={[
                    "mt-1 inline-flex h-3 w-3 shrink-0 items-center justify-center rounded-full",
                    stage.event === null
                      ? "border border-border bg-background"
                      : "bg-emerald-600 dark:bg-emerald-500",
                  ]}
                  aria-hidden="true"
                />
                {
                  index < stageStates.length - 1 ? (
                    <span
                      class:list={[
                        "mt-1 min-h-8 w-px flex-1",
                        stage.event !== null && stageStates[index + 1]?.event !== null
                          ? "bg-emerald-600 dark:bg-emerald-500"
                          : "bg-border",
                      ]}
                      aria-hidden="true"
                    />
                  ) : null
                }
              </div>

              <div class="min-w-0 flex-1 pb-3">
                <div class="text-sm font-medium leading-tight text-foreground">{stage.label}</div>
                <div class="mt-1 text-xs leading-tight text-muted-foreground">
                  {stage.event === null ? "Pending" : formatTimestamp(stage.event.created_at)}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="hidden overflow-x-auto pb-1 md:block">
          <div class="flex min-w-[760px] items-start gap-0">
              {stageStates.map((stage, index) => (
                  <div class="flex min-w-[132px] flex-1 flex-col items-center gap-3 text-center">
                    <div class="flex h-4 w-full items-center pt-1">
                      <span
                        class:list={[
                          "h-px w-full",
                          index === 0
                            ? "bg-transparent"
                            : stageStates[index - 1]?.event !== null && stage.event !== null
                              ? "bg-emerald-600 dark:bg-emerald-500"
                              : "bg-border",
                        ]}
                        aria-hidden="true"
                      />

                      <span
                        class:list={[
                          "inline-flex h-3 w-3 shrink-0 items-center justify-center rounded-full",
                          stage.event === null
                            ? "border border-border bg-background"
                            : "bg-emerald-600 dark:bg-emerald-500",
                        ]}
                        aria-hidden="true"
                      />

                      <span
                        class:list={[
                          "h-px w-full",
                          index === stageStates.length - 1
                            ? "bg-transparent"
                            : stage.event !== null && stageStates[index + 1]?.event !== null
                              ? "bg-emerald-600 dark:bg-emerald-500"
                              : "bg-border",
                        ]}
                        aria-hidden="true"
                      />
                    </div>

                    <div class="flex flex-col items-center gap-1">
                      <div class="text-sm font-medium leading-tight text-foreground">{stage.label}</div>
                      <div class="text-xs leading-tight text-muted-foreground">
                        {stage.event === null ? "Pending" : formatTimestamp(stage.event.created_at)}
                      </div>
                    </div>
                  </div>
              ))}
          </div>
        </div>
      </>
    )
  }
</div>
