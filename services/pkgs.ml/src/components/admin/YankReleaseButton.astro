---
import { Button } from "@/components/ui/button";

interface Props {
  packageName: string;
  version: string;
  compact?: boolean;
}

const { packageName, version, compact = false } = Astro.props;
---

<form
  data-yank-form
  data-package-name={packageName}
  data-package-version={version}
  class="inline-flex"
>
  <Button
    type="submit"
    variant="outline"
    size={compact ? "sm" : "default"}
    className="rounded-md border-destructive/20 text-destructive hover:bg-destructive/10 hover:text-destructive"
  >
    Yank version
  </Button>
</form>

<script is:inline>
  if (!(window).__pkgsYankReleaseInit) {
    (window).__pkgsYankReleaseInit = true;

    document.addEventListener("submit", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLFormElement) || !target.hasAttribute("data-yank-form")) {
        return;
      }

      event.preventDefault();

      const packageName = target.dataset.packageName ?? "";
      const version = target.dataset.packageVersion ?? "";
      if (packageName.length === 0 || version.length === 0) {
        return;
      }

      const confirmed = window.confirm(`Yank ${packageName}@${version}?`);
      if (!confirmed) {
        return;
      }

      const submitButton = target.querySelector("button");
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      try {
        const response = await fetch(
          `/api/me/packages/${encodeURIComponent(packageName)}/versions/${encodeURIComponent(version)}/yank`,
          {
            method: "POST",
            headers: {
              accept: "application/json",
            },
          },
        );

        if (response.status === 401) {
          window.location.href = `/login?return_to=${encodeURIComponent(window.location.href)}`;
          return;
        }

        const payload = await response.json();
        if (!response.ok) {
          window.alert(payload?.message ?? `Failed to yank ${packageName}@${version}.`);
          return;
        }

        window.location.reload();
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>
