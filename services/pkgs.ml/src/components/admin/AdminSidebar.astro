---
import GitHubAvatar from "@/components/GitHubAvatar.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  user: string;
  ownerAvatarUrl?: string;
  packageCount: number;
  latestUpdateLabel: string;
  activeSection: "overview" | "packages" | "tokens";
}

const {
  user,
  ownerAvatarUrl,
  packageCount,
  latestUpdateLabel,
  activeSection,
} = Astro.props;

const navItems = [
  { key: "overview", label: "Overview", href: `/u/${user}` },
  { key: "packages", label: "Packages", href: `/u/${user}/packages` },
  { key: "tokens", label: "Tokens", href: `/u/${user}/tokens` },
] as const;
---

<Card className="rounded-md shadow-none">
  <CardHeader className="border-b border-border">
    <CardTitle className="text-base">
      <GitHubAvatar login={user} avatarUrl={ownerAvatarUrl} href={`/u/${user}`} />
    </CardTitle>
  </CardHeader>
  <CardContent className="grid gap-4 py-4">
    <div class="grid gap-1">
      <div class="text-sm text-muted-foreground">Published packages</div>
      <div class="text-base font-medium text-foreground">
        {packageCount} package{packageCount === 1 ? "" : "s"}
      </div>
    </div>

    <div class="grid gap-1">
      <div class="text-sm text-muted-foreground">Latest update</div>
      <div class="text-base text-foreground">{latestUpdateLabel}</div>
    </div>

    <nav class="grid gap-1 border-t border-border pt-4 text-sm">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-md px-3 py-2 transition-colors",
            activeSection === item.key
              ? "bg-primary/10 font-medium text-foreground"
              : "text-muted-foreground hover:bg-muted hover:text-foreground",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="grid gap-2 border-t border-border pt-4 text-sm text-muted-foreground">
      <a
        href={`https://github.com/${user}`}
        target="_blank"
        rel="noreferrer"
        class="hover:text-foreground"
      >
        GitHub profile
      </a>
      <a href={`/?q=${encodeURIComponent(user)}`} class="hover:text-foreground">
        Search by owner
      </a>
    </div>
  </CardContent>
</Card>
