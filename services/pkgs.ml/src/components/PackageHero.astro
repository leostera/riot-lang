---
import GitHubAvatar from "@/components/GitHubAvatar.astro";
import { buildPackageFacts, formatDate } from "../lib/package-index.ts";
import type {
  IndexedPackageRelease,
  PackageIndexDocument,
  PackageOverviewDocument,
} from "../lib/types.ts";

interface Props {
  document: PackageIndexDocument;
  release: IndexedPackageRelease;
  selectedVersion: string;
  overview?: PackageOverviewDocument | null;
}

const { document, release, selectedVersion, overview = null } = Astro.props;
const facts = buildPackageFacts(document, release);
const breadcrumbBits = release.canonical_locator.split("/");
const owner = overview?.owner_github_login ?? breadcrumbBits[1] ?? "unknown";
const ownerAvatarUrl = overview?.owner_github_avatar_url;
const packageHref = `/p/${document.name}`;

const installFact = facts.find((fact) => fact.label === "Install");
const tomlFact = facts.find((fact) => fact.label === "riot.toml");
---

<section class="w-full px-4 py-4 sm:px-6 xl:px-8">
  <div class="mx-auto grid w-full max-w-6xl gap-3">
    <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Discover Packages</a>
      <span>&gt;</span>
      <a href={`/u/${owner}`} class="hover:text-foreground">{owner}</a>
      <span>&gt;</span>
      <a href={packageHref} class="hover:text-foreground">{document.name}</a>
      <span>&gt;</span>
      <label class="sr-only" for="package-version-select">Select version</label>
      <select
        id="package-version-select"
        class="min-w-28 rounded-md border border-border bg-background px-2 py-1 text-sm text-foreground outline-none ring-0"
        data-package-name={document.name}
      >
        {
          document.releases.map((candidate) => (
            <option value={candidate.version} selected={candidate.version === selectedVersion}>
              v{candidate.version}
            </option>
          ))
        }
      </select>
    </nav>

    <div class="grid gap-4 rounded-md border border-border bg-card px-4 py-4 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
      <div class="grid min-w-0 gap-3">
        <div class="grid gap-2">
          <div class="flex flex-wrap items-center gap-2">
            <h1 class="text-xl font-semibold tracking-tight text-foreground">{document.name}</h1>
            <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
              v{selectedVersion}
            </span>
          </div>

          <p class="max-w-3xl text-base leading-7 text-muted-foreground">
            {release.description || "A published OCaml package with indexed metadata and source-backed releases."}
          </p>

          <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
            <a href={release.repo_url} target="_blank" rel="noreferrer" class="hover:text-foreground">Repository</a>
            {
              release.homepage ? (
                <a href={release.homepage} target="_blank" rel="noreferrer" class="hover:text-foreground">Homepage</a>
              ) : null
            }
          </div>
        </div>
      </div>

      <aside class="grid gap-3 border-t border-border pt-3 lg:border-l lg:border-t-0 lg:pl-4 lg:pt-0">
        <div class="grid gap-2">
          <div class="text-sm font-medium uppercase tracking-wide text-muted-foreground">
            Install
          </div>
          <div class="grid gap-2">
            <div class="grid gap-1">
              <div class="text-sm text-muted-foreground">{installFact?.label}</div>
              <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                {installFact?.value}
              </code>
            </div>
            <div class="grid gap-1">
              <div class="text-sm text-muted-foreground">{tomlFact?.label}</div>
              <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                {tomlFact?.value}
              </code>
            </div>
          </div>
        </div>

        <dl class="grid gap-y-3 text-sm">
          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Last release</dt>
            <dd class="text-foreground">{formatDate(release.published_at)}</dd>
          </div>

          {
            release.license ? (
              <div class="grid gap-1">
                <dt class="text-sm text-muted-foreground">License</dt>
                <dd class="text-foreground">{release.license}</dd>
              </div>
            ) : null
          }

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Owner</dt>
            <dd>
              <GitHubAvatar
                login={owner}
                avatarUrl={ownerAvatarUrl}
                href={`/u/${owner}`}
                size="sm"
              />
            </dd>
          </div>

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Dependencies</dt>
            <dd class="text-foreground">{overview?.dependency_count ?? release.dependencies.length}</dd>
          </div>

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Dependents</dt>
            <dd class="text-foreground">{overview?.dependent_count ?? 0}</dd>
          </div>

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Installs</dt>
            <dd class="text-foreground">{overview?.download_count ?? 0}</dd>
          </div>

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Published versions</dt>
            <dd class="text-foreground">{overview?.release_count ?? document.releases.length}</dd>
          </div>

          {
            (overview?.categories.length ?? 0) > 0 ? (
              <div class="grid gap-1">
                <dt class="text-sm text-muted-foreground">Categories</dt>
                <dd class="flex flex-wrap gap-1">
                  {overview?.categories.map((category) => (
                    <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-foreground">
                      {category}
                    </span>
                  ))}
                </dd>
              </div>
            ) : null
          }
        </dl>
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  const versionSelect = document.getElementById("package-version-select");

  versionSelect?.addEventListener("change", (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLSelectElement)) {
      return;
    }

    const packageName = target.dataset.packageName;
    const version = target.value;
    if (!packageName || !version) {
      return;
    }

    window.location.href = `/p/${encodeURIComponent(packageName)}/${encodeURIComponent(version)}`;
  });
</script>
