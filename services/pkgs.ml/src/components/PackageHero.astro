---
import GitHubAvatar from "@/components/GitHubAvatar.astro";
import {
  packageExampleLabel,
  packageExamplePlayHref,
  packagePlaygroundHref,
} from "@/lib/package-examples.ts";
import ocaml from "highlight.js/lib/languages/ocaml";
import { common } from "lowlight";
import rehypeHighlight from "rehype-highlight";
import rehypeStringify from "rehype-stringify";
import remarkGfm from "remark-gfm";
import remarkParse from "remark-parse";
import remarkRehype from "remark-rehype";
import { unified } from "unified";
import { buildPackageFacts, formatDate } from "../lib/package-index.ts";
import type {
  IndexedPackageRelease,
  PackageExamplesDocument,
  PackageIndexDocument,
  PackageOverviewDocument,
  PackageReadmeDocument,
} from "../lib/types.ts";

interface Props {
  document: PackageIndexDocument;
  release: IndexedPackageRelease;
  selectedVersion: string;
  overview?: PackageOverviewDocument | null;
  readme?: PackageReadmeDocument | null;
  examples?: PackageExamplesDocument | null;
}

function markOcamlCodeBlocks(node: unknown): void {
  if (!node || typeof node !== "object") {
    return;
  }

  const element = node as {
    type?: string;
    tagName?: string;
    properties?: { className?: string[] | string };
    children?: unknown[];
  };

  if (element.type === "element" && element.tagName === "pre") {
    const codeChild = element.children?.find((child) => {
      if (!child || typeof child !== "object") {
        return false;
      }

      const childElement = child as { type?: string; tagName?: string };
      return childElement.type === "element" && childElement.tagName === "code";
    }) as
      | {
          properties?: { className?: string[] | string };
        }
      | undefined;

    if (codeChild) {
      const classNames = Array.isArray(codeChild.properties?.className)
        ? [...codeChild.properties.className]
        : typeof codeChild.properties?.className === "string"
          ? [codeChild.properties.className]
          : [];

      const hasLanguage = classNames.some((className) => className.startsWith("language-"));
      if (!hasLanguage) {
        codeChild.properties = {
          ...codeChild.properties,
          className: [...classNames, "language-ocaml"],
        };
      }
    }
  }

  for (const child of element.children ?? []) {
    markOcamlCodeBlocks(child);
  }
}

function rehypeDefaultOcaml() {
  return (tree: unknown) => {
    markOcamlCodeBlocks(tree);
  };
}

async function renderReadmeMarkdown(markdown: string): Promise<string> {
  return String(
    await unified()
      .use(remarkParse)
      .use(remarkGfm)
      .use(remarkRehype)
      .use(rehypeDefaultOcaml)
      .use(rehypeHighlight, {
        aliases: {
          ocaml: ["ml"],
        },
        languages: {
          ...common,
          ocaml,
        },
      })
      .use(rehypeStringify)
      .process(markdown),
  );
}

const {
  document,
  release,
  selectedVersion,
  overview = null,
  readme = null,
  examples = null,
} = Astro.props;
const facts = buildPackageFacts(document, release);
const breadcrumbBits = release.canonical_locator.split("/");
const owner = overview?.owner_github_login ?? breadcrumbBits[1] ?? "unknown";
const ownerAvatarUrl = overview?.owner_github_avatar_url;
const packageHref = `/p/${document.name}`;
const docsHref = `https://docs.pkgs.ml/p/${encodeURIComponent(document.name)}/${encodeURIComponent(selectedVersion)}/`;
const playgroundHref = packagePlaygroundHref(document.name, selectedVersion, document.latest);
const readmeHtml = readme?.readme_markdown ? await renderReadmeMarkdown(readme.readme_markdown) : null;
const hasReadme = Boolean(readmeHtml);
const categories = overview?.categories ?? [];
const examplesList = examples?.examples ?? [];
const summaryDescription =
  release.description || "A published OCaml package with indexed metadata and source-backed releases.";

const summaryFacts = [
  {
    label: "Last release",
    value: formatDate(release.published_at),
  },
  ...(release.license
    ? [
        {
          label: "License",
          value: release.license,
        },
      ]
    : []),
  {
    label: "Dependencies",
    value: String(overview?.dependency_count ?? release.dependencies.length),
  },
  {
    label: "Dependents",
    value: String(overview?.dependent_count ?? 0),
  },
  {
    label: "Installs",
    value: String(overview?.download_count ?? 0),
  },
  {
    label: "Published versions",
    value: String(overview?.release_count ?? document.releases.length),
  },
] as const;

const installFact = facts.find((fact) => fact.label === "Install");
const tomlFact = facts.find((fact) => fact.label === "riot.toml");
const readmeProseClass =
  "readme-prose min-w-0 w-full max-w-none break-words px-2 py-2 text-base leading-8 text-foreground sm:px-4 lg:px-5 " +
  "[&_a]:text-primary [&_a]:underline [&_a]:decoration-primary/40 [&_a]:underline-offset-4 " +
  "[&_a]:break-all " +
  "[&_blockquote]:my-5 [&_blockquote]:border-l-2 [&_blockquote]:border-border [&_blockquote]:pl-4 [&_blockquote]:text-muted-foreground " +
  "[&_code]:break-words [&_code]:rounded-sm [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.95em] " +
  "[&_h1]:mb-6 [&_h1]:mt-2 [&_h1]:font-heading [&_h1]:text-2xl [&_h1]:font-medium [&_h1]:leading-tight [&_h1]:tracking-tight " +
  "[&_h2]:mb-4 [&_h2]:mt-10 [&_h2]:font-heading [&_h2]:text-xl [&_h2]:font-medium [&_h2]:leading-tight [&_h2]:tracking-tight " +
  "[&_h3]:mb-3 [&_h3]:mt-8 [&_h3]:font-heading [&_h3]:text-lg [&_h3]:font-medium [&_h3]:leading-tight " +
  "[&_hr]:my-8 [&_hr]:border-border " +
  "[&_img]:h-auto [&_img]:max-w-full " +
  "[&_li]:my-1.5 " +
  "[&_ol]:my-4 [&_ol]:pl-5 [&_ol]:list-decimal " +
  "[&_p]:my-4 " +
  "[&_pre]:my-5 [&_pre]:max-w-full [&_pre]:overflow-x-auto [&_pre]:rounded-md [&_pre]:border [&_pre]:border-border [&_pre]:bg-muted [&_pre]:px-3 [&_pre]:py-3 [&_pre]:text-sm " +
  "[&_pre_code]:bg-transparent [&_pre_code]:p-0 " +
  "[&_table]:my-5 [&_table]:block [&_table]:max-w-full [&_table]:overflow-x-auto [&_table]:border-collapse [&_table]:text-sm " +
  "[&_td]:border-b [&_td]:border-border/70 [&_td]:px-3 [&_td]:py-2 " +
  "[&_th]:border-b [&_th]:border-border [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_th]:font-medium " +
  "[&_ul]:my-4 [&_ul]:pl-5 [&_ul]:list-disc";
---

<section class="w-full px-4 py-4 sm:px-6 xl:px-8">
  <div class="mx-auto grid w-full max-w-6xl gap-3">
    <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Discover Packages</a>
      <span>&gt;</span>
      <a href={`/u/${owner}`} class="hover:text-foreground">{owner}</a>
      <span>&gt;</span>
      <a href={packageHref} class="hover:text-foreground">{document.name}</a>
      <span>&gt;</span>
      <label class="sr-only" for="package-version-select">Select version</label>
      <select
        id="package-version-select"
        class="min-w-28 rounded-md border border-border bg-background px-2 py-1 text-sm text-foreground outline-none ring-0"
        data-package-name={document.name}
      >
        {
          document.releases.map((candidate) => (
            <option value={candidate.version} selected={candidate.version === selectedVersion}>
              v{candidate.version}
            </option>
          ))
        }
      </select>
    </nav>

    <div class="grid gap-4 rounded-md border border-border bg-card px-4 py-4 lg:flex lg:items-start lg:gap-4">
      {
        hasReadme ? (
          <div class="grid gap-4 lg:hidden">
            <div class="grid gap-3 border-b border-border pb-4">
              <div class="grid gap-2">
                <div class="flex flex-wrap items-center gap-2">
                  <h1 class="text-xl font-semibold tracking-tight text-foreground">{document.name}</h1>
                  <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                    v{selectedVersion}
                  </span>
                </div>

                <p class="text-base leading-7 text-muted-foreground">
                  {summaryDescription}
                </p>
              </div>

              <div class="grid gap-1 text-sm text-muted-foreground">
                <a href={release.repo_url} target="_blank" rel="noreferrer" class="hover:text-foreground">Repository</a>
                <a href={docsHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open docs</a>
                <a href={playgroundHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open in playground</a>
                {
                  release.homepage ? (
                    <a href={release.homepage} target="_blank" rel="noreferrer" class="hover:text-foreground">Homepage</a>
                  ) : null
                }
              </div>

              <div class="grid gap-2">
                <div class="text-sm font-medium uppercase tracking-wide text-muted-foreground">
                  Install
                </div>
                <div class="grid gap-2">
                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">{installFact?.label}</div>
                    <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                      {installFact?.value}
                    </code>
                  </div>
                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">{tomlFact?.label}</div>
                    <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                      {tomlFact?.value}
                    </code>
                  </div>
                </div>
              </div>

              <dl class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm">
                {summaryFacts.map((fact) => (
                  <div class="grid gap-1">
                    <dt class="text-sm text-muted-foreground">{fact.label}</dt>
                    <dd class="text-foreground">{fact.value}</dd>
                  </div>
                ))}

                <div class="grid gap-1">
                  <dt class="text-sm text-muted-foreground">Owner</dt>
                  <dd>
                    <GitHubAvatar
                      login={owner}
                      avatarUrl={ownerAvatarUrl}
                      href={`/u/${owner}`}
                      size="sm"
                    />
                  </dd>
                </div>
              </dl>

              {
                categories.length > 0 ? (
                  <div class="grid gap-1">
                    <div class="text-sm text-muted-foreground">Categories</div>
                    <div class="flex flex-wrap gap-1">
                      {categories.map((category) => (
                        <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-foreground">
                          {category}
                        </span>
                      ))}
                    </div>
                  </div>
                ) : null
              }

              {
                examplesList.length > 0 ? (
                  <details class="rounded-sm border border-border bg-muted/40 p-3">
                    <summary class="cursor-pointer text-sm font-medium text-foreground">
                      Examples ({examplesList.length})
                    </summary>
                    <div class="mt-3 grid gap-1">
                      {examplesList.map((example) => (
                        <a
                          href={packageExamplePlayHref(document.name, selectedVersion, example.path)}
                          class="text-sm text-primary hover:text-foreground"
                        >
                          {packageExampleLabel(example.path)}
                        </a>
                      ))}
                    </div>
                  </details>
                ) : null
              }
            </div>
          </div>
        ) : null
      }

      <div class="grid min-w-0 gap-4 lg:min-w-0 lg:flex-1">
        {
          hasReadme ? (
            <div class="grid min-w-0 gap-3">
              <details class="group min-w-0 overflow-hidden rounded-sm border border-border bg-background/40 md:hidden">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-3 border-b border-border px-4 py-3 text-sm font-medium text-foreground marker:hidden">
                  <span>README</span>
                  <span class="text-xs text-muted-foreground group-open:hidden">Expand</span>
                  <span class="hidden text-xs text-muted-foreground group-open:inline">Collapse</span>
                </summary>

                <div class="min-w-0 max-w-full overflow-hidden">
                  <div
                  class={readmeProseClass}
                  set:html={readmeHtml}
                  />
                </div>
              </details>

              <div class="hidden min-w-0 overflow-hidden rounded-sm border border-border bg-background/40 md:block">
                <div class="border-b border-border px-4 py-3 text-sm font-medium text-foreground">
                  README
                </div>
                <div class="min-w-0 max-w-full overflow-hidden">
                  <div class={readmeProseClass} set:html={readmeHtml} />
                </div>
              </div>
            </div>
          ) : (
            <div class="grid gap-2">
              <div class="flex flex-wrap items-center gap-2">
                <h1 class="text-xl font-semibold tracking-tight text-foreground">{document.name}</h1>
                <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                  v{selectedVersion}
                </span>
              </div>

              <p class="max-w-3xl text-base leading-7 text-muted-foreground">
                {summaryDescription}
              </p>

              <div class="grid gap-1 text-sm text-muted-foreground">
                <a href={release.repo_url} target="_blank" rel="noreferrer" class="hover:text-foreground">Repository</a>
                <a href={docsHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open docs</a>
                <a href={playgroundHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open in playground</a>
                {
                  release.homepage ? (
                    <a href={release.homepage} target="_blank" rel="noreferrer" class="hover:text-foreground">Homepage</a>
                  ) : null
                }
              </div>
            </div>
          )
        }
      </div>

      <aside class:list={[
        "grid gap-3 border-t border-border pt-3 lg:w-[360px] lg:flex-none lg:border-l lg:border-t-0 lg:pl-4 lg:pt-0",
        hasReadme ? "hidden lg:grid" : "",
      ]}>
        {
          hasReadme ? (
            <div class="grid gap-3 border-b border-border pb-3">
              <div class="grid gap-2">
                <div class="flex flex-wrap items-center gap-2">
                  <h1 class="text-xl font-semibold tracking-tight text-foreground">{document.name}</h1>
                  <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                    v{selectedVersion}
                  </span>
                </div>

                <p class="text-base leading-7 text-muted-foreground">
                  {summaryDescription}
                </p>
              </div>

              <div class="grid gap-1 text-sm text-muted-foreground">
                <a href={release.repo_url} target="_blank" rel="noreferrer" class="hover:text-foreground">Repository</a>
                <a href={docsHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open docs</a>
                <a href={playgroundHref} target="_blank" rel="noreferrer" class="hover:text-foreground">Open in playground</a>
                {
                  release.homepage ? (
                    <a href={release.homepage} target="_blank" rel="noreferrer" class="hover:text-foreground">Homepage</a>
                  ) : null
                }
              </div>
            </div>
          ) : null
        }

        <div class="grid gap-2">
          <div class="text-sm font-medium uppercase tracking-wide text-muted-foreground">
            Install
          </div>
          <div class="grid gap-2">
            <div class="grid gap-1">
              <div class="text-sm text-muted-foreground">{installFact?.label}</div>
              <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                {installFact?.value}
              </code>
            </div>
            <div class="grid gap-1">
              <div class="text-sm text-muted-foreground">{tomlFact?.label}</div>
              <code class="overflow-x-auto rounded-sm border border-border bg-muted px-2 py-1 text-sm text-foreground">
                {tomlFact?.value}
              </code>
            </div>
          </div>
        </div>

        <dl class="grid gap-y-3 text-sm">
          {summaryFacts.map((fact) => (
            <div class="grid gap-1">
              <dt class="text-sm text-muted-foreground">{fact.label}</dt>
              <dd class="text-foreground">{fact.value}</dd>
            </div>
          ))}

          <div class="grid gap-1">
            <dt class="text-sm text-muted-foreground">Owner</dt>
            <dd>
              <GitHubAvatar
                login={owner}
                avatarUrl={ownerAvatarUrl}
                href={`/u/${owner}`}
                size="sm"
              />
            </dd>
          </div>

          {
            categories.length > 0 ? (
              <div class="grid gap-1">
                <dt class="text-sm text-muted-foreground">Categories</dt>
                <dd class="flex flex-wrap gap-1">
                  {categories.map((category) => (
                    <span class="rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[10px] text-foreground">
                      {category}
                    </span>
                  ))}
                </dd>
              </div>
            ) : null
          }

          {
            examplesList.length > 0 ? (
              <div class="grid gap-1">
                <dt class="text-sm text-muted-foreground">Examples</dt>
                <dd class="grid gap-1">
                  {examplesList.map((example) => (
                    <a
                      href={packageExamplePlayHref(document.name, selectedVersion, example.path)}
                      class="text-sm text-primary hover:text-foreground"
                    >
                      {packageExampleLabel(example.path)}
                    </a>
                  ))}
                </dd>
              </div>
            ) : null
          }
        </dl>
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  const versionSelect = document.getElementById("package-version-select");

  versionSelect?.addEventListener("change", (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLSelectElement)) {
      return;
    }

    const packageName = target.dataset.packageName;
    const version = target.value;
    if (!packageName || !version) {
      return;
    }

    window.location.href = `/p/${encodeURIComponent(packageName)}/${encodeURIComponent(version)}`;
  });
</script>
