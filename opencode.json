{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://starbase1.local:1234/v1",
      },
      "models": {
        "mistralai/devstral-small-2507": { "name": "Devstral Small (MLX)" },
      }
    },
    "exo-local": {
      "name": "Exo (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://starbase1.local:52415/v1",
      },
      "models": {
        "qwen2.5-coder-1.5b": { "name": "Qwen 2.5 Coder (1.5b)" },
      }
    },
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "gemma3:27b": { "name": "Gemma 3 (27b)" },
        "gpt-oss:120b": { "name": "GPT OSS (120b)" },
        "gpt-oss:20b": { "name": "GPT OSS (20b)" },
        "deepseek-r1:8b": { "name": "DeepSeek R1 (8b)" },
        "qwen3-coder:30b": { "name": "Qwen 3 Coder (30b)" },
        "StarCoder2:latest": { "name": "StarCoder 2 (latest)" },
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "tusk*": "allow",
      "git*": "deny",
      "git add*": "deny",
      "git commit *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rm -rf*": "ask",
    },
  },
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/sse"],
      "enabled": false
    }
  }
}
