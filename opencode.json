{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git*": "deny",
      "git add -A": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git commit -m *": "allow",
      "*": "ask",
      "rg*": "allow",
      "tusk clean": "deny",
      "tusk*": "allow",
      "./target/debug/tusk*": "deny",
      "*minitusk*": "deny",
    },
  },
  "mcp": {
    "linear": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ]
    }
  }
}
