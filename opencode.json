{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git*": "deny",
      "*": "ask",
    },
  },
  "mcp": {
    "tusk": {
      "type": "local",
      "command": ["./tusk", "mcp"],
    },
    "linear": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
