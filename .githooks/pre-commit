#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_ocaml_files=()
while IFS= read -r -d '' path; do
  case "$path" in
    *.ml | *.mli)
      staged_ocaml_files+=("$path")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if ((${#staged_ocaml_files[@]} > 0)); then
  riot fmt "${staged_ocaml_files[@]}"
  git add -- "${staged_ocaml_files[@]}"
fi

# riot fix --check
riot build
riot test --small
