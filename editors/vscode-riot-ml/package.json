{
  "name": "riot-ml",
  "displayName": "Riot ML",
  "description": "VS Code integration for Riot",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Formatters",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:riot-ocaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "riot-ocaml",
        "aliases": [
          "Riot OCaml",
          "OCaml"
        ],
        "extensions": [
          ".ml",
          ".mli"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "riot-ocaml",
        "scopeName": "source.ocaml.riot",
        "path": "./syntaxes/riot-ocaml.tmLanguage.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "riot_info_workspace",
        "displayName": "Riot Workspace Info",
        "toolReferenceName": "riotWorkspace",
        "modelDescription": "Resolve the canonical Riot workspace or package for the current VS Code context or an absolute path, including workspace root and packages.",
        "userDescription": "Inspect Riot workspace information",
        "canBeReferencedInPrompt": true,
        "when": "inRiotProject",
        "tags": [
          "riot",
          "workspace",
          "project"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Optional absolute file or directory path inside a Riot workspace."
            }
          }
        }
      },
      {
        "name": "riot_build",
        "displayName": "Riot Build",
        "toolReferenceName": "riotBuild",
        "modelDescription": "Run `riot build` for the current Riot package or workspace and return the result.",
        "userDescription": "Build a Riot package or workspace",
        "canBeReferencedInPrompt": true,
        "when": "inRiotProject",
        "tags": [
          "riot",
          "build"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Optional absolute file or directory path used to resolve the Riot target."
            },
            "scope": {
              "type": "string",
              "enum": [
                "workspace",
                "package"
              ],
              "description": "Whether to run `riot build` for the workspace or the nearest package."
            }
          }
        }
      },
      {
        "name": "riot_check",
        "displayName": "Riot Check",
        "toolReferenceName": "riotCheck",
        "modelDescription": "Run `riot check` for the current Riot package or workspace and return the result.",
        "userDescription": "Check a Riot package or workspace",
        "canBeReferencedInPrompt": true,
        "when": "inRiotProject",
        "tags": [
          "riot",
          "check",
          "typecheck"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Optional absolute file or directory path used to resolve the Riot target."
            },
            "scope": {
              "type": "string",
              "enum": [
                "workspace",
                "package"
              ],
              "description": "Whether to run `riot check` for the workspace or the nearest package."
            }
          }
        }
      },
      {
        "name": "riot_list_runnables",
        "displayName": "Riot List Runnables",
        "toolReferenceName": "riotRunnables",
        "modelDescription": "List Riot runnables, including binaries and examples, in the current workspace.",
        "userDescription": "List Riot binaries and examples",
        "canBeReferencedInPrompt": true,
        "when": "inRiotProject",
        "tags": [
          "riot",
          "run",
          "binary",
          "example"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Optional absolute file or directory path used to resolve the Riot workspace."
            },
            "kind": {
              "type": "string",
              "enum": [
                "all",
                "binary",
                "example"
              ],
              "description": "Filter to all runnables, only binaries, or only examples."
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of runnables to return."
            }
          }
        }
      },
      {
        "name": "riot_run_runnable",
        "displayName": "Riot Run Runnable",
        "toolReferenceName": "riotRun",
        "modelDescription": "Launch a Riot runnable selector in a VS Code terminal.",
        "userDescription": "Run a Riot binary or example",
        "canBeReferencedInPrompt": true,
        "when": "inRiotProject",
        "tags": [
          "riot",
          "run",
          "terminal"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "selector"
          ],
          "properties": {
            "path": {
              "type": "string",
              "description": "Optional absolute file or directory path used to resolve the Riot workspace."
            },
            "selector": {
              "type": "string",
              "description": "Runnable selector like `riot-cli:riot` or `suri:liveview_counter`."
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "riot.install",
        "title": "Riot: Install Riot"
      },
      {
        "command": "riot.startLanguageServer",
        "title": "Riot: Start Language Server"
      },
      {
        "command": "riot.stopLanguageServer",
        "title": "Riot: Stop Language Server"
      },
      {
        "command": "riot.restartLanguageServer",
        "title": "Riot: Restart Language Server"
      },
      {
        "command": "riot.showLanguageServerOutput",
        "title": "Riot: Show Riot LSP Output"
      },
      {
        "command": "riot.showExtensionOutput",
        "title": "Riot: Show Riot Extension Output"
      },
      {
        "command": "riot.showCommandOutput",
        "title": "Riot: Show Riot Command Output"
      },
      {
        "command": "riot.buildWorkspace",
        "title": "Riot: Build Workspace"
      },
      {
        "command": "riot.testWorkspace",
        "title": "Riot: Test Workspace"
      },
      {
        "command": "riot.checkWorkspace",
        "title": "Riot: Run Check"
      },
      {
        "command": "riot.run",
        "title": "Riot: Run"
      },
      {
        "command": "riot.runBinary",
        "title": "Riot: Run Binary"
      },
      {
        "command": "riot.runExample",
        "title": "Riot: Run Example"
      },
      {
        "command": "riot.formatDocument",
        "title": "Riot: Format Current Document"
      },
      {
        "command": "riot.refreshDiagnostics",
        "title": "Riot: Refresh Diagnostics"
      },
      {
        "command": "riot.addPackage",
        "title": "Riot: Add Package"
      },
      {
        "command": "riot.removePackage",
        "title": "Riot: Remove Package"
      },
      {
        "command": "riot.bench.refresh",
        "title": "Riot: Refresh Benchmarks"
      },
      {
        "command": "riot.bench.run",
        "title": "Riot: Run Benchmark"
      },
      {
        "command": "riot.bench.stop",
        "title": "Riot: Stop Benchmark"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "riot",
          "title": "Riot",
          "icon": "media/riot.svg"
        }
      ],
      "panel": [
        {
          "id": "riotBenchmarkResultsPanel",
          "title": "Riot Benchmark Results",
          "icon": "media/riot.svg"
        }
      ]
    },
    "views": {
      "riot": [
        {
          "id": "riotBenchmarks",
          "name": "Benchmarks"
        }
      ],
      "riotBenchmarkResultsPanel": [
        {
          "type": "webview",
          "id": "riotBenchmarkResults",
          "name": "Results"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "riot.startLanguageServer",
          "when": "inRiotProject && !riotLspRunning"
        },
        {
          "command": "riot.stopLanguageServer",
          "when": "inRiotProject && (riotLspRunning || riotCliFallbackActive)"
        },
        {
          "command": "riot.restartLanguageServer",
          "when": "inRiotProject"
        },
        {
          "command": "riot.showLanguageServerOutput",
          "when": "inRiotProject"
        },
        {
          "command": "riot.showExtensionOutput",
          "when": "inRiotProject"
        },
        {
          "command": "riot.showCommandOutput",
          "when": "inRiotProject"
        },
        {
          "command": "riot.buildWorkspace",
          "when": "inRiotProject"
        },
        {
          "command": "riot.testWorkspace",
          "when": "inRiotProject"
        },
        {
          "command": "riot.checkWorkspace",
          "when": "inRiotProject"
        },
        {
          "command": "riot.run",
          "when": "inRiotProject"
        },
        {
          "command": "riot.runBinary",
          "when": "inRiotProject"
        },
        {
          "command": "riot.runExample",
          "when": "inRiotProject"
        },
        {
          "command": "riot.formatDocument",
          "when": "inRiotProject"
        },
        {
          "command": "riot.refreshDiagnostics",
          "when": "inRiotProject"
        },
        {
          "command": "riot.addPackage",
          "when": "inRiotProject"
        },
        {
          "command": "riot.removePackage",
          "when": "inRiotProject"
        }
      ],
      "view/title": [
        {
          "command": "riot.bench.refresh",
          "when": "view == riotBenchmarks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "riot.bench.run",
          "when": "view == riotBenchmarks && viewItem == riotBenchmarks.idle",
          "group": "inline"
        },
        {
          "command": "riot.bench.stop",
          "when": "view == riotBenchmarks && viewItem == riotBenchmarks.running",
          "group": "inline"
        }
      ]
    },
    "taskDefinitions": [
      {
        "type": "riot",
        "required": [
          "command",
          "cwd"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "build",
              "test",
              "check"
            ]
          },
          "cwd": {
            "type": "string"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "label": {
            "type": "string"
          }
        }
      }
    ],
    "configuration": {
      "title": "Riot",
      "properties": {
        "riot.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the Riot executable. Leave empty to use the extension-managed Riot binary or `riot` from `PATH`."
        },
        "riot.installUrl": {
          "type": "string",
          "default": "https://get.riot.ml",
          "markdownDescription": "Installer URL used by `Riot: Install Riot`."
        },
        "riot.latestMetadataUrl": {
          "type": "string",
          "default": "https://api.pkgs.ml/v1/riot/latest.json",
          "markdownDescription": "Release metadata URL used for startup version and upgrade checks."
        },
        "riot.formatOnSave": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Format `*.ml` and `*.mli` files with Riot before saving them."
        },
        "riot.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show Riot parser and lint diagnostics in the editor."
        },
        "riot.diagnostics.runFix": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include `riot-fix` lint diagnostics when Riot diagnostics are available."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch": "bunx npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "keywords": [
    "riot",
    "ocaml",
    "formatter",
    "linter"
  ],
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
