{
  "name": "Riot OCaml",
  "scopeName": "source.ocaml.riot",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#modules"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.ocaml",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ocaml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ocaml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.ocaml",
          "match": "'(?:\\\\.|[^'])+'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ocaml",
          "match": "\\b\\d+(?:[._]\\d+)*(?:\\.(?:\\d+|\\d+[._]\\d+))?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ocaml",
          "match": "\\b(?:and|as|assert|begin|class|constraint|do|done|downto|else|end|exception|external|for|fun|function|functor|if|in|include|inherit|initializer|lazy|let|match|method|module|mutable|new|nonrec|object|of|open|private|rec|sig|struct|then|to|try|type|val|virtual|when|while|with)\\b"
        },
        {
          "name": "constant.language.ocaml",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ocaml",
          "match": "\\b(?:int|float|string|char|bool|unit|list|array|option|result|bytes)\\b"
        },
        {
          "name": "entity.name.type.ocaml",
          "match": "\\b[A-Z][A-Za-z0-9_']*\\b"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "support.class.module.ocaml",
          "match": "\\b[A-Z][A-Za-z0-9_']*(?=\\.)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ocaml",
          "match": "->|<-|:=|\\|>|\\|\\||&&|::|\\+\\.|-\\.|\\*\\.|/\\.|=|<>|<=|>=|<|>|\\+|-|\\*|/"
        }
      ]
    }
  }
}
