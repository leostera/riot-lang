# LLDB Configuration for RAML Runtime
#
# This file configures LLDB to show OCaml values in human-readable format.
# Place this in your project root or add to ~/.lldbinit

# =============================================================================
# Custom Type Formatters for OCaml Values
# =============================================================================

# Format Value type
type summary add --summary-string "Value(${var.0#x})" "raml_rt::value::Value"
type summary add --python-script "value_formatter" "raml_rt::value::Value"

# Format Block type
type summary add --summary-string "Block(tag=${var.header.tag}, size=${var.header.size})" "raml_rt::value::Block"

# =============================================================================
# Custom Commands
# =============================================================================

# pval - Print OCaml value in human-readable format
command script add -f lldb_raml.pval pval

# pheap - Print heap statistics
command script add -f lldb_raml.pheap pheap

# pstack - Print interpreter stack
command script add -f lldb_raml.pstack pstack

# pblock - Print block contents
command script add -f lldb_raml.pblock pblock

# =============================================================================
# Python Helpers
# =============================================================================

command script import lldb_raml.py

script
import lldb

def value_formatter(value, internal_dict):
    """Format an OCaml Value for display in LLDB"""
    raw = value.GetChildMemberWithName('0').GetValueAsUnsigned()
    
    # Check if it's an integer (LSB = 1)
    if raw & 1:
        int_val = raw >> 1
        # Handle as signed integer
        if int_val >= (1 << 62):
            int_val -= (1 << 63)
        return f"Int({int_val})"
    
    # Check if it's null
    if raw == 0:
        return "Null"
    
    # It's a block pointer
    return f"Block({raw:#x})"

# Command: pval <expr>
# Print an OCaml value in human-readable format
def pval(debugger, command, result, internal_dict):
    """Print OCaml value: pval <expression>"""
    target = debugger.GetSelectedTarget()
    process = target.GetProcess()
    thread = process.GetSelectedThread()
    frame = thread.GetSelectedFrame()
    
    # Evaluate the expression
    value = frame.EvaluateExpression(command)
    if not value.IsValid():
        result.AppendMessage(f"Error: Could not evaluate '{command}'")
        return
    
    # Get raw value
    raw = value.GetChildMemberWithName('0')
    if not raw.IsValid():
        result.AppendMessage(f"Error: Not a Value type")
        return
    
    raw_val = raw.GetValueAsUnsigned()
    
    # Format based on type
    if raw_val & 1:  # Integer
        int_val = raw_val >> 1
        if int_val >= (1 << 62):
            int_val -= (1 << 63)
        result.AppendMessage(f"Int({int_val})")
    elif raw_val == 0:
        result.AppendMessage("Null")
    else:  # Block
        # Try to read block header
        error = lldb.SBError()
        header_addr = raw_val
        header = process.ReadUnsignedFromMemory(header_addr, 8, error)
        
        if error.Success():
            tag = header & 0xFF
            color = (header >> 8) & 0x3
            size = (header >> 10) & 0x3FFFFF
            
            result.AppendMessage(f"Block(addr={raw_val:#x}, tag={tag}, size={size}, color={color})")
            
            # Print fields
            for i in range(min(size, 10)):  # Limit to 10 fields
                field_addr = header_addr + 8 + (i * 8)
                field_val = process.ReadUnsignedFromMemory(field_addr, 8, error)
                if error.Success():
                    if field_val & 1:
                        int_val = field_val >> 1
                        result.AppendMessage(f"  [{i}] = Int({int_val})")
                    else:
                        result.AppendMessage(f"  [{i}] = Block({field_val:#x})")
        else:
            result.AppendMessage(f"Block({raw_val:#x}) [could not read header]")

# Command: pheap
# Print heap statistics
def pheap(debugger, command, result, internal_dict):
    """Print heap statistics"""
    result.AppendMessage("Heap Statistics:")
    result.AppendMessage("  (Not yet implemented)")

# Command: pstack
# Print interpreter stack
def pstack(debugger, command, result, internal_dict):
    """Print interpreter stack"""
    target = debugger.GetSelectedTarget()
    process = target.GetProcess()
    thread = process.GetSelectedThread()
    frame = thread.GetSelectedFrame()
    
    # Try to find interpreter in current scope
    interp = frame.FindVariable("self")
    if not interp.IsValid():
        result.AppendMessage("Error: No interpreter in current scope")
        return
    
    stack = interp.GetChildMemberWithName("stack")
    if not stack.IsValid():
        result.AppendMessage("Error: Could not find stack")
        return
    
    stack_len = stack.GetNumChildren()
    result.AppendMessage(f"Stack (depth={stack_len}):")
    
    for i in range(min(stack_len, 20)):  # Limit to 20 entries
        val = stack.GetChildAtIndex(i)
        raw = val.GetChildMemberWithName('0').GetValueAsUnsigned()
        
        if raw & 1:
            int_val = raw >> 1
            result.AppendMessage(f"  [{i}] Int({int_val})")
        else:
            result.AppendMessage(f"  [{i}] Block({raw:#x})")

# Command: pblock <addr>
# Print block contents
def pblock(debugger, command, result, internal_dict):
    """Print block contents: pblock <address>"""
    target = debugger.GetSelectedTarget()
    process = target.GetProcess()
    
    try:
        addr = int(command, 0)
    except:
        result.AppendMessage(f"Error: Invalid address '{command}'")
        return
    
    error = lldb.SBError()
    header = process.ReadUnsignedFromMemory(addr, 8, error)
    
    if not error.Success():
        result.AppendMessage(f"Error: Could not read memory at {addr:#x}")
        return
    
    tag = header & 0xFF
    color = (header >> 8) & 0x3
    size = (header >> 10) & 0x3FFFFF
    
    result.AppendMessage(f"Block at {addr:#x}:")
    result.AppendMessage(f"  tag:   {tag}")
    result.AppendMessage(f"  size:  {size}")
    result.AppendMessage(f"  color: {color}")
    result.AppendMessage(f"  fields:")
    
    for i in range(min(size, 20)):
        field_addr = addr + 8 + (i * 8)
        field_val = process.ReadUnsignedFromMemory(field_addr, 8, error)
        if error.Success():
            if field_val & 1:
                int_val = field_val >> 1
                result.AppendMessage(f"    [{i}] = Int({int_val})")
            else:
                result.AppendMessage(f"    [{i}] = Block({field_val:#x})")

end

# =============================================================================
# Auto-load settings
# =============================================================================

settings set target.process.follow-fork-mode child
settings set target.process.stop-on-sharedlibrary-events false

# Print message on load
script print("RAML LLDB extensions loaded. Commands: pval, pheap, pstack, pblock")
