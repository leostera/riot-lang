<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAML-RT: OCaml Bytecode in Browser</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        
        header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        header p {
            opacity: 0.9;
            font-size: 1.1em;
        }
        
        main {
            padding: 30px;
        }
        
        .section {
            margin-bottom: 30px;
        }
        
        .section h2 {
            color: #333;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
        }
        
        .upload-area {
            border: 3px dashed #667eea;
            border-radius: 8px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background: #f8f9ff;
        }
        
        .upload-area:hover {
            background: #eef0ff;
            border-color: #764ba2;
        }
        
        .upload-area.dragover {
            background: #e0e7ff;
            border-color: #667eea;
            transform: scale(1.02);
        }
        
        .upload-icon {
            font-size: 4em;
            margin-bottom: 20px;
        }
        
        input[type="file"] {
            display: none;
        }
        
        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 6px;
            font-size: 1em;
            cursor: pointer;
            transition: transform 0.2s;
            margin: 5px;
        }
        
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        
        .output {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 20px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
            min-height: 200px;
            max-height: 400px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        
        .output.success {
            border-left: 4px solid #4caf50;
        }
        
        .output.error {
            border-left: 4px solid #f44336;
        }
        
        .file-info {
            background: #f5f5f5;
            padding: 15px;
            border-radius: 6px;
            margin: 15px 0;
        }
        
        .file-info strong {
            color: #667eea;
        }
        
        .examples {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        
        .example-card {
            background: #f8f9ff;
            border: 2px solid #e0e7ff;
            border-radius: 8px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .example-card:hover {
            border-color: #667eea;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.2);
        }
        
        .example-card h3 {
            color: #667eea;
            margin-bottom: 10px;
            font-size: 1.1em;
        }
        
        .example-card code {
            display: block;
            background: white;
            padding: 10px;
            border-radius: 4px;
            font-size: 0.85em;
            color: #333;
        }
        
        .status {
            padding: 10px 15px;
            border-radius: 6px;
            margin: 10px 0;
            font-weight: 500;
        }
        
        .status.loading {
            background: #fff3cd;
            color: #856404;
        }
        
        .status.success {
            background: #d4edda;
            color: #155724;
        }
        
        .status.error {
            background: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🦀 RAML-RT</h1>
            <p>Run OCaml Bytecode in Your Browser</p>
        </header>
        
        <main>
            <!-- File Upload Section -->
            <div class="section">
                <h2>📁 Upload OCaml Bytecode</h2>
                <div class="upload-area" id="uploadArea">
                    <div class="upload-icon">📦</div>
                    <p><strong>Drop .cmo or .out file here</strong></p>
                    <p style="margin-top: 10px; opacity: 0.7;">or click to browse</p>
                    <input type="file" id="fileInput" accept=".cmo,.out">
                </div>
                <div id="fileInfo"></div>
            </div>
            
            <!-- Quick Examples -->
            <div class="section">
                <h2>⚡ Quick Examples</h2>
                <div class="examples">
                    <div class="example-card" onclick="runExample('hello')">
                        <h3>Hello World</h3>
                        <code>print_int 42</code>
                    </div>
                    <div class="example-card" onclick="runExample('math')">
                        <h3>Math</h3>
                        <code>10 + 20 + 12</code>
                    </div>
                    <div class="example-card" onclick="runExample('stack')">
                        <h3>Stack Ops</h3>
                        <code>push/pop demo</code>
                    </div>
                </div>
            </div>
            
            <!-- Control Panel -->
            <div class="section">
                <h2>🎮 Control Panel</h2>
                <button id="loadBtn" disabled>Load Bytecode</button>
                <button id="runBtn" disabled>Run</button>
                <button id="clearBtn">Clear Output</button>
            </div>
            
            <!-- Status -->
            <div id="status"></div>
            
            <!-- Output -->
            <div class="section">
                <h2>📤 Output</h2>
                <div class="output" id="output">Waiting for bytecode...</div>
            </div>
        </main>
    </div>

    <script type="module">
        import init, { WasmRuntime } from './pkg/raml_rt.js';
        
        let runtime = null;
        let currentFile = null;
        let wasmLoaded = false;
        
        // Elements
        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('fileInfo');
        const loadBtn = document.getElementById('loadBtn');
        const runBtn = document.getElementById('runBtn');
        const clearBtn = document.getElementById('clearBtn');
        const output = document.getElementById('output');
        const statusDiv = document.getElementById('status');
        
        // Logging
        function log(msg, type = 'info') {
            const timestamp = new Date().toLocaleTimeString();
            const prefix = type === 'error' ? '❌' : type === 'success' ? '✅' : 'ℹ️';
            output.textContent += `[${timestamp}] ${prefix} ${msg}\n`;
            output.scrollTop = output.scrollHeight;
            
            if (type === 'error') {
                output.className = 'output error';
            } else if (type === 'success') {
                output.className = 'output success';
            }
        }
        
        function setStatus(msg, type = 'loading') {
            statusDiv.innerHTML = `<div class="status ${type}">${msg}</div>`;
        }
        
        function clearStatus() {
            statusDiv.innerHTML = '';
        }
        
        // Initialize WASM
        async function initWasm() {
            try {
                setStatus('Loading WASM runtime...', 'loading');
                await init();
                runtime = Runtime.new();
                wasmLoaded = true;
                log('WASM runtime initialized!', 'success');
                clearStatus();
            } catch (e) {
                log(`Failed to load WASM: ${e}`, 'error');
                setStatus('Failed to load WASM runtime', 'error');
            }
        }
        
        // File Upload Handling
        uploadArea.onclick = () => fileInput.click();
        
        fileInput.onchange = (e) => {
            const file = e.target.files[0];
            if (file) handleFile(file);
        };
        
        uploadArea.ondragover = (e) => {
            e.preventDefault();
            uploadArea.classList.add('dragover');
        };
        
        uploadArea.ondragleave = () => {
            uploadArea.classList.remove('dragover');
        };
        
        uploadArea.ondrop = (e) => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file) handleFile(file);
        };
        
        async function handleFile(file) {
            currentFile = file;
            const bytes = await file.arrayBuffer();
            const uint8 = new Uint8Array(bytes);
            
            // Display file info
            fileInfo.innerHTML = `
                <div class="file-info">
                    <strong>File:</strong> ${file.name}<br>
                    <strong>Size:</strong> ${bytes.byteLength} bytes<br>
                    <strong>Type:</strong> ${file.name.endsWith('.cmo') ? '.cmo (object file)' : '.out (executable)'}
                </div>
            `;
            
            log(`Loaded file: ${file.name} (${bytes.byteLength} bytes)`);
            loadBtn.disabled = false;
        }
        
        // Load Bytecode
        loadBtn.onclick = async () => {
            if (!currentFile) return;
            
            try {
                setStatus('Loading bytecode...', 'loading');
                const bytes = await currentFile.arrayBuffer();
                const uint8 = new Uint8Array(bytes);
                
                if (currentFile.name.endsWith('.cmo')) {
                    log('Loading .cmo file...');
                    runtime.load_cmo_file(uint8);
                } else {
                    log('Loading executable file...');
                    runtime.load_executable(uint8);
                }
                
                log(`✓ Bytecode loaded successfully!`, 'success');
                log(`  Instructions: ${runtime.code_size()}`);
                log(`  Primitives: ${runtime.primitive_count()}`);
                
                setStatus('Bytecode loaded!', 'success');
                runBtn.disabled = false;
            } catch (e) {
                log(`Failed to load bytecode: ${e}`, 'error');
                setStatus('Failed to load bytecode', 'error');
            }
        };
        
        // Run Bytecode
        runBtn.onclick = () => {
            try {
                log('Starting execution...');
                setStatus('Running...', 'loading');
                runtime.run();
                log('Execution completed!', 'success');
                clearStatus();
            } catch (e) {
                log(`Runtime error: ${e}`, 'error');
                setStatus('Execution failed', 'error');
            }
        };
        
        // Clear Output
        clearBtn.onclick = () => {
            output.textContent = '';
            output.className = 'output';
            clearStatus();
        };
        
        // Quick Examples
        window.runExample = (type) => {
            log(`Loading ${type} example...`);
            
            let bytecode;
            switch(type) {
                case 'hello':
                    // CONST 42; C_CALL1 print_int; STOP
                    bytecode = new Uint32Array([0x5B, 0x2A, 0x31, 0x00, 0x7F]);
                    break;
                case 'math':
                    // CONST 10; PUSH; CONST 20; ADDINT; PUSH; CONST 12; ADDINT; C_CALL1 print_int; STOP
                    bytecode = new Uint32Array([0x5B, 0x0A, 0x09, 0x5B, 0x14, 0x5E, 0x09, 0x5B, 0x0C, 0x5E, 0x31, 0x00, 0x7F]);
                    break;
                case 'stack':
                    // CONST 1; PUSH; CONST 2; PUSH; CONST 3; ACC 0; C_CALL1 print_int; STOP
                    bytecode = new Uint32Array([0x5B, 0x01, 0x09, 0x5B, 0x02, 0x09, 0x5B, 0x03, 0x00, 0x31, 0x00, 0x7F]);
                    break;
            }
            
            try {
                runtime.load_bytecode(bytecode);
                log(`Loaded ${type} example`);
                log('Running...');
                setStatus('Running example...', 'loading');
                runtime.run();
                log('Done!', 'success');
                clearStatus();
            } catch (e) {
                log(`Error: ${e}`, 'error');
                setStatus('Example failed', 'error');
            }
        };
        
        // Initialize on load
        initWasm();
        
        log('Welcome to RAML-RT!');
        log('Upload a .cmo or .out file, or try a quick example.');
    </script>
</body>
</html>
