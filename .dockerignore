# Build artifacts - don't include in Docker context
_build/
target/
*.o
*.cmo
*.cmi
*.cmx
*.cmxa
*.cmxs
*.a
*.so

# Bootstrap binaries (will be rebuilt in container)
minitusk
tusk

# Tusk local cache
.tusk/

# Git
.git/

# GitHub workflows (not needed in container)
.github/

# Documentation
docs/
assets/
*.md
!README.md

# Development files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# Test outputs
test-results/
coverage/

# LLM scratch files
llm/

# Docker files (don't copy Docker into Docker)
docker/
!docker/ocaml-toolchain.Dockerfile
!docker/ocaml-toolchain-run.sh
Dockerfile
.dockerignore

# Native build artifacts
native/**/*.o
packages/*/native/*.o

# Vendored OCaml generated toolchains and installs
vendor/ocaml/compiler/
vendor/ocaml/cross/*
!vendor/ocaml/cross/*.sh
!vendor/ocaml/cross/flexdll/
!vendor/ocaml/cross/targets/

# Local Docker working volumes
.docker/volumes/
