NT_EXPR","text":"f","width":1}]},{"type":"token","kind":"WHITESPACE","text":"\n","width":1},{"type":"node","kind":"ERROR","width":2,"children":[{"type":"token","kind":"IDENT_EXPR","text":"xs","width":2}]}]},"diagnostics":[{"kind":{"id":"E0007","name":"invalid-pattern","expected":"identifier or pattern","found":{"kind":"keyword","text":"rec"},"fix":"use a different name like rec_","hint":"\nThe left side of a let-expression allows you to pattern match on values to assign them to variables, but also to deconstruct them and access their inner values.\n\n   ```ocaml\n   let variable = 42 in\n   let { x; _ } = point in\n   let Some x = optional in\n   (* ... *)\n   ```\n\nBeware that pattern matching on only one of many possible values will lead to runtime errors!\n"},"span":{"start":7,"end":8}},{"kind":{"id":"E0003","name":"missing-let-binding-equals","expected":"=","found":{"kind":"identifier","text":"map"},"fix":"add = between the pattern and expression","hint":"Every let binding needs an = between the pattern and the expression."},"span":{"start":7,"end":7}},{"kind":{"id":"E0008","name":"invalid-expression","expected":"expression","found":{"kind":"::","text":"::"},"hint":"Expected a value, function call, or operator expression."},"span":{"start":55,"end":55}},{"kind":{"id":"E0020","name":"missing-binary-operand","expected":"left operand for ::","found":{"kind":"::","text":"::"},"fix":"add an expression before the operator","hint":"Binary operators like +, -, *, =, etc. require both a left and right operand.\n\nFor example:\n  ```ocaml\n  let x = 1 + 2   (* correct *)\n  let y = 1 +     (* missing right operand *)\n  let z = + 2     (* missing left operand *)\n  ```\n\nIf you want to create a partially applied operator function, use parentheses:\n  ```ocaml\n  let add_one = (+) 1\n  ```\n"},"span":{"start":58,"end":59}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"->","text":"->"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":64,"end":65}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"f"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":66,"end":67}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"x"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":68,"end":69}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"::","text":"::"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":71,"end":72}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"map"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":75,"end":76}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"f"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":77,"end":78}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"xs"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":80,"end":81}}]}
