","text":"\n","width":1},{"type":"node","kind":"ERROR","width":5,"children":[{"type":"token","kind":"IDENT_EXPR","text":"value","width":5}]}]},"diagnostics":[{"kind":{"id":"E0007","name":"invalid-pattern","expected":"identifier or pattern","found":{"kind":"keyword","text":"module"},"fix":"use a different name like module_","hint":"\nThe left side of a let-expression allows you to pattern match on values to assign them to variables, but also to deconstruct them and access their inner values.\n\n   ```ocaml\n   let variable = 42 in\n   let { x; _ } = point in\n   let Some x = optional in\n   (* ... *)\n   ```\n\nBeware that pattern matching on only one of many possible values will lead to runtime errors!\n"},"span":{"start":10,"end":11}},{"kind":{"id":"E0003","name":"missing-let-binding-equals","expected":"=","found":{"kind":"identifier","text":"M"},"fix":"add = between the pattern and expression","hint":"Every let binding needs an = between the pattern and the expression."},"span":{"start":10,"end":10}},{"kind":{"id":"E0008","name":"invalid-expression","expected":"expression","found":{"kind":"keyword","text":"val"},"hint":"Expected a value, function call, or operator expression."},"span":{"start":19,"end":20}},{"kind":{"id":"E0014","name":"unclosed-delimiter","expected":")","found":{"kind":":","text":":"},"fix":"add ) to close the parenthesis","hint":"Delimiters like (, [, {, begin must be properly closed with ), ], }, end respectively."},"span":{"start":21,"end":21}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":":","text":":"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":23,"end":24}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"S"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":25,"end