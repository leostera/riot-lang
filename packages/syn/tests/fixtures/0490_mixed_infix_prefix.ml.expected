cs":[{"kind":{"id":"E0020","name":"missing-binary-operand","expected":"left operand for -","found":{"kind":"-","text":"-"},"fix":"add an expression before the operator","hint":"Binary operators like +, -, *, =, etc. require both a left and right operand.\n\nFor example:\n  ```ocaml\n  let x = 1 + 2   (* correct *)\n  let y = 1 +     (* missing right operand *)\n  let z = + 2     (* missing left operand *)\n  ```\n\nIf you want to create a partially applied operator function, use parentheses:\n  ```ocaml\n  let add_one = (+) 1\n  ```\n"},"span":{"start":9,"end":10}},{"kind":{"id":"E0008","name":"invalid-expression","expected":"expression","found":{"kind":"!","text":"!"},"hint":"Expected a value, function call, or operator expression."},"span":{"start":15,"end":16}},{"kind":{"id":"E0008","name":"invalid-expression","expected":"expression","found":{"kind":"~","text":"~"},"hint":"Expected a value, function call, or operator expression."},"span":{"start":20,"end":21}}]}
