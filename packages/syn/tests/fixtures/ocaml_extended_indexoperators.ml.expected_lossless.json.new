      },
      "text": "{|\n\nlet (.?[]) = Hashtbl.find_opt;;\nval ( .?[] ) : ('a, 'b) Hashtbl.t -> 'a -> 'b option = <fun>\n\nlet (.@[]) = Hashtbl.find;;\nval ( .@[] ) : ('a, 'b) Hashtbl.t -> 'a -> 'b = <fun>\n\nlet (.@[]<-) = Hashtbl.add;;\nval ( .@[]<- ) : ('a, 'b) Hashtbl.t -> 'a -> 'b -> unit = <fun>\n\nlet (.@{}) = Hashtbl.find;;\nval ( .@{} ) : ('a, 'b) Hashtbl.t -> 'a -> 'b = <fun>\n\nlet (.@{}<-) = Hashtbl.add;;\nval ( .@{}<- ) : ('a, 'b) Hashtbl.t -> 'a -> 'b -> unit = <fun>\n\nlet (.@()) = Hashtbl.find;;\nval ( .@() ) : ('a, 'b) Hashtbl.t -> 'a -> 'b = <fun>\n\nlet (.@()<-) = Hashtbl.add;;\nval ( .@()<- ) : ('a, 'b) Hashtbl.t -> 'a -> 'b -> unit = <fun>\n|}",
      "leading_trivia": [
        {
          "span": {
            "start": 262,
