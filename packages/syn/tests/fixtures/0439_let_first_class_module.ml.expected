n values to assign them to variables, but also to deconstruct them and access their inner values.\n\n   ```ocaml\n   let variable = 42 in\n   let { x; _ } = point in\n   let Some x = optional in\n   (* ... *)\n   ```\n\nBeware that pattern matching on only one of many possible values will lead to runtime errors!\n"},"span":{"start":11,"end":12}},{"kind":{"id":"E0003","name":"missing-let-binding-equals","expected":"=","found":{"kind":"identifier","text":"M"},"fix":"add = between the pattern and expression","hint":"Every let binding needs an = between the pattern and the expression."},"span":{"start":11,"end":11}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"keyword","text":"in"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":21,"end":22}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"M"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":23,"end":24}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":".","text":"."},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":24,"end":25}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"f"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":25,"end":26}},{"kind":{"id":"E0005","name":"unexpected-structure-item","expected":"structure item (e.g., let, type, module)","found":{"kind":"identifier","text":"x"},"hint":"Structure items are top-level declarations like let, type, or module."},"span":{"start":27,"end":28}}]}
