let find_colon = fun text ->
    let rec loop index paren_depth =
      if index >= String.length text then
        None
      else
        match String.get text index with
        | '(' -> loop (index + 1) (paren_depth + 1)
        | ')' -> loop (index + 1) (Int.max 0 (paren_depth - 1))
        | ':' when paren_depth = 0 -> Some index
        | _ -> loop (index + 1) paren_depth
    in
    loop 0 0
