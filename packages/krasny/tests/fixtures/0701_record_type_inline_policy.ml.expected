type small = { left: int; right: string }

type policy = {
  failure_threshold: int;
  reset_after: Time.Duration.t;
}

type pooled_connection = {
  key: string;
  conn: Connection.t;
  mutable last_used_at: Time.Instant.t;
}

type state = {
  client: t;
  connection: connection;
  mutable buffer: string;
  mutable done_: bool;
}

type single_mutable = { mutable value: int }
