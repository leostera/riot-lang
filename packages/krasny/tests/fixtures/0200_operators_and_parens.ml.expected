let mixed_ops = 1 + 2 * 3 - 4 / 2

let float_add = 1.0 +. 2.0

let eq = a = b

let neq = a != b

let lt = a < b

let gt = a > b

let lte = a <= b

let gte = a >= b

let string_eq = left = right

let bool_eq = left = right

