let make : type socket err. reader:(socket, err) reader ->
writer:(socket, err) writer ->
of_io_error:(err -> error) ->
uri:uri ->
t = fun ~reader ~writer ~of_io_error ~uri -> make_conn reader writer of_io_error uri

let perform : type a b. (a, b) step_callback = fun k eff -> k eff

