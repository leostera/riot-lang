let test = fun _ctx ->
  let* () =
    expect_string_equal
      ~label:"ansi to_string"
      ~expected:"ANSI(9)"
      ~actual:(to_string (`ansi 9 :> color))
  in
  let* () =
    expect_prefix
      ~label:"uv to_string"
      ~prefix:"UV("
      ~actual:(to_string (`uv (0.1, 0.2) :> color))
  in
  Ok ()
