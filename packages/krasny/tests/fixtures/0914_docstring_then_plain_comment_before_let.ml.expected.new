let slot = fun ?(attrs = []) children ->
  El {
    tag = "slot";
    attrs;
    children;
  }

let template ?(attrs = []) children =
  El {
    tag = "template";
    attrs;
    children;
  }

(** Rendering *)
(* Self-closing tags per HTML5 spec *)
let self_closing_tags =
  [
    "area";
    "base";
    "br";
    "col";
    "embed";
    "hr";
    "img";
    "input";
    "link";
    "meta";
    "source";
    "track";
    "wbr";
  ]
