(** Model Context Protocol (MCP) implementation for OCaml *)
open Std

(** {1 Core Types} *)

type protocol_version = string
(** Protocol version string (e.g., "2024-11-05") *)
type json = Data.Json.t
(** JSON type alias *)
(** {2 JSON-RPC Base Types} *)

type request_id =
  String of string
  | Number of int
(** JSON-RPC request ID *)
type error_code = int
(** JSON-RPC error code *)
type error = {
  code: error_code;
  message: string;
  data: json option;
}
(** JSON-RPC error *)
(** {2 Client/Server Info} *)

type client_info = {
  name: string;
  version: string;
}
type server_info = {
  name: string;
  version: string;
}
(** {2 Capabilities} *)

type tool_capability = unit
(** Empty for now, can be extended *)
