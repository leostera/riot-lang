let build_config budget_policy transport =
  let config =
    H.Config.make
      ~retry_policy:(H.RetryPolicy.make ~max_attempts:1 ())
      ~budget_policy
      ~transport
      ()
  in
  config

let apply_headers = fun request headers ->
  List.fold_left
    headers
    ~init:request
    ~fn:(fun request (name, value) ->
      Net.Http.Request.with_header request name value)
