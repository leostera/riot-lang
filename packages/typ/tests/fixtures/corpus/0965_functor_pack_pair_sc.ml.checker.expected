module type BOX = sig type t val value : t end
module Make : (X : BOX) -> sig type t = X.t val value : X.t end
module Seed : sig type t = string * char val value : t end
module Built : sig type t = Seed.t val value : Seed.t end
val packed : (module BOX with type t = string * char)
val answer : string * char
