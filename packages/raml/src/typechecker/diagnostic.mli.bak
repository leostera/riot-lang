(** Type Checker Diagnostics
    
    Structured, typed error and warning messages from the type checker.
    Designed for:
    - User-friendly error messages
    - IDE integration (LSP)
    - Testing
    - Error recovery
*)

(** {1 Severity Levels} *)

type severity =
  | Error   (** Fatal error - compilation cannot proceed *)
  | Warning (** Non-fatal issue - compilation can continue *)
  | Info    (** Informational message *)
  | Hint    (** Suggestion for improvement *)

(** {1 Diagnostic Categories} *)

type category =
  | TypeError
  | UnboundName
  | PatternMatching
  | Scope
  | Syntax
  | NotSupported

(** {1 Diagnostic Types} *)

type t =
  (** {2 Type Errors} *)
  | TypeMismatch of {
      expected : Types.type_expr;
      got : Types.type_expr;
      context : string option;
      loc : Location.t option;
    }
  (** Expected type X but got type Y *)
  
  | OccursCheck of {
      var : Types.type_expr;
      in_type : Types.type_expr;
      loc : Location.t option;
    }
  (** Infinite type: type variable occurs in its own definition *)
  
  | ArityMismatch of {
      expected : int;
      got : int;
      what : string; (** "function", "type constructor", etc *)
      loc : Location.t option;
    }
  (** Wrong number of arguments/parameters *)
  
  (** {2 Name Resolution} *)
  
  | UnboundVariable of {
      name : string;
      loc : Location.t option;
      suggestions : string list; (** Did you mean? *)
    }
  (** Variable not in scope *)
  
  | UnboundType of {
      name : string;
      loc : Location.t option;
      suggestions : string list;
    }
  (** Type not defined *)
  
  | UnboundConstructor of {
      name : string;
      loc : Location.t option;
      suggestions : string list;
    }
  (** Constructor not defined *)
  
  | UnboundField of {
      name : string;
      record_type : Types.type_expr option;
      loc : Location.t option;
    }
  (** Record field not found *)
  
  | UnboundModule of {
      name : string;
      loc : Location.t option;
    }
  (** Module not found *)
  
  (** {3 Ambiguity} *)
  
  | AmbiguousName of {
      name : string;
      candidates : string list;
      loc : Location.t option;
    }
  (** Name could refer to multiple things *)
  
  (** {2 Pattern Matching} *)
  
  | NonExhaustiveMatch of {
      missing_patterns : string list;
      loc : Location.t option;
    }
  (** Pattern match is not exhaustive *)
  
  | UnusedMatch of {
      pattern : string;
      loc : Location.t option;
    }
  (** Pattern will never match (redundant) *)
  
  | PatternTypeMismatch of {
      pattern : string;
      expected_type : Types.type_expr;
      got_type : Types.type_expr;
      loc : Location.t option;
    }
  (** Pattern has wrong type *)
  
  (** {2 Scope & Visibility} *)
  
  | EscapingType of {
      type_var : string;
      scope_level : int;
      loc : Location.t option;
    }
  (** Type variable escaping its scope *)
  
  | PrivateType of {
      name : string;
      loc : Location.t option;
    }
  (** Cannot access private type *)
  
  (** {2 Type Declarations} *)
  
  | CyclicTypeDefinition of {
      type_name : string;
      cycle : string list;
      loc : Location.t option;
    }
  (** Type definition is cyclic without indirection *)
  
  | DuplicateTypeParameter of {
      param : string;
      loc : Location.t option;
    }
  (** Type parameter used twice *)
  
  | UnboundTypeParameter of {
      param : string;
      in_type : string;
      loc : Location.t option;
    }
  (** Type parameter used but not declared *)
  
  | DuplicateConstructor of {
      name : string;
      previous_loc : Location.t option;
      loc : Location.t option;
    }
  (** Constructor defined multiple times *)
  
  | DuplicateField of {
      name : string;
      previous_loc : Location.t option;
      loc : Location.t option;
    }
  (** Record field defined multiple times *)
  
  (** {2 GADT-specific} *)
  
  | GADTEscapingType of {
      type_var : string;
      loc : Location.t option;
    }
  (** Existential type escaping GADT pattern *)
  
  | GADTTypeMismatch of {
      expected : Types.type_expr;
      got : Types.type_expr;
      equation : string;
      loc : Location.t option;
    }
  (** Type equation from GADT not satisfied *)
  
  (** {2 Warnings} *)
  
  | UnusedVariable of {
      name : string;
      loc : Location.t option;
    }
  (** Variable bound but never used *)
  
  | UnusedTypeParameter of {
      param : string;
      in_type : string;
      loc : Location.t option;
    }
  (** Type parameter declared but not used *)
  
  | PartialApplication of {
      func : string;
      expected_args : int;
      got_args : int;
      loc : Location.t option;
    }
  (** Function not fully applied *)
  
  | FragileMatch of {
      pattern : string;
      loc : Location.t option;
    }
  (** Pattern match on extensible variant *)
  
  (** {2 Not Implemented} *)
  
  | NotImplemented of {
      feature : string;
      loc : Location.t option;
    }
  (** Feature not yet implemented *)
  
  (** {2 General} *)
  
  | Custom of {
      severity : severity;
      category : category;
      message : string;
      loc : Location.t option;
    }
  (** Custom diagnostic message *)

(** {1 Diagnostic Construction} *)

val make :
  ?loc:Location.t ->
  ?severity:severity ->
  ?category:category ->
  t -> t

val severity : t -> severity
val category : t -> category
val location : t -> Location.t option
val message : t -> string

(** {1 Pretty Printing} *)

val to_string : t -> string
(** Human-readable error message *)

val to_string_with_context : source:string -> t -> string
(** Error message with source code context *)

val pp : Format.formatter -> t -> unit
(** Pretty-print diagnostic *)

(** {1 Diagnostic Collections} *)

type collection = {
  errors : t list;
  warnings : t list;
  infos : t list;
  hints : t list;
}

val empty_collection : collection

val add : t -> collection -> collection

val has_errors : collection -> bool

val error_count : collection -> int
val warning_count : collection -> int

val merge : collection -> collection -> collection

(** {1 Suggestions} *)

val suggest_similar : string -> string list -> string list
(** Find similar names using edit distance *)

val did_you_mean : string -> string list -> string option
(** Return best suggestion if close enough *)
