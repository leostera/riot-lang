(** Incremental Type Checker
    
    The ONLY way to type-check RAML programs.
    
    Designed for:
    - LSP servers (fast re-checking on edits)
    - Build systems (cache across builds)
    - REPLs (incremental evaluation)
    - Any tool that needs type information
    
    Key properties:
    - Always incremental (no separate "full check")
    - Automatic caching and invalidation
    - Dependency tracking built-in
    - Span-based change detection
*)

open Std

(** {1 Core Types} *)

type t
(** Incremental type checker state.
    
    Maintains:
    - Cached typed items
    - Environment snapshots
    - Dependency graph
    - Parse tree cache
    
    Thread-safe: No (single-threaded use)
    Persistent: No (in-memory only)
*)

type edit = {
  span : Syn.Ceibo.Span.t;
  old_text : string;
  new_text : string;
}
(** A single edit to the source code *)

type check_result = {
  typed_tree : TypedTree.structure;
  diagnostics : Diagnostic.collection;
  cache_stats : cache_stats;
}
(** Result of type checking *)

and cache_stats = {
  items_checked : int;      (** Total items in file *)
  items_cached : int;       (** Items reused from cache *)
  items_invalidated : int;  (** Items that needed re-checking *)
  dependencies_traced : int; (** Dependencies followed *)
}
(** Statistics about cache performance *)

(** {1 Creation} *)

val create : unit -> t
(** Create a new incremental type checker.
    
    Starts with empty cache.
    Use this once per file being edited.
    
    Example:
    {[
      let checker = IncrementalChecker.create () in
      (* Use for all subsequent checks of this file *)
    ]}
*)

(** {1 Type Checking} *)

val check :
  t ->
  source:string ->
  ?edits:edit list ->
  unit ->
  (check_result, string) result
(** Type check source code incrementally.
    
    On first call: Parses and checks entire file, builds cache.
    On subsequent calls: Only re-checks changed items and their dependents.
    
    Parameters:
    - [source]: Full source text (NOT a diff!)
    - [edits]: Optional hint about what changed (for optimization)
    
    Returns:
    - Typed tree for entire file
    - All diagnostics (errors + warnings)
    - Cache statistics
    
    Example:
    {[
      (* First check *)
      let result1 = check checker ~source:"let x = 42" () in
      (* items_cached = 0, items_checked = 1 *)
      
      (* Edit: change 42 to 43 *)
      let source2 = "let x = 43" in
      let result2 = check checker ~source:source2 () in
      (* items_cached = 0, items_checked = 1 (x changed) *)
      
      (* Add new binding *)
      let source3 = "let x = 43\nlet y = 99" in
      let result3 = check checker ~source:source3 () in
      (* items_cached = 1, items_checked = 1 (x cached, y new) *)
    ]}
*)

val check_expr :
  t ->
  source:string ->
  unit ->
  (TypedTree.expression * Diagnostic.collection, string) result
(** Type check a single expression (for REPL use).
    
    Like [check] but for expressions instead of structure items.
*)

(** {1 Cache Management} *)

val clear : t -> unit
(** Clear all cached data.
    
    Next [check] will be equivalent to first call.
    Use when you want to force a full re-check.
*)

val invalidate_item : t -> name:string -> unit
(** Invalidate a specific top-level item by name.
    
    Useful when you know exactly what changed externally.
*)

val get_stats : t -> cache_stats
(** Get current cache statistics *)

(** {1 Querying} *)

val get_type_at : t -> Syn.Ceibo.Span.t -> Types.type_expr option
(** Get the type of expression at given span.
    
    Returns [None] if:
    - Span doesn't point to a valid expression
    - File hasn't been checked yet
    - Type checking failed at that location
*)

val get_definition : t -> name:string -> Syn.Ceibo.Span.t option
(** Get the definition location of a name.
    
    Useful for "go to definition" in LSP.
*)

val get_usages : t -> name:string -> Syn.Ceibo.Span.t list
(** Get all usage locations of a name.
    
    Useful for "find references" in LSP.
*)

val get_completions : t -> Syn.Ceibo.Span.t -> string list
(** Get completion suggestions at a location.
    
    Returns all names in scope at the given position.
*)

(** {1 Multi-File Support} *)

type file_id = string
(** File identifier (typically absolute path) *)

type multi_file_checker
(** Type checker for multiple files with cross-file dependencies *)

val create_multi_file : unit -> multi_file_checker
(** Create a multi-file type checker *)

val check_file :
  multi_file_checker ->
  file_id:file_id ->
  source:string ->
  ?edits:edit list ->
  unit ->
  (check_result, string) result
(** Type check a file in multi-file context.
    
    Automatically:
    - Tracks cross-file dependencies
    - Invalidates dependent files
    - Re-exports for other files
*)

val get_file_dependencies : multi_file_checker -> file_id -> file_id list
(** Get files that this file depends on *)

val get_file_dependents : multi_file_checker -> file_id -> file_id list
(** Get files that depend on this file *)

(** {1 Advanced} *)

val set_options : t -> options -> unit
(** Set type checker options *)

and options = {
  cache_enabled : bool;
    (** Enable/disable caching (default: true) *)
  
  max_cache_size : int;
    (** Maximum cached items (default: 10000) *)
  
  trace_dependencies : bool;
    (** Track dependencies for invalidation (default: true) *)
  
  collect_unused : bool;
    (** Detect unused bindings (default: true) *)
  
  exhaustiveness_check : bool;
    (** Check pattern exhaustiveness (default: true) *)
}

val default_options : options
