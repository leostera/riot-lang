% Test #0501: comprehensive_all_features

% Comprehensive test combining all features
node(1).
node(2).
node(3).
edge(1, 2).
edge(2, 3).
value(1, 10).
value(2, 20).
value(3, 30).

% Rules with joins
connected(X, Y) :- edge(X, Y).
connected(X, Z) :- edge(X, Y), connected(Y, Z).

% Rules with negation
not_connected(X, Y) :- node(X), node(Y), !connected(X, Y), X != Y.

% Rules with built-ins
high_value(X) :- value(X, V), V > 15.

% Combined rules
high_value_connected(X, Y) :- connected(X, Y), high_value(X), high_value(Y).
