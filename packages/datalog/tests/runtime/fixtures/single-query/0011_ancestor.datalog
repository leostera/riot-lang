% Test: Ancestor relationship
% Description: Classic family tree with ancestor computation
% Expected: All ancestor-descendant pairs

parent("alice", "bob").
parent("alice", "carol").
parent("bob", "dave").
parent("bob", "eve").
parent("carol", "frank").

% Base case: parents are ancestors
ancestor(X, Y) :- parent(X, Y).

% Recursive case: ancestors of ancestors
ancestor(X, Z) :- parent(X, Y), ancestor(Y, Z).
