% Test: Stratified recursion with negation
% Description: Recursive reachability + negation of blocked nodes
% Expected: Properly stratified evaluation

edge(1, 2).
edge(2, 3).
edge(3, 4).

reachable(X, Y) :- edge(X, Y).
reachable(X, Y) :- edge(X, Z), reachable(Z, Y).

blocked(3).

reachable_not_blocked(X, Y) :- reachable(X, Y), !blocked(Y).

