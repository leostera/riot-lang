% Test: Multiple different predicates interacting
% Description: Complex interactions between different kinds of relations
% Expected: Queries spanning multiple derived predicates

% People and their ages
person("alice", 30).
person("bob", 25).
person("charlie", 35).
person("diana", 28).

% Employment relationships
works_at("alice", "techcorp").
works_at("bob", "techcorp").
works_at("charlie", "medcorp").
works_at("diana", "lawfirm").

% Manages relationships
manages("alice", "bob").
manages("charlie", "diana").

% Colleagues work at same company
colleague(X, Y) :- works_at(X, C), works_at(Y, C), X != Y.

% Senior is older and manages
senior(X, Y) :- manages(X, Y), person(X, AgeX), person(Y, AgeY), AgeX > AgeY.

% Mentor is senior colleague
mentor(X, Y) :- senior(X, Y), colleague(X, Y).
