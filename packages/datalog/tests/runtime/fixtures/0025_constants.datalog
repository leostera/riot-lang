% Test: Constants in rules
% Description: Rules that match specific constant values
% Expected: Filter results based on constants

person("alice", 25, "engineer").
person("bob", 30, "doctor").
person("charlie", 25, "engineer").
person("diana", 35, "lawyer").

% Find all engineers
engineer(Name) :- person(Name, _, "engineer").

% Find all people aged 25
age_25(Name) :- person(Name, 25, _).
