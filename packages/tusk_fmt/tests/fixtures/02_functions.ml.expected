(*  Test: Functions and applications  *)
(*  Anonymous function  *)
let f = fun x -> x + 1

(*  Multiple parameters  *)
let add = fun x y -> x + y

(*  Nested functions  *)
let compose = fun f g -> fun x -> f (g x)

(*  Function application  *)
let result = add 12

(*  Complex application  *)
let result2 = Std.List.map (fun x -> x * 2) [1; 2; 3]

(*  Partial application  *)
let add5 = add 5

(*  Labeled arguments  *)
let create ~name ~age = { name = name; age = age }

(*  Optional arguments  *)
let greet ?title name = 
  match title with
  | None -> "Hello " ^ name
  | Some t -> "Hello " ^ t ^ " " ^ name

(*  Unit argument  *)
let print_hello () = Std.println "Hello"
