(*  Test: Module system  *)
(*  Simple module  *)
module MyModule = struct
  let x = 42
  let f y = x + y
end

(*  Module signature  *)
module type COMPARABLE = sig
  type t
  val compare: t -> t -> int
end

(*  Module with signature  *)
module IntComparable: COMPARABLE = struct
    type t = int
  let compare = Std.Int.compare
end

(*  Nested modules  *)
module Outer = struct
  module Inner = struct
    let value = 100
  end
  let get_inner() = Inner.value
end

(*  Module include  *)
module Extended = struct
  include MyModule
  let y = 100
end

(*  Module open  *)
let result =
  let open MyModule in 
  f 10

(*  Local open  *)
let result2 = MyModule.(f 10)

(*  Functor  *)
module Make(M: COMPARABLE) = struct
  let is_equal a b = M.compare a b = 0
end

(*  First-class modules  *)
let packed = (module IntComparable: COMPARABLE)

(*  Module type of  *)
module type S = module type of MyModule
