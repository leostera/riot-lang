(*  Test: Operators and precedence  *)
(*  Arithmetic  *)
let sum = 1 + 2 + 3

let product = 2 * 3 * 4

let mixed = 1 + 2 * 3 - 4 / 2

let modulo = 10 mod 3

let power = 2. * * 8.

(*  Comparison  *)
let equal = x = y

let not_equal = x <> y

let less = x < y

let greater = x > y

let less_equal = x <= y

let greater_equal = x >= y

(*  Boolean  *)
let and_op = true && false

let or_op = true
|
| false

let not_op = not true

(*  Complex boolean  *)
let complex_bool = (x > 0&&x < 10)
|
|(x > 20&&x < 30)

(*  String concatenation  *)
let concat = "Hello" ^ " " ^ "World"

(*  List cons  *)
let list = 1 :: 2 :: 3 ::[]

(*  Function composition  *)
let (> >) f g x = g (f x)

let (< <) f g x = f (g x)

(*  Pipe operators  *)
let (| >) x f = f x

let (<
|)f x = f x

(*  Using pipe  *)
let result =[1;
2;
3]
| > Std.List.map (fun x -> x * 2)
| > Std.List.filter (fun x -> x > 2)
| > Std.List.fold_left (+) 0

(*  Reference operators  *)
let ref_ops ()=

let x = ref 0 in x:=!x + 1;
!x

(*  Physical equality  *)
let phys_equal = x = = y

let phys_not_equal = x! = y

(*  Bitwise operators  *)
let bit_and = 0b1010 land 0b1100

let bit_or = 0b1010 lor 0b1100

let bit_xor = 0b1010 lxor 0b1100

let bit_not = lnot 0b1010

let bit_shift_left = 1 lsl 3

let bit_shift_right = 8 lsr 1
