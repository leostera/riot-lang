(*  Test: Real-world code patterns from this codebase  *)
open Std

(*  Path manipulation  *)
let process_file path =

let path = Path.v"src" / Path.v"main.ml" in match Fs.read path with
  |Ok content -> Std.println"Read   %d   bytes"(String.length content)
  |Error err -> Std.Log.error"Failed:   %s"err

  (*  Result handling  *)
  let safe_operation ()= Fs.read (Path.v"config.toml")
  | > Result.map String.trim
  | > Result.and_then (fun s -> Ok (String.length s))
  | > Result.expect ~msg: "Config   required"

  (*  Collections  *)
  let process_items items =

  let map = Collections.HashMap.create ()in Std.List.iter (fun item -> Collections.HashMap.add map item.id item) items; map

  (*  Module with types  *)
  module Config =struct
    type t ={host: string; port: int; debug: bool;}
    let default ={host = "localhost"; port = 8080; debug = false ;}
    let from_env ()= match Env.get"PORT" with
      |Some port_str ->{default with port = int_of_string port_str}
      |None -> default(*  Pattern matching with guards  *)
      let classify_request req = match req. method , req.path with
        |`GET, path when String.starts_with ~prefix: "/api"path -> `Api
        |`GET, "/" -> `Index
        |`GET, path when String.ends_with ~suffix: ".html"path -> `Static
        |_ -> `NotFound
      end
