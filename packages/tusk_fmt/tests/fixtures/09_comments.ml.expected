(*  Test: Comment preservation  *)
(*  Single line comment  *)
let x = 42

(** * Documentation comment  *)
let documented = "value"

(*  Multi-line comment
   spanning multiple
   lines  *)
let y = 100

let z =
  (*  inline comment  *)
  50

(*  Comment before  *)
let a =
  (*  Comment inside  *)
  10 +
  (*  another inline  *)
  20

(** * Module documentation  *)
module M = struct
  (** * Function documentation  *)
  let f x = x + 1

  (*  Regular comment  *)
  let g = 42
end

(*  Nested comments (* like (* this *) *)  *)
let nested = true

(* 
 * Formatted comment block
 * with multiple lines
 * and asterisks
  *)
let formatted = "block"
