{
  "method": "POST",
  "path": "/webhook",
  "version": "HTTP/1.1",
  "headers": {
    "Host": "webhook.example.com",
    "Content-Type": "application/json",
    "X-Webhook-Signature": "sha256=abcdef1234567890",
    "X-Webhook-ID": "evt_1234567890",
    "Content-Length": "45"
  },
  "body": "{\"event\":\"user.created\",\"user_id\":\"usr_123\"}"
}
