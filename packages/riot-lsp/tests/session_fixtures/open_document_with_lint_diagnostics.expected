{
  "outbound": [
    {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "capabilities": {
          "positionEncoding": "utf-16",
          "textDocumentSync": {
            "openClose": true,
            "change": 1
          },
          "documentFormattingProvider": true,
          "definitionProvider": true,
          "hoverProvider": true,
          "completionProvider": {
            "resolveProvider": false,
            "triggerCharacters": [
              "."
            ]
          },
          "inlayHintProvider": true,
          "documentSymbolProvider": true,
          "codeActionProvider": {
            "codeActionKinds": [
              "quickfix",
              "source.fixAll"
            ],
            "resolveProvider": false
          }
        },
        "serverInfo": {
          "name": "riot-lsp"
        }
      }
    },
    {
      "params": {
        "diagnostics": [
          {
            "message": "Type names should be descriptive instead of using single-letter placeholders, except for t",
            "range": {
              "start": {
                "line": 0,
                "character": 5
              },
              "end": {
                "line": 0,
                "character": 6
              }
            },
            "severity": 2,
            "code": "avoid-single-letter-type-names",
            "source": "riot-fix",
            "data": {
              "severity": "warning",
              "message": "Type names should be descriptive instead of using single-letter placeholders, except for t",
              "span": {
                "start": 5,
                "end": 6
              },
              "rule_id": "avoid-single-letter-type-names",
              "suggestion": "Use a descriptive type name, or `t` for the module primary type",
              "fix": null
            }
          }
        ],
        "uri": "file:///workspace/app.ml",
        "version": 1
      },
      "jsonrpc": "2.0",
      "method": "textDocument/publishDiagnostics"
    }
  ],
  "exitCode": null,
  "state": {
    "initialized": true,
    "shutdownRequested": false,
    "documents": [
      {
        "uri": "file:///workspace/app.ml",
        "version": 1
      }
    ]
  }
}
