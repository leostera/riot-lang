{
  "outbound": [
    {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "capabilities": {
          "positionEncoding": "utf-16",
          "textDocumentSync": {
            "openClose": true,
            "change": 1
          },
          "documentFormattingProvider": true,
          "codeActionProvider": false
        },
        "serverInfo": {
          "name": "riot-lsp"
        }
      }
    },
    {
      "params": {
        "diagnostics": [],
        "uri": "file:///workspace/app.ml",
        "version": 1
      },
      "jsonrpc": "2.0",
      "method": "textDocument/publishDiagnostics"
    },
    {
      "jsonrpc": "2.0",
      "id": 2,
      "result": [
        {
          "range": {
            "start": {
              "line": 0,
              "character": 0
            },
            "end": {
              "line": 1,
              "character": 0
            }
          },
          "newText": "let answer = 42\n"
        }
      ]
    }
  ],
  "exitCode": null,
  "state": {
    "initialized": true,
    "shutdownRequested": false,
    "documents": [
      {
        "uri": "file:///workspace/app.ml",
        "version": 1
      }
    ]
  }
}
