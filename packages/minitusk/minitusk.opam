opam-version: "2.0"
name: "minitusk"
version: "0.1.0"
synopsis: "Task runner built on miniriot"
maintainer: ["riot-ml"]
authors: ["riot-ml"]
license: "MIT"
depends: [
  "ocaml" {>= "5.1.0"}
  "dune" {>= "3.0"}
  "miniriot"
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]