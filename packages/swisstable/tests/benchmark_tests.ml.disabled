open Kernel

let () = Global.println "SwissTable vs HashMap Benchmark\n"

(* Helper to measure execution time *)
let time_it name f =
  let start = Unix.gettimeofday () in
  let result = f () in
  let elapsed = Unix.gettimeofday () -. start in
  Global.println ((%s: %.6f seconds ^ " " ^ string_of_int(name elapsed)));
  result

(* Benchmark 1: Sequential inserts *)
let bench_sequential_inserts n =
  Global.println ((\n=== Benchmark: %d sequential inserts === ^ " " ^ string_of_int(n)));
  
  let () = time_it "  SwissTable" (fun () ->
    let map = Swisstable.create () in
    for i = 0 to n - 1 do
      let key = "key_" ^ Global.string_of_int i in
      let _ = Swisstable.insert map key i in
      ()
    done;
    assert (Swisstable.len map = n)
  ) in
  
  let () = time_it "  HashMap   " (fun () ->
    let map = Kernel.Collections.HashMap.create () in
    for i = 0 to n - 1 do
      let key = "key_" ^ Global.string_of_int i in
      let _ = Kernel.Collections.HashMap.insert map key i in
      ()
    done;
    assert (Kernel.Collections.HashMap.len map = n)
  ) in
  ()

(* Benchmark 2: Lookups *)
let bench_lookups n =
  Global.println ((\n=== Benchmark: %d lookups === ^ " " ^ string_of_int(n)));
  
  (* Prepare SwissTable *)
  let smap = Swisstable.create () in
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    let _ = Swisstable.insert smap key i in
    ()
  done;
  
  (* Prepare HashMap *)
  let hmap = Kernel.Collections.HashMap.create () in
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    let _ = Kernel.Collections.HashMap.insert hmap key i in
    ()
  done;
  
  let () = time_it "  SwissTable" (fun () ->
    for i = 0 to n - 1 do
      let key = "key_" ^ Global.string_of_int i in
      match Swisstable.get smap key with
      | Some v -> assert (v = i)
      | None -> failwith "SwissTable lookup failed"
    done
  ) in
  
  let () = time_it "  HashMap   " (fun () ->
    for i = 0 to n - 1 do
      let key = "key_" ^ Global.string_of_int i in
      match Kernel.Collections.HashMap.get hmap key with
      | Some v -> assert (v = i)
      | None -> failwith "HashMap lookup failed"
    done
  ) in
  ()

(* Benchmark 3: Mixed operations *)
let bench_mixed n =
  Global.println ((\n=== Benchmark: %d mixed operations === ^ " " ^ string_of_int(n)));
  
  Random.self_init ();
  
  let () = time_it "  SwissTable" (fun () ->
    let map = Swisstable.create () in
    for i = 0 to n - 1 do
      let op = Random.int 10 in
      if op < 6 then begin
        (* Insert *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Swisstable.insert map key i in
        ()
      end else if op < 8 then begin
        (* Lookup *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Swisstable.get map key in
        ()
      end else begin
        (* Remove *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Swisstable.remove map key in
        ()
      end
    done
  ) in
  
  Random.self_init ();
  
  let () = time_it "  HashMap   " (fun () ->
    let map = Kernel.Collections.HashMap.create () in
    for i = 0 to n - 1 do
      let op = Random.int 10 in
      if op < 6 then begin
        (* Insert *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Kernel.Collections.HashMap.insert map key i in
        ()
      end else if op < 8 then begin
        (* Lookup *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Kernel.Collections.HashMap.get map key in
        ()
      end else begin
        (* Remove *)
        let key = "key_" ^ Global.string_of_int (Random.int (n / 2)) in
        let _ = Kernel.Collections.HashMap.remove map key in
        ()
      end
    done
  ) in
  ()

(* Benchmark 4: Iteration *)
let bench_iteration n =
  Global.println ((\n=== Benchmark: iteration over %d elements === ^ " " ^ string_of_int(n)));
  
  (* Prepare SwissTable *)
  let smap = Swisstable.create () in
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    let _ = Swisstable.insert smap key i in
    ()
  done;
  
  (* Prepare HashMap *)
  let hmap = Kernel.Collections.HashMap.create () in
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    let _ = Kernel.Collections.HashMap.insert hmap key i in
    ()
  done;
  
  let () = time_it "  SwissTable iter" (fun () ->
    let count = ref 0 in
    Swisstable.iter (fun _ _ -> incr count) smap;
    assert (!count = n)
  ) in
  
  let () = time_it "  HashMap iter   " (fun () ->
    let count = ref 0 in
    Kernel.Collections.HashMap.iter (fun _ _ -> incr count) hmap;
    assert (!count = n)
  ) in
  
  let () = time_it "  SwissTable fold" (fun () ->
    let sum = Swisstable.fold (fun _ v acc -> acc + v) smap 0 in
    assert (sum = (n - 1) * n / 2)
  ) in
  
  let () = time_it "  HashMap fold   " (fun () ->
    let sum = Kernel.Collections.HashMap.fold (fun _ v acc -> acc + v) hmap 0 in
    assert (sum = (n - 1) * n / 2)
  ) in
  ()

(* Benchmark 5: Memory overhead (estimated) *)
let bench_memory () =
  Global.println "\n=== Memory Overhead Estimate ===";
  
  let n = 10000 in
  
  (* SwissTable overhead: 
     - buckets array: n * (Some overhead + tuple overhead + key + value)
     - ctrl array: n bytes + Group.width bytes
     - Plus record overhead
  *)
  let swiss_overhead = n + 8 in (* Just control bytes *)
  
  (* HashMap (Hashtbl) overhead:
     - More complex internal structure
     - Typically ~16 bytes per entry
  *)
  let hash_overhead = n * 16 in
  
  Global.println ((  SwissTable: ~%d bytes control overhead ^ " " ^ string_of_int(swiss_overhead)));
  Global.println ((  HashMap:    ~%d bytes estimated overhead ^ " " ^ string_of_int(hash_overhead)));
  Global.println ((  SwissTable uses ~%.1fx less overhead ^ " " ^ string_of_int())
    ((float_of_int hash_overhead) /. (float_of_int swiss_overhead)))

(* Run all benchmarks *)
let () =
  bench_sequential_inserts 10000;
  bench_lookups 10000;
  bench_mixed 10000;
  bench_iteration 10000;
  bench_memory ();
  
  Global.println "\n=== Larger Scale Tests ===";
  bench_sequential_inserts 100000;
  bench_lookups 100000;
  
  Global.println "\n✅ Benchmarks complete!"
