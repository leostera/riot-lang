open Kernel

let () = Global.println "SwissTable Stress Tests"

(* Test 1: Large number of sequential inserts *)
let test_large_sequential () =
  let map = Swisstable.create () in
  let n = 10000 in
  Global.println ((Inserting %d sequential elements... ^ " " ^ string_of_int(n)));
  
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    let _ = Swisstable.insert map key i in
    ()
  done;
  
  assert (Swisstable.len map = n);
  
  (* Verify all elements *)
  for i = 0 to n - 1 do
    let key = "key_" ^ Global.string_of_int i in
    match Swisstable.get map key with
    | Some v when v = i -> ()
    | _ -> Global.panic ("Verification failed at " ^ key)
  done;
  
  Global.println "✓ Test 1: 10k sequential inserts"

(* Test 2: Random inserts and lookups *)
let test_random_operations () =
  let map = Swisstable.create () in
  let n = 5000 in
  Global.println ((Performing %d random operations... ^ " " ^ string_of_int(n)));
  
  Random.self_init ();
  
  for i = 0 to n - 1 do
    let key = Global.string_of_int (Random.int 1000) in
    let value = Random.int 10000 in
    let _ = Swisstable.insert map key value in
    ()
  done;
  
  (* Perform random lookups *)
  for _ = 0 to 1000 do
    let key = Global.string_of_int (Random.int 1000) in
    let _ = Swisstable.get map key in
    ()
  done;
  
  Global.println "✓ Test 2: random operations"

(* Test 3: Insert, remove, reinsert pattern *)
let test_churn () =
  let map = Swisstable.create () in
  let n = 1000 in
  Global.println ((Testing churn with %d iterations... ^ " " ^ string_of_int(n)));
  
  for i = 0 to n - 1 do
    (* Insert *)
    let key = "key_" ^ Global.string_of_int i in
    let _ = Swisstable.insert map key i in
    
    (* Remove old entries *)
    if i > 100 then begin
      let old_key = "key_" ^ Global.string_of_int (i - 100) in
      let _ = Swisstable.remove map old_key in
      ()
    end
  done;
  
  (* Map should have ~100 elements *)
  assert (Swisstable.len map <= 101);
  
  Global.println "✓ Test 3: insert/remove churn"

(* Test 4: Many hash collisions (same hash bucket) *)
let test_hash_collisions () =
  let map = Swisstable.create () in
  Global.println "Testing hash collisions...";
  
  (* Insert many elements that may collide *)
  for i = 0 to 999 do
    let key = (i, "collision_test") in
    let _ = Swisstable.insert map key i in
    ()
  done;
  
  assert (Swisstable.len map = 1000);
  
  (* Verify all elements *)
  for i = 0 to 999 do
    let key = (i, "collision_test") in
    match Swisstable.get map key with
    | Some v when v = i -> ()
    | _ -> Global.panic "Collision test verification failed"
  done;
  
  Global.println "✓ Test 4: hash collisions"

(* Test 5: Stress test with mixed operations *)
let test_mixed_operations () =
  let map = Swisstable.create () in
  let n = 5000 in
  Global.println ((Mixed operations stress test (%d ops)... ^ " " ^ string_of_int(n)));
  
  Random.self_init ();
  let inserted_keys = ref [] in
  
  for i = 0 to n - 1 do
    let op = Random.int 10 in
    if op < 6 then begin
      (* 60% insert *)
      let key = "key_" ^ Global.string_of_int (Random.int 1000) in
      let _ = Swisstable.insert map key i in
      inserted_keys := key :: !inserted_keys
    end else if op < 8 then begin
      (* 20% remove *)
      if !inserted_keys <> [] then begin
        let idx = Random.int (List.length !inserted_keys) in
        let key = List.nth !inserted_keys idx in
        let _ = Swisstable.remove map key in
        ()
      end
    end else begin
      (* 20% lookup *)
      if !inserted_keys <> [] then begin
        let idx = Random.int (List.length !inserted_keys) in
        let key = List.nth !inserted_keys idx in
        let _ = Swisstable.get map key in
        ()
      end
    end
  done;
  
  Global.println "✓ Test 5: mixed operations stress test"

(* Test 6: Growing from empty multiple times *)
let test_multiple_growth_cycles () =
  Global.println "Testing multiple growth cycles...";
  
  for cycle = 1 to 10 do
    let map = Swisstable.create () in
    for i = 0 to 99 do
      let key = "cycle" ^ Global.string_of_int cycle ^ "_key" ^ Global.string_of_int i in
      let _ = Swisstable.insert map key i in
      ()
    done;
    assert (Swisstable.len map = 100)
  done;
  
  Global.println "✓ Test 6: multiple growth cycles"

(* Test 7: Very large map *)
let test_very_large () =
  let map = Swisstable.create () in
  let n = 50000 in
  Global.println ((Creating very large map (%d elements)... ^ " " ^ string_of_int(n)));
  
  for i = 0 to n - 1 do
    let key = "large_" ^ Global.string_of_int i in
    let _ = Swisstable.insert map key i in
    if i mod 10000 = 0 then
      Global.println ((  ... inserted %d elements ^ " " ^ string_of_int(i)))
  done;
  
  assert (Swisstable.len map = n);
  
  (* Sample verification *)
  for i = 0 to 99 do
    let idx = Random.int n in
    let key = "large_" ^ Global.string_of_int idx in
    match Swisstable.get map key with
    | Some v when v = idx -> ()
    | _ -> Global.panic "Large map verification failed"
  done;
  
  Global.println "✓ Test 7: very large map (50k elements)"

(* Test 8: String keys of varying lengths *)
let test_varying_key_lengths () =
  let map = Swisstable.create () in
  Global.println "Testing varying key lengths...";
  
  for i = 1 to 1000 do
    let key = String.make i 'x' in
    let _ = Swisstable.insert map key i in
    ()
  done;
  
  assert (Swisstable.len map = 1000);
  
  for i = 1 to 1000 do
    let key = String.make i 'x' in
    match Swisstable.get map key with
    | Some v when v = i -> ()
    | _ -> Global.panic "Varying key length test failed"
  done;
  
  Global.println "✓ Test 8: varying key lengths"

(* Test 9: Clear and refill *)
let test_clear_and_refill () =
  let map = Swisstable.create () in
  Global.println "Testing clear and refill...";
  
  for cycle = 1 to 5 do
    (* Fill *)
    for i = 0 to 999 do
      let key = "key_" ^ Global.string_of_int i in
      let _ = Swisstable.insert map key (i * cycle) in
      ()
    done;
    
    assert (Swisstable.len map = 1000);
    
    (* Clear *)
    Swisstable.clear map;
    assert (Swisstable.is_empty map)
  done;
  
  Global.println "✓ Test 9: clear and refill"

(* Test 10: Iteration over large map *)
let test_large_iteration () =
  let map = Swisstable.create () in
  let n = 10000 in
  Global.println ((Testing iteration over %d elements... ^ " " ^ string_of_int(n)));
  
  for i = 0 to n - 1 do
    let key = "iter_" ^ Global.string_of_int i in
    let _ = Swisstable.insert map key i in
    ()
  done;
  
  (* Test iter *)
  let count = ref 0 in
  Swisstable.iter (fun _ _ -> incr count) map;
  assert (!count = n);
  
  (* Test fold *)
  let sum = Swisstable.fold (fun _ v acc -> acc + v) map 0 in
  let expected_sum = (n - 1) * n / 2 in
  assert (sum = expected_sum);
  
  (* Test to_list *)
  let list = Swisstable.to_list map in
  assert (List.length list = n);
  
  Global.println "✓ Test 10: large iteration"

(* Run all stress tests *)
let () =
  test_large_sequential ();
  test_random_operations ();
  test_churn ();
  test_hash_collisions ();
  test_mixed_operations ();
  test_multiple_growth_cycles ();
  test_very_large ();
  test_varying_key_lengths ();
  test_clear_and_refill ();
  test_large_iteration ();
  Global.println "\n✅ All stress tests passed!"
