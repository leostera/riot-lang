  "js": "import * as Printf from \"./Printf.js\";\n\nconst double_if_some = (function(value) {\n  if ((value[0] === 0)) {\n    return [0];\n  } else {\n    const n = value[1];\n    return [1, (n + n)];\n  }\n});\n\nconst __raml_match_22 = double_if_some([1, 21]);\n\nif ((__raml_match_22[0] === 1)) {\n  const n = __raml_match_22[1];\n  Printf.printf(\"%d\\\\n\", n);\n} else {\n  print_endline(\"none\");\n}\n\nexport {\n  double_if_some\n};\n",
