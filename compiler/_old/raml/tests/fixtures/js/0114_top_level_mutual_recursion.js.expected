{
  "js": "import * as Printf from \"./Printf.js\";\n\nlet even;\n\nlet odd;\n\n(even = (function(n) {\n  if ((n <= 0)) {\n    return true;\n  } else {\n    return odd((n - 1));\n  }\n}));\n\n(odd = (function(n) {\n  if ((n <= 0)) {\n    return false;\n  } else {\n    return even((n - 1));\n  }\n}));\n\nconst result = even(10);\n\nPrintf.printf(\"%b\\\\n\", result);\n\nexport {\n  even,\n  odd,\n  result\n};\n",
