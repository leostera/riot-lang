{
  "js": "import * as Printf from \"./Printf.js\";\n\nlet even;\n\nlet odd;\n\n(even = (function(n) {\n  return ((n === 0) ? true : odd((n - 1)));\n}));\n\n(odd = (function(n) {\n  return ((n !== 0) ? even((n - 1)) : false);\n}));\n\nPrintf.printf(\"%b %b\\\\n\", even(10), odd(11));\n\nexport {\n  even,\n  odd\n};\n",
