.data
.globl _answer
.p2align 3
_answer:
.quad 0

.text
.globl _loop
.p2align 2
_loop:
stp x29, x30, [sp, #-16]!
mov x29, sp
sub sp, sp, #16
str x0, [sp, #0]
ldr x0, [sp, #0]
bl _loop
str x0, [sp, #8]
ldr x0, [sp, #8]
add sp, sp, #16
ldp x29, x30, [sp], #16
ret

.globl _apply
.p2align 2
_apply:
stp x29, x30, [sp, #-16]!
mov x29, sp
sub sp, sp, #32
str x0, [sp, #0]
str x1, [sp, #8]
ldr x0, [sp, #8]
ldr x16, [sp, #0]
blr x16
str x0, [sp, #16]
ldr x0, [sp, #16]
add sp, sp, #32
ldp x29, x30, [sp], #16
ret

.globl _inc
.p2align 2
_inc:
stp x29, x30, [sp, #-16]!
mov x29, sp
sub sp, sp, #16
str x0, [sp, #0]
ldr x0, [sp, #0]
bl _succ
str x0, [sp, #8]
ldr x0, [sp, #8]
add sp, sp, #16
ldp x29, x30, [sp], #16
ret

.globl _main
.p2align 2
_main:
stp x29, x30, [sp, #-16]!
mov x29, sp
sub sp, sp, #16
movz x9, #41, lsl #0
str x9, [sp, #0]
ldr x0, [sp, #0]
bl _inc
str x0, [sp, #8]
ldr x9, [sp, #8]
adrp x10, _answer@PAGE
add x10, x10, _answer@PAGEOFF
str x9, [x10, #0]
movz x0, #0, lsl #0
add sp, sp, #16
ldp x29, x30, [sp], #16
ret
