      "output": "import { makeCurried as __makeCurried } from \"./riot-runtime.js\";\n\nconst choose = (function(flag) {\n  const decide = __makeCurried((function(when_true, when_false) {\n    if (flag) {\n      return when_true;\n    } else {\n      return when_false;\n    }\n  }), 2);\n  return decide(\"left\", \"right\");\n});\n\nconst selected = choose(true);\n\nexport {\n  choose,\n  selected\n};\n",
