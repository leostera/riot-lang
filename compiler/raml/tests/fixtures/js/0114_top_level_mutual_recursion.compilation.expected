  "codegen": {
    "backend": "js",
    "stage": {
      "output": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive } from \"./riot-runtime.js\";\n\nlet even;\n\nlet odd;\n\n(even = (function(n) {\n  if (__callPrimitive(\"%le\", n, 0)) {\n    return true;\n  } else {\n    return odd(__callPrimitive(\"%subint\", n, 1));\n  }\n}));\n\n(odd = (function(n) {\n  if (__callPrimitive(\"%le\", n, 0)) {\n    return false;\n  } else {\n    return even(__callPrimitive(\"%subint\", n, 1));\n  }\n}));\n\nconst result = even(10);\n\nPrintf.printf(\"%b\\\\n\", result);\n\nexport {\n  even,\n  odd,\n  result\n};\n",
      "status": "ok"
    },
    "target": "js-unknown-ecma"
  },
