      "output": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive, makeCurried as __makeCurried } from \"./riot-runtime.js\";\n\nconst compose = __makeCurried((function(f, g, x) {\n  return f(g(x));\n}), 3);\n\nconst pipeline = compose((function(x) {\n  return __callPrimitive(\"%addint\", x, 1);\n}), compose((function(x) {\n  return __callPrimitive(\"%mulint\", x, 2);\n}), (function(x) {\n  return __callPrimitive(\"%subint\", x, 3);\n})));\n\nPrintf.printf(\"%d\\\\n\", pipeline(25));\n\nexport {\n  compose,\n  pipeline\n};\n",
