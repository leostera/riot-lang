{
  "js": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive } from \"./riot-runtime.js\";\n\nconst luminance = (function(color) {\n  if (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", color, 0), 0)) {\n    return 76;\n  } else {\n    if (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", color, 0), 1)) {\n      return 150;\n    } else {\n      if (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", color, 0), 2)) {\n        return 29;\n      } else {\n        const __raml_tuple_8 = __callPrimitive(\"%tuple_get\", color, 1);\n        const r = __callPrimitive(\"%tuple_get\", __raml_tuple_8, 0);\n        const g = __callPrimitive(\"%tuple_get\", __raml_tuple_8, 1);\n        const b = __callPrimitive(\"%tuple_get\", __raml_tuple_8, 2);\n        return __callPrimitive(\"%divint\", __callPrimitive(\"%addint\", __callPrimitive(\"%addint\", __callPrimitive(\"%mulint\", 3, r), __callPrimitive(\"%mulint\", 6, g)), b), 10);\n      }\n    }\n  }\n});\n\nconst sample = __callPrimitive(\"%tuple_make\", 3, __callPrimitive(\"%tuple_make\", 10, 20, 30));\n\nPrintf.printf(\"%d\\\\n\", luminance(sample));\n\nexport {\n  luminance,\n  sample\n};\n",
