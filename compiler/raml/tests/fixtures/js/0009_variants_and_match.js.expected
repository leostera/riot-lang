{
  "js": "import * as Printf from \"./Printf.js\";\n\nconst luminance = (function(color) {\n  if ((color[0] === 0)) {\n    return 76;\n  } else {\n    if ((color[0] === 1)) {\n      return 150;\n    } else {\n      if ((color[0] === 2)) {\n        return 29;\n      } else {\n        const __raml_tuple_8 = color[1];\n        const r = __raml_tuple_8[0];\n        const g = __raml_tuple_8[1];\n        const b = __raml_tuple_8[2];\n        return ((((3 * r) + (6 * g)) + b) / 10);\n      }\n    }\n  }\n});\n\nconst sample = [3, [10, 20, 30]];\n\nPrintf.printf(\"%d\\\\n\", luminance(sample));\n\nexport {\n  luminance,\n  sample\n};\n",
