      "output": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive, makeCurried as __makeCurried, print_endline as __print_endline } from \"./riot-runtime.js\";\n\nconst safe_div = __makeCurried((function(a, b) {\n  if (__callPrimitive(\"%eq\", b, 0)) {\n    return __callPrimitive(\"%tuple_make\", 0);\n  } else {\n    return __callPrimitive(\"%tuple_make\", 1, __callPrimitive(\"%divint\", a, b));\n  }\n}), 2);\n\nlet __raml_init_result;\n\n{\n  const __raml_match_22 = safe_div(84, 2);\n  if (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", __raml_match_22, 0), 0)) {\n    (__raml_init_result = __callPrimitive(\"%tuple_make\", 0));\n  } else {\n    const x = __callPrimitive(\"%tuple_get\", __raml_match_22, 1);\n    (__raml_init_result = safe_div(x, 3));\n  }\n}\n\nconst result = __raml_init_result;\n\nif (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", result, 0), 1)) {\n  const n = __callPrimitive(\"%tuple_get\", result, 1);\n  Printf.printf(\"%d\\\\n\", n);\n} else {\n  __print_endline(\"none\");\n}\n\nexport {\n  safe_div,\n  result\n};\n",
