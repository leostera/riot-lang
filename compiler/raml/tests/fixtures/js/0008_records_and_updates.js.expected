{
  "js": "import { makeCurried as __makeCurried } from \"./riot-runtime.js\";\n\nimport * as Printf from \"./Printf.js\";\n\nconst move = __makeCurried((function(dx, dy, p) {\n  return {x: (p.x + dx), y: (p.y + dy)};\n}), 3);\n\nconst p = {x: 1, y: 2};\n\nconst q = move(3, 4, p);\n\nPrintf.printf(\"(%d,%d) -> (%d,%d)\\\\n\", p.x, p.y, q.x, q.y);\n\nexport {\n  move\n};\n",
