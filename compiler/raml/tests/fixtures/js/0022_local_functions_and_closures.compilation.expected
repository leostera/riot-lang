    "stage": {
      "output": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive } from \"./riot-runtime.js\";\n\nconst make_adder = (function(base) {\n  const add = (function(x) {\n    return __callPrimitive(\"%addint\", base, x);\n  });\n  return add;\n});\n\nconst add7 = make_adder(7);\n\nPrintf.printf(\"%d\\\\n\", add7(35));\n\nexport {\n  make_adder\n};\n",
      "status": "ok"
    },
    "target": "js-unknown-ecma"
  },
