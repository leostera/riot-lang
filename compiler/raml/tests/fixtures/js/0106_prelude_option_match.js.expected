  "js": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive, print_endline as __print_endline } from \"./riot-runtime.js\";\n\nconst double_if_some = (function(value) {\n  if (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", value, 0), 0)) {\n    return __callPrimitive(\"%tuple_make\", 0);\n  } else {\n    const n = __callPrimitive(\"%tuple_get\", value, 1);\n    return __callPrimitive(\"%tuple_make\", 1, __callPrimitive(\"%addint\", n, n));\n  }\n});\n\nconst __raml_match_22 = double_if_some(__callPrimitive(\"%tuple_make\", 1, 21));\n\nif (__callPrimitive(\"%eq\", __callPrimitive(\"%tuple_get\", __raml_match_22, 0), 1)) {\n  const n = __callPrimitive(\"%tuple_get\", __raml_match_22, 1);\n  Printf.printf(\"%d\\\\n\", n);\n} else {\n  __print_endline(\"none\");\n}\n\nexport {\n  double_if_some\n};\n",
