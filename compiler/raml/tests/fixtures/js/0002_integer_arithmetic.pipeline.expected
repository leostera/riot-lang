    "js": {
      "output": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive } from \"./riot-runtime.js\";\n\nconst a = __callPrimitive(\"%addint\", 40, 2);\n\nconst b = __callPrimitive(\"%subint\", __callPrimitive(\"%mulint\", a, 3), 5);\n\nconst c = __callPrimitive(\"%divint\", b, 7);\n\nconst d = __callPrimitive(\"%modint\", b, 7);\n\nPrintf.printf(\"%d %d %d %d\\\\n\", a, b, c, d);\n\nexport {\n  a,\n  b,\n  c,\n  d\n};\n",
