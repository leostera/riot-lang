  "js": "import * as Printf from \"./Printf.js\";\n\nimport { callPrimitive as __callPrimitive } from \"./riot-runtime.js\";\n\nlet even;\n\nlet odd;\n\n(even = (function(n) {\n  return (__callPrimitive(\"%eq\", n, 0) ? true : odd(__callPrimitive(\"%subint\", n, 1)));\n}));\n\n(odd = (function(n) {\n  return (__callPrimitive(\"%neq\", n, 0) ? even(__callPrimitive(\"%subint\", n, 1)) : false);\n}));\n\nPrintf.printf(\"%b %b\\\\n\", even(10), odd(11));\n\nexport {\n  even,\n  odd\n};\n",
